   252 F2E1				org		$f3f6-8
   253
   254 				;==========================================================================
   255 				;==========================================================================
   256
   257 				;==========================================================================
   258 				;
   259 				; Return:
   260 				;	MEMTOP = first byte used by display
   261 				;
   262 				; Errors:
   263 				;	- If there is not enough memory (MEMTOP > APPMHI), GR.0 is reopened
   264 				;	  automatically and an error is returned.
   265 				;
   266 				; Notes:
   267 				;	- Resets character base (CHBAS).
   268 				;	- Resets character attributes (CHACT).
   269 				;	- Resets playfield colors (COLOR0-COLOR4).
   270 				;	- Resets tab map, even if the mode does not have a text window.
   271 				;	- Resets logical line map, even if the mode does not have a text window.
   272 				;	- Does NOT reset P/M colors (PCOLR0-PCOLR3).
   273 				;	- Does NOT reset margins (LMARGN/RMARGN).
   274 				;	- Sets up fine scrolling if FINE bit 7 is set. Note that this is
   275 				;	  different than the scroll logic itself, which tests the whole byte.
   276 				;	- Returns error $80 if BREAK has been pressed.
   277 				;	- If clear is bypassed, ROWCRS and COLCRS are preserved.
   278 				;
   279 				; Modified:
   280 				;	- FRMADR: used for bitflags
   281 				;		bit 7 = skip clear
   282 				;		bit 6 = split screen
   283 				;		bit 0 = fine scrolling (XL/XE only)
   284 				;	- ADRESS: temporary addressing
   285 				;
   286 = F3F6			ScreenOpen = ScreenOpenGr0.use_iocb
   287 = F3F2			ScreenOpenMode0 = ScreenOpenGr0.use_mode0
   288 F3EE			.proc	ScreenOpenGr0
   289 F3EE A9 0C 85 2A			mva		#12 icax1z
   290 F3F2			use_mode0:
   291 F3F2 A9 00 85 2B			mva		#0 icax2z
   292 F3F6			use_iocb:
   293 					;shut off ANTIC playfield and instruction DMA
   294 F3F6 AD 2F 02			lda		sdmctl
   295 F3F9 29 DC			and		#$dc
   296 F3FB 8D 2F 02			sta		sdmctl
   297 F3FE 8D 00 D4			sta		dmactl
   298 					
   299 					;reset cursor parameters
   300 F401 A2 0B			ldx		#11
   301 F403 A9 00			lda		#0
   302 F405			clear_parms:
   303 F405 95 54			sta		rowcrs,x
   304 F407 9D 90 02			sta		txtrow,x
   305 F40A CA				dex
   306 F40B D0 F8			bne		clear_parms
   307
   308 					;mark us as being in main screen context
   309 F40D 86 7B			stx		swpflg	
   310 					
   311 					;copy mode value to dindex
   312 F40F A5 2B			lda		icax2z
   313 F411 29 0F			and		#15
   314 F413 85 57			sta		dindex
   315 F415 AA				tax
   316 					
   317 					;poke PRIOR value (saves us some time to do it now)
   318 					;note that we must preserve bits 0-5 of GPRIOR or else Wayout shows logo artifacts
   319 F416 BD 89 F2			lda		ScreenModeTable,x
   320 F419 4D 6F 02			eor		gprior
   321 F41C 29 C0			and		#$c0
   322 F41E 4D 6F 02			eor		gprior
   323 F421 8D 6F 02			sta		gprior
   324 					
   325 					;if a GTIA mode is active, force off split mode
   326 					;if we're in mode 0, force off the no-clear flag (per OS Manual p.57)
   327 F424 C9 40			cmp		#$40		;test for GTIA mode and store in carry
   328 F426 8A				txa					;test for GR.0
   329 F427 F0 06			beq		is_gr0		;disable split screen and no-clear for GR.0
   330
   331 F429 A5 2A			lda		icax1z
   332 F42B 90 02 29 EF			scc:and	#$ef		;disable split screen for GTIA mode
   333 F42F			is_gr0:
   334
   335 					;save off the split screen and clear flags in a more convenient form
   336 F42F 0A				asl
   337 F430 0A				asl
   338 F431 85 68			sta		frmadr
   339 					
   340 					;compute number of mode lines that we're going to have and save it off
   341 F433 BC 99 F2			ldy		ScreenHeightShifts,x
   342 F436 BE A9 F2			ldx		ScreenHeights,y
   343 F439 0A				asl
   344 F43A 10 03 BE BE F2		spl:ldx	ScreenHeightsSplit,y
   345 F43F 86 69			stx		frmadr+1
   346
   347 					;attempt to allocate playfield memory
   348 F441 A5 6A			lda		ramtop
   349 F443 A6 57			ldx		dindex
   350 F445 18				clc
   351 F446 7D 79 F2			adc		ScreenPlayfieldSizesHi,x
   352 F449 B0 09			bcs		pf_alloc_ok
   353
   354 F44B			alloc_fail:
   355 					;we ran out of memory -- attempt to reopen with gr.0 if we aren't
   356 					;already (to prevent recursion), and exit with an error
   357 F44B 8A				txa
   358 F44C F0 03			beq		cant_reopen_gr0
   359 					
   360 F44E 20 EE F3			jsr		ScreenOpenGr0	
   361 F451			cant_reopen_gr0:
   362 F451 A0 93			ldy		#CIOStatOutOfMemory
   363 F453 60				rts
   364 					
   365 F454			pf_alloc_ok:
   366 F454 85 59			sta		savmsc+1
   367 F456 BC 69 F2			ldy		ScreenPlayfieldSizesLo,x
   368 F459 84 58			sty		savmsc
   369
   370 					;Gr. modes 7 and 14 consume enough space for the playfield that there
   371 					;is not enough space left between the playfield and the next 1K
   372 					;boundary to contain the display list. In these cases, we preallocate
   373 					;to the 1K boundary to prevent a DL crossing error. Gr.8-11 and 15
   374 					;do this too -- I have no idea why, as it's not like the OS correctly
   375 					;handles moving the 4K page split for those modes if RAMTOP is
   376 					;misaligned.
   377 F45B BD 89 F2			lda		ScreenModeTable,x
   378 F45E A6 59			ldx		savmsc+1
   379 F460 29 30			and		#$30
   380 F462 F0 03			beq		no_dlist_page_crossing
   381 F464 A0 00			ldy		#0
   382 F466 CA				dex
   383 F467			no_dlist_page_crossing:
   384 F467 84 70			sty		rowac
   385 F469 8E E6 02			stx		memtop+1
   386 F46C 86 71			stx		rowac+1
   387 F46E 8E 31 02			stx		sdlsth
   388 						
   389 					;Compute display list size.
   390 					;
   391 					; We need:
   392 					;	- 8 fixed bytes (24 blank lines, LMS address, JVB)
   393 					;	- N bytes for mode lines
   394 					;	- 2 bytes for LMS split address (ANTIC modes E-F only)
   395 					;	- 6 bytes for split
   396 					;
   397 					;Note that the display list never crosses a page boundary. This is
   398 					;conservative, as the display list only can't cross 1K boundaries.
   399 					
   400 F471 C9 20			cmp		#$20				;test 4K hop bit (bit 5)
   401 F473 A9 F8			lda		#$f8				;start with -8 (if carry is clear after test)
   402 F475 90 02 A9 F5			scc:lda	#$f5				;use -11 if so (carry is set)
   403 F479 E5 69			sbc		frmadr+1			;subtract mode line count
   404 F47B 24 68			bit		frmadr
   405 F47D 50 02 E9 06			svc:sbc	#6					;subtract 6 bytes for a split
   406 					
   407 				.if _KERNEL_XLXE
   408 F481 A0 01			ldy		#1
   409 F483 CC 6E 02			cpy		fine				;clear carry to alloc +1 byte if fine scrolling is enabled
   410 				.endif
   411
   412 F486 65 70			adc		rowac				;allocate dl bytes (note that carry is set!)
   413 F488 8D E5 02			sta		memtop
   414 F48B 85 70			sta		rowac
   415 F48D 8D 30 02			sta		sdlstl
   416 					
   417 					;check if we're below APPMHI
   418 F490 E4 0F			cpx		appmhi+1
   419 F492 90 B7			bcc		alloc_fail
   420 F494 D0 04			bne		alloc_ok
   421 F496 C5 0E			cmp		appmhi
   422 F498 90 B1			bcc		alloc_fail
   423 					
   424 F49A			alloc_ok:
   425 					;MEMTOP is -1 from first used byte; we cheat here with the knowledge that
   426 					;the low byte of MEMTOP is never $00
   427 F49A CE E5 02			dec		memtop
   428
   429 					;set up text window address (-160 from top)
   430 F49D A6 6A			ldx		ramtop
   431 F49F CA				dex
   432 F4A0 8E 95 02			stx		txtmsc+1
   433 F4A3 A9 60 8D 94 02		mva		#$60 txtmsc
   434
   435 					;Turn on keyboard and break interrupts; note that this is done both for S:
   436 					;and E: opens. Close does not do this.
   437 F4A8 08				php
   438 F4A9 78				sei
   439 F4AA 0A				asl							;!! - A = $C0
   440 F4AB 05 10			ora		pokmsk
   441 F4AD 85 10			sta		pokmsk
   442 F4AF 8D 0E D2			sta		irqen
   443 F4B2 28				plp
   444
   445 					;Set row count: 24 for full-screen. We will fix up the split case to 4 later
   446 					;while we are writing the display list. Mapping the Atari incorrectly states
   447 					;that this value is set to 0 when no text window is present; this is wrong
   448 					;and in fact BAYPILOT.BAS relies on this being set to 24 for a GR.7+16
   449 					;screen since it later aliases it to GR.0.
   450 F4B3 A0 18			ldy		#24
   451 F4B5 8C BF 02			sty		botscr
   452
   453 					;init colors -- note that we do NOT overwrite pcolr0-3!
   454 F4B8 A0 05			ldy		#5
   455 F4BA B9 BA F5 99 C3 02 + 	mva:rne	standard_colors-1,y color0-1,y-
   456
   457 F4C3 8C F0 02			sty		crsinh				;!! - Y=0 for this and for write index
   458 					
   459 					;add 24 blank lines
   460 F4C6 A9 70			lda		#$70
   461 F4C8 A2 03			ldx		#3
   462 F4CA 20 84 F5			jsr		write_repeat
   463
   464 					;override COLOR4 (background) to $06 for GR.11 so it isn't dark
   465 F4CD A5 57			lda		dindex
   466 F4CF C9 0B			cmp		#11
   467 F4D1 D0 05			bne		not_gr11
   468 F4D3 A9 06			lda		#$06
   469 F4D5 8D C8 02			sta		color4
   470 F4D8			not_gr11:
   471 					
   472 					;add in the main screen
   473 F4D8 20 3A F5			jsr		setup_display
   474 					
   475 					;save off the DL ptr
   476 F4DB 84 7E			sty		countr
   477 					
   478 					;clear it if necessary
   479 F4DD 20 B4 F5			jsr		try_clear
   480 					
   481 					;check if we are doing a split
   482 F4E0 24 68			bit		frmadr
   483 F4E2 50 12			bvc		nosplit
   484
   485 					;change text screen height to four lines
   486 F4E4 A2 04			ldx		#4
   487 F4E6 8E BF 02			stx		botscr
   488
   489 					;swap to the text screen
   490 F4E9 20 40 F9			jsr		EditorSwapToText
   491 					
   492 					;add text screen dlist
   493 F4EC A4 7E			ldy		countr
   494 F4EE 20 3A F5			jsr		setup_display
   495 F4F1 84 7E			sty		countr
   496 						
   497 					;clear the split screen
   498 F4F3 20 B4 F5			jsr		try_clear
   499
   500 F4F6			nosplit:
   501 F4F6 A9 02 8D F3 02		mva		#2		chact
   502
   503 					;init tab map to every 8 columns
   504 F4FB A2 0F			ldx		#15
   505 F4FD 4A				lsr								;!! A=1
   506 F4FE 9D A2 02 CA D0 FA		sta:rne	tabmap-1,x-
   507
   508 					;reset line status
   509 F504 86 6B			stx		bufcnt
   510 					
   511 					;init character set
   512 F506 A2 E0 8E F4 02		mvx		#$e0	chbas			;!! - also used for NMIEN
   513
   514 					;enable VBI; note that we have not yet enabled display DMA
   515 				.if _KERNEL_XLXE
   516 F50B 24 68			bit		frmadr
   517 F50D D0 02 A2 40			sne:ldx	#$40
   518 				.else
   519 					ldx		#$40
   520 				.endif
   521 F511 8E 0E D4			stx		nmien
   522 					
   523 					;terminate display list with jvb
   524 F514 A4 7E			ldy		countr
   525 F516 A2 70			ldx		#rowac
   526 F518 A9 41			lda		#$41
   527 F51A 20 A6 F5			jsr		write_with_zp_address
   528 					
   529 					;init display list and playfield dma
   530 F51D AD 2F 02			lda		sdmctl
   531 F520 09 22			ora		#$22
   532 F522 8D 2F 02			sta		sdmctl
   533 					
   534 					;wait for screen to establish (necessary for Timewise splash screen to render)
   535 F525 A5 14			lda		rtclok+2
   536 F527 C5 14 F0 FC			cmp:req	rtclok+2
   537
   538 					;If we're in screen mode 0, show the cursor; otherwise, skip it and wait for
   539 					;E: to do so. We need to skip this even if a split screen is present, or else
   540 					;ACTris 2.1 displays a bogus cursor. Unfortunately we may have swapped to the
   541 					;split screen, so the mode we need may be in either DINDEX or TINDEX; it's
   542 					;easier for us just to re-check AUX2 bits 0-3.
   543 F52B A5 2B			lda		icax2z
   544 F52D 29 0F			and		#$0f
   545 F52F D0 03			bne		no_cursor
   546
   547 					;show cursor
   548 F531 20 B4 F6			jsr		ScreenPutByte.recompute_show_cursor_exit
   549 F534			no_cursor:
   550 					;swap back to main context
   551 F534 20 99 FD			jsr		EditorSwapToScreen_Y1
   552 					
   553 					;exit
   554 F537 A2 00			ldx		#0				;required by Qix (v3)
   555 F539 60				rts
   556 					
   557 					
   558 				;--------------------------------------------------------
   559 F53A			setup_display:
   560 					;Add initial mode line with LMS, and check if we need to do an LMS
   561 					;split (playfield exceeds 4K). As it turns out, this only happens if
   562 					;we're using ANTIC mode E or F.
   563 F53A A6 57			ldx		dindex
   564 F53C BD 89 F2			lda		ScreenModeTable,x
   565 F53F 29 0F			and		#$0f
   566
   567 				.if _KERNEL_XLXE
   568 					;check if we are doing fine scrolling and set the vscrol bit if so
   569 F541 A6 57			ldx		dindex
   570 F543 D0 07			bne		nofine
   571 F545 AE 6E 02			ldx		fine
   572 F548 F0 02			beq		nofine
   573 F54A 09 20			ora		#$20
   574 F54C			nofine:
   575 				.endif
   576
   577 F54C 48				pha
   578 F54D 09 40			ora		#$40
   579 F54F A2 58			ldx		#savmsc
   580 F551 20 A6 F5			jsr		write_with_zp_address
   581
   582 					;retrieve row count
   583 F554 A6 69			ldx		frmadr+1
   584 F556 A5 57			lda		dindex
   585 F558 D0 03 AE BF 02		sne:ldx	botscr
   586 					
   587 					;dec row count since we already did the LMS
   588 F55D CA				dex
   589 F55E 68				pla
   590 					
   591 				.if _KERNEL_XLXE
   592 					;subtract two rows if we are fine scrolling, as we need to do DLI
   593 					;and non-vscrolled row
   594 F55F C9 22			cmp		#$22
   595 F561 F0 28			beq		dofine
   596 				.endif
   597 					
   598 					;check if this is a split mode
   599 F563 C9 0E			cmp		#$0e
   600 F565 90 1D			bcc		no_lms_split
   601 					
   602 					;yes it is -- write 93 lines
   603 F567 A2 5D			ldx		#93
   604 F569 20 84 F5			jsr		write_repeat
   605 					
   606 					;write LMS to jump over 4K boundary
   607 F56C 48				pha
   608 F56D 09 40			ora		#$40
   609 F56F 91 70 C8			sta		(rowac),y+
   610 F572 A9 00			lda		#0
   611 F574 91 70 C8			sta		(rowac),y+
   612 F577 A5 59			lda		savmsc+1
   613 F579 69 0E			adc		#$0f-1				;!! - C=1 from bcc above
   614 F57B 91 70 C8			sta		(rowac),y+
   615 					
   616 					;set up to write 95 fewer lines (note that carry is cleared)
   617 F57E A5 69			lda		frmadr+1
   618 F580 E9 5E			sbc		#94
   619 F582 AA				tax
   620 F583 68				pla
   621 					
   622 					;write mode lines and return
   623 F584			no_lms_split:
   624 F584			write_repeat:
   625 F584 91 70 C8			sta		(rowac),y+
   626 F587 CA				dex
   627 F588 D0 FA			bne		write_repeat
   628 F58A			no_clear:
   629 F58A 60				rts
   630
   631 				.if _KERNEL_XLXE
   632 F58B			dofine:
   633 					;write the regular lines (22 or 2)
   634 F58B CA				dex
   635 F58C 20 84 F5			jsr		write_repeat
   636
   637 					;write DLI line
   638 F58F 09 80			ora		#$80
   639 F591 91 70 C8			sta		(rowac),y+
   640 					
   641 					;write non-scrolled line
   642 F594 29 5F			and		#$5f
   643 F596 91 70 C8			sta		(rowac),y+
   644 					
   645 					;indicate to mainline that DLIs should be turned on
   646 F599 E6 68			inc		frmadr
   647 					
   648 					;set up DLI routine
   649 F59B A2 DB			ldx		#<ScreenFineScrollDLI
   650 F59D A9 FD			lda		#>ScreenFineScrollDLI
   651 F59F			write_vdslst:
   652 F59F 8E 00 02			stx		vdslst
   653 F5A2 8D 01 02			sta		vdslst+1
   654 F5A5 60				rts
   655 				.endif
   656
   657 				;--------------------------------------------------------
   658 F5A6			write_with_zp_address:
   659 F5A6 91 70 C8			sta		(rowac),y+
   660 F5A9 B5 00			lda		0,x
   661 F5AB 91 70 C8			sta		(rowac),y+
   662 F5AE B5 01			lda		1,x
   663 F5B0 A2 01			ldx		#1
   664 F5B2 D0 D0			bne		write_repeat		;!! - unconditional
   665 					
   666 F5B4			try_clear:
   667 F5B4 24 68			bit		frmadr
   668 F5B6 30 D2			bmi		no_clear
   669 F5B8 4C 49 F8			jmp		ScreenClear
   670 					
   671 				;--------------------------------------------------------
   672 F5BB			standard_colors:
   673 F5BB 28				dta		$28
   674 F5BC CA				dta		$ca
   675 F5BD 94				dta		$94
   676 F5BE 46				dta		$46
   677 = F5BF			.def :ScreenBitposFlipTab
   678 F5BF 00				dta		$00			;!! - shared value between tables
   679 F5C0 01				dta		$01
   680 F5C1 03				dta		$03
   681 F5C2 07				dta		$07
   682
   683 				.endp
   684
   685 				;==========================================================================
   686 F5C3			.proc	ScreenInit
   687 F5C3 AD E6 02 85 6A		mva		memtop+1 ramtop
   688 					
   689 					.ifdef _KERNEL_816
   690 					stz		colrsh
   691 					.else
   692 F5C8 A9 00 85 4F			mva		#0	colrsh
   693 					.endif
   694
   695 F5CC A9 FE 85 4E			mva		#$FE	drkmsk
   696 F5D0 60				rts
   697 				.endp
   698
   699 				;==========================================================================
   700 				; Behavior in gr.0:
   701 				;	- Reading char advances to next position, but cursor is not moved
   702 				;	- Cursor is picked up ($A0)
   703 				;	- Wrapping from end goes to left margin on next row
   704 				;	- Cursor may be outside of horizontal margins
   705 				;	- Error 141 (cursor out of range) if out of range
   706 				;	- Cursor will wrap to out of range if at end of screen (no automatic
   707 				;	  vertical wrap)
   708 				;	- Does NOT update OLDROW/OLDCOL
   709 				;
   710 F5D1			.proc ScreenGetByte
   711 F5D1 20 F9 F8			jsr		ScreenCheckPosition
   712 F5D4 30 3A			bmi		xit
   713 					
   714 					;compute addressing
   715 F5D6 A4 54			ldy		rowcrs
   716 F5D8 20 78 F9			jsr		ScreenComputeToAddrX0
   717 F5DB A5 55			lda		colcrs
   718 F5DD A6 57			ldx		dindex
   719 F5DF BC C9 F2			ldy		ScreenEncodingTab,x
   720 F5E2 59 BF F5			eor		ScreenBitposFlipTab,y
   721 F5E5 AA				tax
   722 F5E6 A5 56			lda		colcrs+1
   723 F5E8 20 C0 F9			jsr		ScreenSetupPixelAddr.phase2
   724 					
   725 					;retrieve byte containing pixel
   726 F5EB A4 6F			ldy		shfamt
   727 F5ED B1 66			lda		(toadr),y
   728 					
   729 					;shift down
   730 F5EF 20 AD F9			jsr		ScreenAlignPixel
   731
   732 					;convert from Internal to ATASCII - must be done before we mask
   733 					;Internal	ATASCII
   734 					;00-1F		20-3F
   735 					;20-3F		40-5F
   736 					;40-5F		00-1F
   737 					;60-7F		60-7F
   738 F5F2 0A				asl
   739 F5F3 08				php
   740 F5F4 10 02 49 40			spl:eor	#$40		;00>20, 20>40, 40>60, 60>40
   741 F5F8 69 40			adc		#$40		;00>20, 20>40, 40>00, 60>60
   742 F5FA 28				plp
   743 F5FB 6A				ror
   744
   745 					;mask using right-justified pixel mask for mode
   746 F5FC A6 57			ldx		dindex
   747 F5FE BC C9 F2			ldy		ScreenEncodingTab,x
   748 F601 39 D9 F2			and		ScreenPixelMasks,y
   749 					
   750 					;advance to next position
   751 F604 A6 57			ldx		dindex
   752 F606 F0 03			beq		mode0
   753 F608 4C D8 F9			jmp		ScreenAdvancePosNonMode0
   754 F60B			mode0:
   755 F60B 20 05 FE			jsr		ScreenAdvancePosMode0
   756 F60E A0 01			ldy		#1
   757 F610			xit:
   758 F610 60				rts
   759 				.endp
   760
   761 				;==========================================================================
   762 				; Common behavior:
   763 				;	- Output is suspended if SSFLAG is set for non-clear and non-EOL chars
   764 				;	- Clear screen ($7D) and EOL ($9B) are always handled
   765 				;	- ESCFLG and DSPFLG are ignored (they are E: features)
   766 				;
   767 				; Behavior in gr.0:
   768 				;	- Logical lines are extended
   769 				;	- Scrolling occurs if bottom is hit
   770 				;	- Control chars other than clear and EOL are NOT handled by S:
   771 				;	- ROWCRS or COLCRS out of range results in an error.
   772 				;	- COLCRS in left margin is ignored and prints within margin.
   773 				;	- COLCRS in right margin prints one char and then does EOL.
   774 				;	- Previous cursor is not erased by S:, regardless of CRSINH state
   775 				;	- New cursor is drawn if CRSINH=0
   776 				;
   777 				; Behavior in gr.1+:
   778 				;	- No cursor is displayed
   779 				;	- LMARGN/RMARGN are ignored
   780 				;	- Cursor wraps from right side to next line
   781 				;	- ROWCRS may be below split screen boundary as long as it is within the
   782 				;	  full screen size.
   783 				;
   784 F611			.proc ScreenPutByte
   785 F611 8D FB 02			sta		atachr
   786 F614 20 F9 F8			jsr		ScreenCheckPosition
   787 F617 30 0C			bmi		error
   788
   789 					;check for screen clear
   790 F619 AD FB 02			lda		atachr
   791 F61C C9 7D			cmp		#$7d
   792 F61E D0 0E			bne		not_clear_2
   793 F620 20 49 F8			jsr		ScreenClear
   794 F623 A0 01			ldy		#1
   795 F625			error:
   796 F625 60				rts
   797 					
   798 F626			graphics_eol:
   799 F626 4C F1 F9			jmp		ScreenAdvancePosNonMode0.graphics_eol
   800
   801 					;*** ENTRY POINT FROM EDITOR FOR ESC HANDLING ***
   802 F629			not_clear:
   803 F629 20 F9 F8			jsr		ScreenCheckPosition
   804 F62C 30 F7			bmi		error
   805 					
   806 F62E			not_clear_2:	
   807 					;set old position now (used by setup code for plot pixel)
   808 F62E 20 FB FD			jsr		ScreenSetLastPosition
   809 					
   810 					;restore char
   811 F631 AD FB 02			lda		atachr
   812 					
   813 					;check if we're in gr.0
   814 F634 A6 57			ldx		dindex
   815 F636 F0 1E			beq		mode_0
   816 					
   817 					;nope, we're in a graphics mode... that makes this easier.
   818 					;check if it's an EOL
   819 F638 C9 9B			cmp		#$9b
   820 F63A F0 EA			beq		graphics_eol
   821 					
   822 					;check for display suspend (ctrl+1) and wait until it is cleared
   823 F63C AE FF 02 D0 FB		ldx:rne	ssflag
   824 					
   825 					;fold the pixel, compute masks, and convert ATASCII to Internal
   826 F641 20 CD F6			jsr		ScreenFoldColor
   827 F644 48				pha
   828
   829 					;compute addressing and shift mask
   830 F645 20 A8 F9			jsr		ScreenSetupPlotPixel
   831 					
   832 F648 68				pla
   833 F649 A4 6F			ldy		shfamt
   834 F64B 51 66			eor		(toadr),y
   835 F64D 25 6E			and		bitmsk
   836 F64F 51 66			eor		(toadr),y
   837 F651 91 66			sta		(toadr),y
   838
   839 					;advance cursor position and exit
   840 F653 4C D8 F9			jmp		ScreenAdvancePosNonMode0
   841 					
   842 F656			mode_0:
   843 					;check for EOL, which bypasses the ESC check
   844 F656 C9 9B			cmp		#$9b
   845 F658 D0 18			bne		not_eol
   846 					
   847 					;it's an EOL
   848 F65A A5 52			lda		lmargn
   849 F65C 85 55			sta		colcrs
   850 F65E E6 54			inc		rowcrs
   851 F660 A5 54			lda		rowcrs
   852 F662 CD BF 02			cmp		botscr
   853 F665 90 08			bcc		noywrap
   854 					
   855 					;We've gone over -- delete logical line 0 to make room.
   856 					;Note that we need to set ROWCRS here first because the scroll may
   857 					;delete more than one physical line.
   858 F667 AE BF 02			ldx		botscr
   859 F66A 86 54			stx		rowcrs
   860 					
   861 F66C 20 CE FC			jsr		EditorDeleteLine0
   862 F66F			noywrap:
   863 F66F 4C B4 F6			jmp		recompute_show_cursor_exit
   864
   865 F672			not_eol:
   866 					;check for display suspend (ctrl+1) and wait until it is cleared
   867 F672 AE FF 02 D0 FB		ldx:rne	ssflag
   868 					
   869 F677 48				pha
   870 F678 20 C2 FC			jsr		EditorRecomputeCursorAddr
   871 F67B 68				pla
   872 F67C 20 EA F6			jsr		ScreenConvertATASCIIToInternal
   873 					
   874 					;plot character
   875 F67F A0 00			ldy		#0
   876 F681 91 5E			sta		(oldadr),y
   877 					
   878 					;inc pos
   879 F683 E6 5E D0 02 E6 5F		inw		oldadr
   880 F689 20 05 FE			jsr		ScreenAdvancePosMode0
   881 					
   882 					;check if we've gone beyond the right margin
   883 F68C B0 29			bcs		nowrap
   884 					
   885 					;check if we're beyond the bottom of the screen
   886 F68E A5 54			lda		rowcrs
   887 F690 CD BF 02			cmp		botscr
   888 F693 90 12			bcc		no_scroll
   889 					
   890 					;yes -- scroll up
   891 F695 20 CE FC			jsr		EditorDeleteLine0
   892
   893 					;check if we can extend the current logical line -- 3 rows max.
   894 F698 20 BA F6			jsr		check_extend
   895
   896 					;Mark the current physical line as part of the last logical line.
   897 					;
   898 					;NOTE: There is a subtlety here in that we may delete multiple physical
   899 					;      lines if the top logical line is more than one line long, but we
   900 					;      only want to add one physical line onto our current logical line.
   901 F69B 20 71 FD			jsr		EditorGetCurLogicalLineInfo
   902 F69E 59 B2 02			eor		logmap,y
   903 F6A1 99 B2 02			sta		logmap,y
   904
   905 F6A4 4C B4 F6			jmp		post_scroll
   906 					
   907 F6A7			no_scroll:
   908 					;check if we can extend the current logical line -- 3 rows max.
   909 F6A7 20 BA F6			jsr		check_extend
   910
   911 					;okay, here's the fun part -- we didn't scroll beyond, but we might
   912 					;be on another logical line, in which case we need to scroll everything
   913 					;down to extend it.
   914 F6AA A5 54			lda		rowcrs
   915 F6AC 20 80 FD			jsr		EditorTestLogicalLineBit
   916 F6AF F0 03			beq		post_scroll
   917 					
   918 					;yup, insert a physical line
   919 F6B1 20 8C F8			jsr		ScreenInsertPhysLine
   920
   921 F6B4			recompute_show_cursor_exit:
   922 F6B4			post_scroll:
   923 F6B4 20 C2 FC			jsr		EditorRecomputeCursorAddr
   924 F6B7			nowrap:
   925 F6B7 4C 14 FE			jmp		ScreenShowCursorAndXitOK
   926 					
   927 F6BA			check_extend:
   928 F6BA A6 54			ldx		rowcrs
   929 F6BC CA				dex
   930 F6BD 8A				txa
   931 F6BE 20 89 FD			jsr		EditorPhysToLogicalRow
   932
   933 				.ifdef _KERNEL_816
   934 					inc
   935 					inc
   936 				.else
   937 F6C1 18				clc
   938 F6C2 69 02			adc		#2
   939 				.endif
   940
   941 F6C4 C5 54			cmp		rowcrs
   942 F6C6 90 01 60			scc:rts
   943 F6C9 68				pla
   944 F6CA 68				pla
   945 F6CB 90 E7			bcc		post_scroll
   946 				.endp
   947
   948 				;==========================================================================
   949 = E4C9			ScreenGetStatus = CIOExitSuccess
   950
   951 				;==========================================================================
   952 				; Given a color byte, mask it off to the pertinent bits and reflect it
   953 				; throughout a byte. The byte is converted from ATASCII to Internal
   954 				; if the mode uses byte encoding.
   955 				;
   956 				; Entry:
   957 				;	A = color value
   958 				;
   959 				; Exit:
   960 				;	A = folded color byte
   961 				;	Y = encoding mode
   962 				;	DMASK = right-justified bit mask
   963 				;	DELTAC = left-justified bit mask
   964 				;
   965 				; Modified:
   966 				;	HOLD1, ADRESS
   967 				;
   968 F6CD			.proc ScreenFoldColor
   969 F6CD A6 57			ldx		dindex
   970 F6CF BC C9 F2			ldy		ScreenEncodingTab,x			;0 = 8-bit, 1 = 4-bit, 2 = 2-bit, 3 = 1-bit
   971 F6D2 BE DD F2 86 77		mvx		ScreenPixelMasks+4,y deltac
   972 F6D7 BE D9 F2 8E A0 02		mvx		ScreenPixelMasks,y dmask
   973 F6DD 30 0B			bmi		fold_byte
   974 F6DF 2D A0 02			and		dmask
   975 F6E2 19 D7 FD			ora		ScreenEncodingOffsetTable-1,y
   976 F6E5 AA				tax
   977 F6E6 BD 53 F2			lda		ScreenEncodingTable,x
   978 F6E9 60				rts
   979 					
   980 F6EA			fold_byte:
   981 					;convert byte from ATASCII to Internal -- this is required for gr.1
   982 					;and gr.2 to work correctly, and harmless for other modes
   983
   984 				;==========================================================================
   985 				; Convert an ATASCII character to displayable INTERNAL format.
   986 				;
   987 				; Entry:
   988 				;	A = ATASCII char
   989 				;
   990 				; Exit:
   991 				;	A = INTERNAL char
   992 				;
   993 = F6EA			.def :ScreenConvertATASCIIToInternal
   994 						;ATASCII	Internal
   995 						;00-1F		40-5F
   996 						;20-3F		00-1F
   997 						;40-5F		20-3F
   998 						;60-7F		60-7F
   999
  1000 F6EA 0A					asl
  1001 F6EB 08					php
  1002 F6EC E9 3F				sbc		#$3f		;00>60, 20>00, 40>20, 60>40
  1003 F6EE 10 02 49 40				spl:eor	#$40		;00>40, 20>00, 40>20, 60>60
  1004 F6F2 28					plp
  1005 F6F3 6A					ror
  1006 F6F4 60					rts
  1007 				.endp
  1008
  1009
  1010 				;==========================================================================
  1011 F6F5			.proc ScreenSpecial
  1012 F6F5 A5 22			lda		iccomz
  1013 F6F7 C9 11			cmp		#$11
  1014 F6F9 F0 05			beq		ScreenDrawLineFill	;draw line
  1015 F6FB C9 12			cmp		#$12
  1016 F6FD F0 01			beq		ScreenDrawLineFill	;fill
  1017 F6FF 60				rts
  1018 				.endp
  1019
  1020 				;==========================================================================
  1021 				;
  1022 				; Inputs:
  1023 				;	COLCRS,ROWCRS = next point
  1024 				;	OLDCOL,OLDROW = previous point
  1025 				;	ATACHR = color/character to use
  1026 				;
  1027 				; Outputs:
  1028 				;	OLDCOL,OLDROW = next point
  1029 				;
  1030 				; Behavior:
  1031 				;	- In GR.0:
  1032 				;		- Cursor is not drawn, even with CRSINH=0
  1033 				;		- OLDADR is updated to ending location, but not OLDCHR. If CRSINH=0,
  1034 				;		  this can lead to a subsequent E: write stomping the last line draw
  1035 				;		  cell with the under-cursor char from the last time the cursor was
  1036 				;		  drawn elsewhere.
  1037 				;
  1038 				; Some test cases:
  1039 				;	- Ryba Pila
  1040 				;	- SPACEWAY.BAS
  1041 				;	- Worm of Bemer
  1042 				;
  1043 				; The Bresenham algorithm we use (from Wikipedia):
  1044 				;	dx = |x2 - x1|
  1045 				;	dy = |y2 - y1|
  1046 				;	e = dx - dy
  1047 				;
  1048 				;	loop
  1049 				;		plot(x1, y1)
  1050 				;		if x1 == x2 and y1 == y2 then exit
  1051 				;		e2 = 2*e
  1052 				;		if e2 + dy > 0 then
  1053 				;			err = err - dy
  1054 				;			x0 = x0 + sign(dx)
  1055 				;		endif
  1056 				;		if e2 < dx then
  1057 				;			err = err + dx
  1058 				;			y0 = y0 + sign(dy)
  1059 				;		endif
  1060 				;	end
  1061 				;	
  1062 F700			.proc ScreenDrawLineFill
  1063 					;;##TRACE "Drawing line (%d,%d)-(%d,%d) in mode %d" dw(oldcol) db(oldrow) dw(colcrs) db(rowcrs) db(dindex)
  1064 						
  1065 					;initialize bit mask and repeat pertinent pixel bits throughout byte
  1066 F700 AD FD 02			lda		fildat
  1067 F703 20 CD F6			jsr		ScreenFoldColor
  1068 F706 8D BC 02			sta		hold4
  1069 F709 AD FB 02			lda		atachr
  1070 F70C 20 CD F6			jsr		ScreenFoldColor
  1071 F70F 85 51			sta		hold1
  1072
  1073 F711 20 A8 F9			jsr		ScreenSetupPlotPixel
  1074
  1075 					;compute screen pitch
  1076 F714 A0 01			ldy		#1
  1077 F716 20 82 F9			jsr		ScreenComputeRangeSize
  1078 F719 85 78			sta		deltac+1
  1079 F71B AA				tax
  1080 F71C A0 00			ldy		#0
  1081
  1082 					;compute abs(dy) and sign(dy)
  1083 F71E A5 54			lda		rowcrs
  1084 F720 38 E5 5A			sub		oldrow
  1085 F723 B0 0C			bcs		going_down
  1086 F725 49 FF			eor		#$ff					;take abs(dy)
  1087 F727 69 01			adc		#1						;
  1088 					;negate screen pitch
  1089 F729 48				pha
  1090 F72A 8A				txa
  1091 F72B 49 FF			eor		#$ff
  1092 F72D AA				tax
  1093 F72E E8				inx
  1094 F72F 88				dey
  1095 F730 68				pla
  1096 F731			going_down:
  1097 F731 86 70			stx		rowac
  1098 F733 85 76			sta		deltar
  1099 F735 84 71			sty		rowac+1
  1100 					
  1101 					;;##TRACE "dy = %d" db(deltar)
  1102 					
  1103 					;compute abs(dx) and sign(dx)
  1104 F737 A2 00			ldx		#0
  1105 F739 A5 55			lda		colcrs
  1106 F73B 38 E5 5B			sub		oldcol
  1107 F73E 85 72			sta		colac
  1108 F740 A5 56			lda		colcrs+1
  1109 F742 E5 5C			sbc		oldcol+1
  1110 F744 B0 10			bcs		going_right
  1111 F746 49 FF			eor		#$ff
  1112 F748 A8				tay
  1113 F749 A5 72			lda		colac
  1114 F74B 49 FF			eor		#$ff
  1115 F74D 69 01			adc		#1
  1116 F74F 85 72			sta		colac
  1117 F751 98				tya
  1118 F752 69 00			adc		#0
  1119 F754 A2 CC			ldx		#left_shift_8-right_shift_8
  1120 F756			going_right:
  1121 F756 85 73			sta		colac+1
  1122
  1123 					;;##TRACE "dx = %d" dw(colac)
  1124 					
  1125 					;set up x shift routine
  1126 F758 8A				txa
  1127 F759 A6 57			ldx		dindex
  1128 F75B BC C9 F2			ldy		ScreenEncodingTab,x
  1129 F75E 18				clc
  1130 F75F 79 AC F7			adc		shift_lo_tab,y
  1131 F762 85 64			sta		adress
  1132 F764 A9 F7			lda		#>left_shift_8
  1133 F766 85 65			sta		adress+1
  1134 F768 85 75			sta		endpt+1
  1135 					
  1136 					;set up x fill shift routine
  1137 F76A B9 AC F7			lda		shift_lo_tab,y
  1138 F76D 18				clc
  1139 F76E 69 D9			adc		#fill_right_8-right_shift_8
  1140 F770 85 74			sta		endpt
  1141 					
  1142 					;compute initial error accumulator in frmadr (dx-dy)
  1143 F772 A6 72			ldx		colac
  1144 F774 8A				txa
  1145 F775 38 E5 76			sub		deltar
  1146 F778 85 68			sta		frmadr
  1147 F77A A4 73			ldy		colac+1				;leave dx in y:x for max() below
  1148 F77C 98				tya
  1149 F77D E9 00			sbc		#0
  1150 F77F 85 69			sta		frmadr+1
  1151
  1152 					;compute max(dx, dy) based on sign of (dx - dy)
  1153 F781 B0 04			bcs		dx_larger
  1154 F783 A0 00			ldy		#0
  1155 F785 A6 76			ldx		deltar
  1156 F787			dx_larger:
  1157 F787 86 7E			stx		countr
  1158 F789 84 7F			sty		countr+1
  1159
  1160 F78B 98				tya
  1161 F78C D0 03			bne		not_empty
  1162 F78E 8A				txa
  1163 F78F F0 0D			beq		skip_showcursor
  1164 F791			not_empty:
  1165 					
  1166 					;;##TRACE "Pixel count = %d" dw(countr)
  1167 					
  1168 					;enter pixel loop (this will do a decrement for us)
  1169 F791 4C 01 F8			jmp		next_pixel
  1170
  1171 				;----------------------------------------------
  1172 F794			done:
  1173 F794 20 FB FD			jsr		ScreenSetLastPosition
  1174
  1175 					;RYBA PILA requires the quirky behavior of the last character of a non-zero length
  1176 					;DRAWTO being stomped by the character saved from the cursor draw of the last PLOT
  1177 					;(write to S:). Note that we must NOT do this for length 0 or it breaks SPACEWAY.
  1178 F797 A4 57			ldy		dindex
  1179 F799 D0 03			bne		skip_showcursor
  1180 F79B 20 C2 FC			jsr		EditorRecomputeCursorAddr
  1181 F79E			skip_showcursor:
  1182 F79E A0 01			ldy		#1
  1183 F7A0 60				rts
  1184
  1185 				;----------------------------------------------	
  1186 F7A1			fill_done:
  1187 F7A1 86 6E			stx		bitmsk
  1188 F7A3 4C 01 F8			jmp		next_pixel
  1189
  1190 				;----------------------------------------------	
  1191 F7A6			do_fill:
  1192 F7A6 A4 6F			ldy		shfamt				;load current byte offset
  1193 F7A8 A6 6E			ldx		bitmsk				;save current bitmask
  1194 F7AA D0 33			bne		fill_start			;!! - unconditional
  1195
  1196 				;----------------------------------------------		
  1197 F7AC			shift_lo_tab:
  1198 F7AC EA				dta		<right_shift_8	
  1199 F7AD E4				dta		<right_shift_4	
  1200 F7AE E6				dta		<right_shift_2	
  1201 F7AF E7				dta		<right_shift_1
  1202
  1203 				;----------------------------------------------	
  1204 F7B0			left_shift_4:
  1205 F7B0 0A				asl
  1206 F7B1 0A				asl
  1207 F7B2			left_shift_2:
  1208 F7B2 0A				asl
  1209 F7B3			left_shift_1:
  1210 F7B3 0A				asl
  1211 F7B4 90 05			bcc		left_shift_ok
  1212 F7B6			left_shift_8:
  1213 F7B6 C6 6F			dec		shfamt
  1214 F7B8 AD A0 02			lda		dmask
  1215 F7BB			left_shift_ok:
  1216 F7BB D0 31			bne		post_xinc			;!! - unconditional
  1217
  1218 				;----------------------------------------------	
  1219 F7BD			fill_right_4:
  1220 F7BD 4A				lsr
  1221 F7BE 4A				lsr
  1222 F7BF			fill_right_2:
  1223 F7BF 4A				lsr
  1224 F7C0			fill_right_1:
  1225 F7C0 4A				lsr
  1226 F7C1 90 09			bcc		fill_right_ok
  1227 F7C3			fill_right_8:
  1228 F7C3 A5 77			lda		deltac
  1229 F7C5 C8				iny
  1230 F7C6 C4 78			cpy		deltac+1
  1231 F7C8 90 02 A0 00			scc:ldy	#0
  1232 F7CC			fill_right_ok:
  1233 F7CC 85 6E			sta		bitmsk
  1234 F7CE F0 D1			beq		fill_done
  1235 F7D0			fill_loop:
  1236 F7D0 B1 66			lda		(toadr),y			;load screen byte
  1237 F7D2 24 6E			bit		bitmsk				;mask to current pixel
  1238 F7D4 D0 CB			bne		fill_done			;exit loop if non-zero
  1239 F7D6 4D BC 02			eor		hold4				;XOR with fill color
  1240 F7D9 25 6E			and		bitmsk				;mask change bits to current pixel
  1241 F7DB 51 66			eor		(toadr),y			;merge with screen byte
  1242 F7DD 91 66			sta		(toadr),y			;save screen byte
  1243 F7DF			fill_start:
  1244 F7DF A5 6E			lda		bitmsk
  1245 F7E1 6C 74 00			jmp		(endpt)
  1246
  1247 				;----------------------------------------------	
  1248 F7E4			right_shift_4:
  1249 F7E4 4A				lsr
  1250 F7E5 4A				lsr
  1251 F7E6			right_shift_2:
  1252 F7E6 4A				lsr
  1253 F7E7			right_shift_1:
  1254 F7E7 4A				lsr
  1255 F7E8 90 04			bcc		right_shift_ok
  1256 F7EA			right_shift_8:
  1257 F7EA E6 6F			inc		shfamt
  1258 F7EC A5 77			lda		deltac
  1259 F7EE			right_shift_ok:
  1260 					;fall through to post_xinc
  1261 F7EE			post_xinc:
  1262 F7EE 85 6E			sta		bitmsk
  1263 F7F0			no_xinc:
  1264
  1265 					;plot pixel
  1266 					;;##TRACE "Plotting at $%04X+%d with mask $%02X" dw(toadr) db(shfamt) db(bitmsk)	
  1267 F7F0 A4 6F			ldy		shfamt
  1268 F7F2 A5 51			lda		hold1
  1269 F7F4 51 66			eor		(toadr),y
  1270 F7F6 25 6E			and		bitmsk
  1271 F7F8 51 66			eor		(toadr),y
  1272 F7FA 91 66			sta		(toadr),y
  1273
  1274 					;do fill if needed
  1275 F7FC A5 22			lda		iccomz
  1276 F7FE 4A				lsr
  1277 F7FF 90 A5			bcc		do_fill
  1278 					
  1279 F801			next_pixel:
  1280 					;loop back for next pixel
  1281 F801 A5 7E			lda		countr
  1282 F803 D0 04			bne		next_pixel_2
  1283 F805 C6 7F			dec		countr+1
  1284 F807 30 8B			bmi		done
  1285 F809			next_pixel_2:
  1286 F809 C6 7E			dec		countr
  1287
  1288 					;!! - fall through to pixel loop
  1289
  1290 					;------- pixel loop state -------
  1291 					;	(zp)	frmadr		error accumulator
  1292 					;	(zp)	toadr		current row address
  1293 					;	(abs)	dmask		right-justified bit mask
  1294 					;	(zp)	deltac		left-justified bit mask
  1295 					;	(zp)	bitmsk		current bit mask
  1296 					;	(zp)	shfamt		current byte offset within row
  1297 					;	(zp)	rowac		y step address increment/decrement (note different from Atari OS)
  1298 					;	(zp)	adress		left/right shift routine
  1299 					;	(zp)	deltac+1	screen pitch, in bytes (for fill)
  1300 					;	(zp)	endpt		right shift routine
  1301 					;	(zp)	colac		dy
  1302 F80B			pixel_loop:
  1303 					;compute 2*err
  1304 					;;##TRACE "Error accum = %d (dx=%d, dy=%d(%d))" dsw(frmadr) dw(colac) db(deltar) dsw(rowac)
  1305 F80B A5 68			lda		frmadr
  1306 F80D 0A				asl
  1307 F80E A8				tay
  1308 F80F A5 69			lda		frmadr+1
  1309 F811 2A				rol
  1310 F812 AA				tax
  1311 					
  1312 					;check for y increment (2*e < dx, or A:Y < colac)
  1313 F813 98				tya
  1314 F814 18				clc
  1315 F815 E5 72			sbc		colac
  1316 F817 8A				txa
  1317 F818 48				pha
  1318 F819 E5 73			sbc		colac+1
  1319 F81B 10 13			bpl		no_yinc
  1320
  1321 F81D			do_yinc:
  1322 					;bump y (add/subtract pitch, e += dx)
  1323 F81D A2 02			ldx		#2
  1324 F81F			yinc_loop:
  1325 F81F B5 70			lda		rowac,x
  1326 F821 18				clc
  1327 F822 75 66			adc		toadr,x
  1328 F824 95 66			sta		toadr,x
  1329 F826 B5 71			lda		rowac+1,x
  1330 F828 75 67			adc		toadr+1,x
  1331 F82A 95 67			sta		toadr+1,x
  1332 F82C CA				dex
  1333 F82D CA				dex
  1334 F82E 10 EF			bpl		yinc_loop
  1335 F830			no_yinc:
  1336
  1337 					;check for x increment (2*e + dy > 0, or Y:[S] + deltar > 0)
  1338 F830 98				tya
  1339 F831 18				clc
  1340 F832 65 76			adc		deltar
  1341 F834 68				pla
  1342 F835 69 00			adc		#0
  1343 F837 30 B7			bmi		no_xinc
  1344
  1345 					;update error accumulator
  1346 F839 A5 68			lda		frmadr
  1347 F83B 38 E5 76			sub		deltar
  1348 F83E 85 68			sta		frmadr
  1349 F840 B0 02 C6 69			scs:dec	frmadr+1
  1350
  1351 					;bump x
  1352 F844 A5 6E			lda		bitmsk
  1353 F846 6C 64 00			jmp		(adress)
  1354
  1355 				.if [right_shift_4 ^ right_shift_8]&$ff00
  1356 					.error "Right draw routines cross page: ",right_shift_4,"-",right_shift_8
  1357 				.endif
  1358 				.if [left_shift_4 ^ left_shift_8]&$ff00
  1359 					.error "Left draw routines cross page: ",left_shift_4,"-",left_shift_8
  1360 				.endif
