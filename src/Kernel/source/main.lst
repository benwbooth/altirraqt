    11 F9FC			.proc	EditorOpen
    12 F9FC 20 E8 FD			jsr		ScreenResetLogicalLineMap
    13 F9FF 8E FE 02			stx		dspflg		;!! relies on X=0 from ScreenResetLogicalLineMap
    14 FA02 8E A2 02			stx		escflg
    15 					
    16 					;we must force mode 0 here -- ACTION calls this with $0C in AUX2 and
    17 					;expects mode 0 to be set
    18 FA05 4C F2 F3			jmp		ScreenOpenMode0
    19 				.endp
