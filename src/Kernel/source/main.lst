    35 				;==========================================================================
    36 				; K: GET BYTE handler.
    37 				;
    38 				; Behavior:
    39 				;	- Exits with a Break error when break key is pressed.
    40 				;	- Ctrl-1 does not suspend input here (it is handled by S:/E:).
    41 				;	- Ctrl-3 returns an EOF error.
    42 				;	- Caps Lock sets caps mode on OS-A/B depending on Ctrl and Shift key
    43 				;	  state. On the XL/XE OS, pressing Caps Lock alone will enable shift
    44 				;	  lock if no lock is enabled and disable it otherwise.
    45 				;	- Shift/Control lock is applied by K:, but only on alpha keys.
    46 				;	- Inverse mode is also applied by K:. Control characters are excluded:
    47 				;	  1B-1F/7D-7F/9B-9F/FD-FF.
    48 				;	- Any Ctrl+Shift key code (>=$C0) produces a key click but is otherwise
    49 				;	  ignored.
    50 				;	- Despite the OS Manual saying that there are no AUX1/AUX2 bits for
    51 				;	  K:, it actually implements the forced input bit for E: (AUX1 bit 0).
    52 				;	  This carries over to also implementing this bit for C:, which is
    53 				;	  relied upon by Black Lamp and Karateka loaders. This returns an EOL,
    54 				;	  BRKKEY is not checked, the keyboard table is not used, and there is
    55 				;	  no key click sound.
    56 				;
    57 FE59			.nowarn .proc	_KeyboardGetByte
    58 FE59			toggle_shift:
    59 					.if _KERNEL_XLXE
    60 					;Caps Lock without Shift or Control is a toggle on the XL/XE line:
    61 					; None -> Shifted
    62 					; Shifted, Control -> None
    63 FE59 AE BE 02			ldx		shflok
    64 FE5C D0 02			bne		caps_off
    65 FE5E A0 40			ldy		#$40
    66 					.endif
    67 FE60			shift_ctrl_on:
    68 FE60			caps_off:
    69 FE60 98				tya
    70 FE61 29 C0			and		#$c0
    71 FE63			write_shflok:
    72 FE63 8D BE 02			sta		shflok
    73
    74 = FE66			.def :KeyboardGetByte
    75 FE66 A5 2A			lda		icax1z
    76 FE68 4A				lsr
    77 FE69 A9 9B			lda		#$9b
    78 FE6B B0 50			bcs		forced_input
    79 FE6D			waitForChar:
    80 FE6D A2 FF			ldx		#$ff
    81 FE6F			waitForChar2:
    82 FE6F A5 11			lda		brkkey
    83 FE71 F0 5A			beq		isBreak
    84 FE73 AD FC 02			lda		ch
    85 FE76 C9 FF			cmp		#$ff
    86 FE78 F0 F5			beq		waitForChar2
    87 					
    88 					;invalidate char
    89 FE7A 8E FC 02			stx		ch
    90 					
    91 					;do keyboard click (we do this even for ignored ctrl+shift+keys)
    92 					.if _KERNEL_XLXE
    93 FE7D AC DB 02			ldy		noclik
    94 FE80 D0 05			bne		no_click
    95 					.endif
    96
    97 FE82 A0 0C			ldy		#12
    98 FE84 20 CC E4			jsr		Bell
    99 FE87			no_click:
   100
   101 					;ignore char if both ctrl and shift are pressed
   102 FE87 C9 C0			cmp		#$c0
   103 FE89 B0 E2			bcs		waitForChar
   104 								
   105 					;translate char
   106 FE8B A8				tay
   107
   108 					.if _KERNEL_XLXE
   109 FE8C B1 79			lda		(keydef),y
   110 					.else
   111 					lda		KeyCodeToATASCIITable,y
   112 					.endif
   113 					
   114 					;handle special keys (see keytable.s)
   115 FE8E 10 10			bpl		valid_key
   116 FE90 C9 81			cmp		#$81
   117 FE92 90 D9			bcc		waitForChar		;$80 - invalid
   118 FE94 F0 2D			beq		isInverse		;$81 - inverse video
   119 FE96 C9 83			cmp		#$83
   120 FE98 90 BF			bcc		toggle_shift	;$82 - caps lock
   121 FE9A C9 85			cmp		#$85
   122 FE9C 90 C2			bcc		shift_ctrl_on	;$83 - shift caps lock / $84 - ctrl caps lock
   123 FE9E F0 32			beq		isCtrl3			;$85 - EOF
   124 					
   125 FEA0			valid_key:
   126 					;check for alpha key
   127 FEA0 C9 61			cmp		#'a'
   128 FEA2 90 0F			bcc		notAlpha
   129 FEA4 C9 7B			cmp		#'z'+1
   130 FEA6 B0 0B			bcs		notAlpha
   131 					
   132 					;check for shift/control lock
   133 FEA8 2C BE 02			bit		shflok
   134 FEAB 70 04			bvs		doShiftLock
   135 FEAD 10 04			bpl		notAlpha
   136 					
   137 					;do control lock logic
   138 FEAF 29 1F			and		#$1f
   139
   140 FEB1			doShiftLock:
   141 FEB1 29 DF			and		#$df
   142
   143 FEB3			notAlpha:
   144 					;check if we should apply inverse flag -- special characters are excluded
   145 FEB3 A2 0F			ldx		#EditorPutByte.special_code_tab_end_2-EditorPutByte.special_code_tab-1
   146 FEB5 20 B9 FC			jsr		EditorIsSpecial
   147 FEB8 F0 03			beq		skip_inverse
   148
   149 					;apply inverse flag
   150 FEBA 4D B6 02			eor		invflg
   151 FEBD			skip_inverse:
   152 FEBD			forced_input:
   153
   154 					;return char
   155 FEBD 8D FB 02			sta		atachr			;required or CON.SYS (SDX 4.46) breaks
   156 FEC0 A0 01			ldy		#1
   157 FEC2 60				rts
   158 					
   159 FEC3			isInverse:
   160 FEC3 AD B6 02			lda		invflg
   161 FEC6 49 80			eor		#$80
   162 FEC8 8D B6 02			sta		invflg
   163 FECB B0 A0			bcs		waitForChar		;!! - unconditional
   164
   165 FECD			isBreak:
   166 FECD 86 11			stx		brkkey
   167 FECF A0 80			ldy		#CIOStatBreak
   168 FED1 60				rts
   169 					
   170 FED2			isCtrl3:
   171 FED2 A0 88			ldy		#CIOStatEndOfFile
   172 FED4 60				rts
   173 				.endp
