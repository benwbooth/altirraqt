  1547 				;==========================================================================
  1548 F8F9			.proc	ScreenCheckPosition
  1549 					;Check for ROWCRS out of range. Note that for split screen modes we still
  1550 					;check against the full height!
  1551 F8F9 AD BF 02			lda		botscr
  1552 F8FC A6 57			ldx		dindex
  1553 F8FE D0 04			bne		rowcheck_not_gr0
  1554 F900 24 7B			bit		swpflg
  1555 F902 30 06			bmi		rowcheck_gr0
  1556 F904			rowcheck_not_gr0:
  1557 F904 BC 99 F2			ldy		ScreenHeightShifts,x
  1558 F907 B9 A9 F2			lda		ScreenHeights,y
  1559 F90A			rowcheck_gr0:
  1560 					;Clamp RMARGN to 39 (required for ARTILLERY.BAS). Yes, this still happens
  1561 					;even if the screen is not GR.0 and we're plotting above the screen split.
  1562 F90A A0 27			ldy		#39
  1563 F90C C4 53			cpy		rmargn
  1564 F90E B0 02			bcs		rmargn_ok
  1565 F910 84 53			sty		rmargn
  1566 F912			rmargn_ok:
  1567 F912 18				clc
  1568 F913 E5 54			sbc		rowcrs
  1569 F915 B0 0E			bcs		rowcheck_pass	
  1570 F917			invalid_position:
  1571
  1572 					;If the cursor is out of range, reset it within bounds.
  1573 F917 A0 00			ldy		#0
  1574 F919 84 56			sty		colcrs+1		;X high = 0
  1575 F91B 8A				txa
  1576 F91C D0 02 A4 52			sne:ldy	lmargn
  1577 F920 84 55			sty		colcrs			;X low = X origin
  1578
  1579 F922 A0 8D			ldy		#CIOStatCursorRange
  1580 F924 60				rts
  1581 					
  1582 F925			rowcheck_pass:
  1583 					;check width
  1584 F925 BC AE F2			ldy		ScreenPixelWidthIds,x
  1585 F928 A5 55			lda		colcrs
  1586 F92A D9 BF F2			cmp		ScreenPixelWidthsLo,y
  1587 F92D A5 56			lda		colcrs+1
  1588 F92F F9 C4 F2			sbc		ScreenPixelWidthsHi,y
  1589 F932 B0 E3			bcs		invalid_position
  1590
  1591 					;check for BREAK
  1592 F934 A0 FF			ldy		#$ff
  1593 F936 A5 11			lda		brkkey
  1594 F938 D0 04			bne		no_break
  1595 F93A 84 11			sty		brkkey
  1596 F93C A0 7F			ldy		#CIOStatBreak-1
  1597 F93E			no_break:
  1598 F93E C8				iny
