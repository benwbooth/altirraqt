   429 				;----------------
   430 FB6E			special_set_tab:
   431 FB6E 20 82 FB			jsr		special_common_tab
   432 FB71 1D A3 02			ora		tabmap,x
   433 FB74 D0 08			bne		special_common_exit_tab
   434
   435 FB76			special_clear_tab:
   436 FB76 20 82 FB			jsr		special_common_tab
   437 FB79 49 FF			eor		#$ff
   438 FB7B 3D A3 02			and		tabmap,x
   439 FB7E			special_common_exit_tab:
   440 FB7E 9D A3 02			sta		tabmap,x
   441 FB81 60				rts
   442 					
   443 FB82			special_common_tab:
   444 FB82 20 A4 FD			jsr		EditorGetLogicalColumn
   445 FB85 A8				tay
   446 FB86 4C B3 FD			jmp		EditorSetupTabIndex	
   447
   448 				;--------------------------------------------------------------------------
   449 				; Tab behavior:
   450 				;	- Moves cursor to the next tab position within the logical line.
   451 				;	- If there are no more tabs, moves cursor to beginning of next line.
   452 				;	  This may cause a scroll.
   453 				;	- Tab does NOT adjust the read row.
   454 				;
   455 FB89			special_tab:
   456 FB89 20 A4 FD			jsr		EditorGetLogicalColumn
   457 FB8C A8				tay
   458 FB8D 8A				txa
   459 FB8E 38				sec
   460 FB8F 65 54			adc		rowcrs
   461 FB91 85 54			sta		rowcrs
   462 					
   463 					;scan forward until we find the next bit set, or we hit position 120
   464 FB93			tab_scan_loop:
   465 FB93 C8				iny
   466 FB94 C0 78			cpy		#120
   467 FB96 B0 08			bcs		tab_found
   468 FB98 20 B3 FD			jsr		EditorSetupTabIndex
   469 FB9B 3D A3 02			and		tabmap,x
   470 FB9E F0 F3			beq		tab_scan_loop
   471 FBA0			tab_found:
   472 FBA0 84 55			sty		colcrs
   473 FBA2			tab_adjust_row:
   474 FBA2 A5 55			lda		colcrs
   475 FBA4 38				sec
   476 FBA5 E9 28			sbc		#40							;subtract a row worth of columns
   477 FBA7 90 19			bcc		tab_adjust_done				;exit if <40
   478 FBA9 85 55			sta		colcrs
   479 FBAB E6 54			inc		rowcrs						;next row
   480 FBAD A5 54			lda		rowcrs						;
   481 FBAF CD BF 02			cmp		botscr						;check if we're below the screen
   482 FBB2 B0 07			bcs		tab_adjust_scroll			;if so, do a scroll
   483 FBB4 20 80 FD			jsr		EditorTestLogicalLineBit	;check if we're on a new log line
   484 FBB7 F0 E9			beq		tab_adjust_row				;if not, keep adjusting
   485 FBB9 10 03			bpl		tab_adjust_left				;position at beginning of new line
   486 					
   487 FBBB			tab_adjust_scroll:
   488 FBBB 20 CE FC			jsr		EditorDeleteLine0
   489 FBBE			tab_adjust_left:
   490 FBBE			hmove_to_lmargn:
   491 					;move to left margin	
   492 FBBE A6 52			ldx		lmargn
   493 FBC0			hmove_to_x:
   494 FBC0 86 55			stx		colcrs
   495 FBC2			tab_adjust_done:
   496 FBC2 60				rts
   497
   498 				;--------------------------------------------------------------------------
   499 FBC3			special_left:
   500 FBC3 A6 52			ldx		lmargn
   501 FBC5 E4 55			cpx		colcrs						;lmargn-colcrs >= 0
   502 FBC7 B0 03			bcs		hmove_to_rmargn				;branch if colcrs <= lmargn
   503 FBC9 C6 55			dec		colcrs
   504 FBCB 60				rts
   505
   506 FBCC			hmove_to_rmargn:
   507 					;move to right margin
   508 FBCC A6 53			ldx		rmargn
   509 FBCE B0 F0			bcs		hmove_to_x
   510
   511 				;--------------------------------------------------------------------------
   512 FBD0			special_right:
   513 FBD0 A6 55			ldx		colcrs
   514 FBD2 E4 53			cpx		rmargn
   515 FBD4 B0 E8			bcs		hmove_to_lmargn
   516
   517 					;right one char
   518 FBD6 E6 55			inc		colcrs
   519 FBD8 60				rts
   520
   521 				;--------------------------------------------------------------------------
   522 				; Delete line behavior:
   523 				;	- The entire logical line that the cursor is in is deleted.
   524 				;	- The cursor is positioned at the beginning of the next logical line.
   525 				;
   526 FBD9			special_delete_line:
   527 					;delete current logical line
   528 FBD9 20 87 FD			jsr		EditorGetCurLogicalRow
   529 FBDC 4C D0 FC			jmp		EditorDeleteLine
   530
   531 				;----------------
   532 FBDF			special_insert_line:
   533 					;insert a new logical line at this point; note that this may split
   534 					;the current line
   535 FBDF 38				sec
   536 FBE0 20 8D F8			jsr		ScreenInsertLine
   537 FBE3 4C BE FB			jmp		tab_adjust_left
   538
   539 				;--------------------------------------------------------------------------
   540 				; Delete character behavior:
   541 				;	- Erases the current character and drags in characters from the
   542 				;	  remainder of the logical line, excluding the margins.
   543 				;	- If the last physical line is blank and not the only physical line in
   544 				;	  the logical line, it is deleted and the logical line is shortened.
   545 				;	  Only one line is removed even if the last two lines are blank. The
   546 				;	  cursor does not move when this happens and may be shifted into the
   547 				;	  next logical line. This also does not change the input line!
   548 				;
   549 FBE6			special_delete_char:
   550 					;compute base address of current row (not char)
   551 FBE6 A4 54			ldy		rowcrs
   552 FBE8 84 51			sty		hold1
   553 FBEA 20 78 F9			jsr		ScreenComputeToAddrX0
   554 					
   555 					;begin shifting in the first column at the current pos
   556 FBED A4 55			ldy		colcrs
   557 					
   558 					;delete chars to end
   559 FBEF 4C 7D FC			jmp		delete_shift_loop_entry	
   560 					
   561 				;--------------------------------------------------------------------------
   562 				; Insert character behavior:
   563 				;	- Inserts a blank at the current position and shifts characters forward
   564 				;	  within the margins.
   565 				;	- If the character shifted out of the end of the logical line is non-
   566 				;	  blank, the logical line will be extended if possible. This can cause
   567 				;	  a scroll. If the logical line is already three rows, the last
   568 				;	  character is lost.
   569 				;
   570 FBF2			special_insert_char:
   571 					;get logical line start
   572 FBF2 20 87 FD			jsr		EditorGetCurLogicalRow
   573 					
   574 					;compute line at which we cannot add another physical line
   575 FBF5 18 69 03			add		#3
   576 FBF8 85 76			sta		deltar
   577 					
   578 					;compute address of row
   579 FBFA A4 54			ldy		rowcrs
   580 FBFC 84 51			sty		hold1
   581 FBFE 20 78 F9			jsr		ScreenComputeToAddrX0
   582 					
   583 FC01 A4 55			ldy		colcrs				;end shift at current column
   584 FC03 A2 00			ldx		#0					;insert blank character at start
   585 FC05 F0 04			beq		insert_line_loop_entry
   586 					
   587 FC07			insert_line_loop:
   588 FC07 A4 52			ldy		lmargn				;end shift at left column
   589 FC09 A6 50			ldx		tmpchr				;character to shift in (from last line)
   590 					
   591 FC0B			insert_line_loop_entry:
   592 FC0B 84 65			sty		adress+1			;stash shift origin
   593 FC0D A4 53			ldy		rmargn				;begin shift at right column
   594 FC0F B1 66			lda		(toadr),y			;get character being shifted out
   595 FC11 85 50			sta		tmpchr				;save it off to later shift in on the next row
   596 FC13			insert_shift_loop:
   597 FC13 88				dey
   598 FC14 B1 66			lda		(toadr),y
   599 FC16 C8				iny
   600 FC17 91 66			sta		(toadr),y
   601 FC19 88				dey
   602 FC1A C4 65			cpy		adress+1
   603 FC1C D0 F5			bne		insert_shift_loop
   604
   605 					;put character shifted out from previous line into beginning of this one
   606 FC1E 8A				txa
   607 FC1F 91 66			sta		(toadr),y
   608 					
   609 					;next row
   610 FC21 E6 51			inc		hold1
   611 					
   612 FC23 20 C2 FD			jsr		EditorNextLineAddr
   613 					
   614 					;check if we're at the end of the logical line
   615 FC26 A5 51			lda		hold1
   616 FC28 CD BF 02			cmp		botscr
   617 FC2B B0 05			bcs		insert_crossed_lline
   618 FC2D 20 80 FD			jsr		EditorTestLogicalLineBit
   619 FC30 F0 D5			beq		insert_line_loop
   620 FC32			insert_crossed_lline:
   621
   622 					;check if we shifted out a non-blank character
   623 FC32 A5 50			lda		tmpchr
   624 FC34 F0 2D			beq		insert_done
   625 						
   626 					;save current row
   627 FC36 A5 54			lda		rowcrs
   628 FC38 48				pha
   629 					
   630 					;check if the logical line is already 3 rows -- if so, we cannot extend and
   631 					;the last char goes into the bit bucket, but we still must scroll (!)
   632 FC39 A6 51			ldx		hold1
   633 FC3B E4 76			cpx		deltar
   634 FC3D 08				php
   635 					
   636 					;move to the bottom line +1; we use ROWCRS so it stays updated with the scrolling
   637 FC3E 86 54			stx		rowcrs
   638 					
   639 					;check if we are at the bottom of the screen; if so we must scroll
   640 FC40 A9 00			lda		#0
   641 FC42 85 76			sta		deltar
   642
   643 FC44 EC BF 02			cpx		botscr
   644 FC47 90 03			bcc		insert_no_scroll
   645 					
   646 					;scroll the screen
   647 FC49 20 CE FC			jsr		EditorDeleteLine0
   648 					
   649 FC4C			insert_no_scroll:
   650 					;if we can't extend, we are done
   651 FC4C 28				plp
   652 FC4D B0 0E			bcs		insert_cant_extend
   653 					
   654 					;just insert a blank line at the end of this logical row to extend it
   655 FC4F 20 8C F8			jsr		ScreenInsertPhysLine
   656 						
   657 					;restore shifted character and put it in place
   658 FC52 A4 54			ldy		rowcrs
   659 FC54 20 78 F9			jsr		ScreenComputeToAddrX0
   660 FC57 A5 50			lda		tmpchr
   661 FC59 A4 52			ldy		lmargn
   662 FC5B 91 66			sta		(toadr),y
   663 FC5D			insert_cant_extend:
   664
   665 					;restore cursor row, adjusting for any scroll
   666 FC5D 68				pla
   667 FC5E 38				sec
   668 FC5F E5 76			sbc		deltar
   669 FC61 85 54			sta		rowcrs
   670
   671 FC63			insert_done:
   672 FC63 60				rts
   673
   674 				;---------------------------------
   675 FC64			dispatch:
   676 FC64 A9 FB			lda		#>special_escape
   677 FC66 48				pha
   678 FC67 BD 0B FB			lda		special_dispatch_lo_tab,x
   679 FC6A 48				pha
   680 FC6B 60				rts
   681
   682 				;---------------------------------
   683 FC6C			delete_line_loop:
   684 					;copy first character into right margin of previous row
   685 FC6C A4 52			ldy		lmargn
   686 FC6E B1 66			lda		(toadr),y
   687 FC70 A4 53			ldy		rmargn
   688 FC72 91 68			sta		(frmadr),y
   689 					
   690 					;start shifting new row at left margin
   691 FC74 A4 52			ldy		lmargn
   692 FC76			delete_shift_loop:	
   693 FC76 C8				iny
   694 FC77 B1 66			lda		(toadr),y
   695 FC79 88				dey
   696 FC7A 91 66			sta		(toadr),y
   697 FC7C C8				iny
   698 FC7D			delete_shift_loop_entry:
   699 FC7D C4 53			cpy		rmargn
   700 FC7F D0 F5			bne		delete_shift_loop
   701 					
   702 					;next line
   703 FC81 20 C2 FD			jsr		EditorNextLineAddr
   704 					
   705 					;check if the next row is a logical line start
   706 FC84 A6 51			ldx		hold1
   707 FC86 E8				inx
   708 FC87 EC BF 02			cpx		botscr
   709 FC8A B0 08			bcs		delete_stop_shifting
   710 FC8C 86 51			stx		hold1
   711 FC8E 8A				txa
   712 FC8F 20 80 FD			jsr		EditorTestLogicalLineBit
   713 					
   714 					;keep going if not
   715 FC92 F0 D8			beq		delete_line_loop
   716 					
   717 FC94			delete_stop_shifting:
   718 					;blank the last character of the last line
   719 FC94 A4 53			ldy		rmargn
   720 FC96 A9 00			lda		#0
   721 FC98 91 68			sta		(frmadr),y
   722 					
   723 					;check if the last line is blank
   724 FC9A			delete_blank_test_loop:
   725 FC9A C4 52			cpy		lmargn
   726 FC9C F0 06			beq		delete_blank_exit_loop
   727 FC9E 88				dey
   728 FC9F B1 68			lda		(frmadr),y
   729 FCA1 F0 F7			beq		delete_blank_test_loop
   730 					;re-show cursor and exit
   731 FCA3 60				rts
   732
   733 FCA4			delete_blank_exit_loop:	
   734 					;the last line is blank... check if it is a logical line start
   735 FCA4 C6 51			dec		hold1
   736 FCA6 A5 51			lda		hold1
   737 FCA8 20 80 FD			jsr		EditorTestLogicalLineBit
   738 					
   739 					;skip if so -- we can't delete the entire logical line
   740 FCAB D0 0B			bne		delete_not_blank
   741 					
   742 					;delete this physical line... however, do not move the cursor and
   743 					;do not change the read line even if the cursor hops to a new one
   744 FCAD A5 55			lda		colcrs
   745 FCAF 48				pha
   746 FCB0 A5 51			lda		hold1
   747 FCB2 20 D0 FC			jsr		EditorDeleteLine
   748 FCB5 68				pla
   749 FCB6 85 55			sta		colcrs
   750 					
   751 FCB8			delete_not_blank:
   752 					;re-show cursor and exit
   753 FCB8 60				rts
   754
   755 				.endp
