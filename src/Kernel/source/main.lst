   233 				;==========================================================================
   234 				; This routine must NOT write BUFADR -- doing so breaks the DLT flasher.
   235 				;
   236 				; Behavior notes:
   237 				;	- Ctrl+1 (suspend display) does not affect control codes handled only
   238 				;	  by E:. In particular, EOL, move up/down/left/right, ESC, insert, and
   239 				;	  delete are not affected by it. CLEAR on the other hand, is, because
   240 				;	  it's handled by S:.
   241 				;
   242 FAB5			.proc	EditorPutByte
   243 					;open the text screen if it is not open already
   244 FAB5 A4 57			ldy		dindex
   245 FAB7 F0 0C			beq		screenok
   246 FAB9 AC BF 02			ldy		botscr
   247 FABC C0 04			cpy		#4
   248 FABE F0 05			beq		screenok
   249
   250 FAC0 48				pha
   251 FAC1 20 EE F3			jsr		ScreenOpenGr0
   252 FAC4 68				pla
   253 FAC5			screenok:
   254
   255 					;swap to text context
   256 FAC5 20 40 F9			jsr		EditorSwapToText
   257
   258 					;hide the cursor -- this must be done before we suspend display on
   259 					;Ctrl+1.
   260 FAC8 20 F0 F8			jsr		ScreenHideCursor
   261
   262 					;save off character to free up acc
   263 FACB A8				tay
   264
   265 					;Check if [esc] is active
   266 					;
   267 					;Note that the ASL trick relies on ESCFLG being $80 when set; this
   268 					;is in fact guaranteed by the spec in the OS Manual, Appendix L, B26.
   269 					;
   270 FACC 0E A2 02			asl		escflg					;test and clear escape flag
   271 FACF B0 1E			bcs		not_special
   272
   273 					;check if this might be a special character
   274 FAD1 29 1F			and		#$1f
   275 FAD3 C9 1B			cmp		#$1b
   276 FAD5 90 18			bcc		not_special
   277
   278 					;might be special, but not EOL... search the special char table
   279 FAD7 A2 0E			ldx		#special_code_tab_end-special_code_tab-1
   280 FAD9 98				tya
   281 FADA 20 B9 FC			jsr		EditorIsSpecial
   282 FADD D0 10			bne		not_special
   283 					
   284 FADF			special_found:
   285 					;check if display of control codes is desired; if so, we need to ignore this
   286 FADF AD FE 02			lda		dspflg
   287 FAE2 D0 0B			bne		not_special
   288
   289 					;jump to routine
   290 FAE4 20 64 FC			jsr		dispatch
   291 FAE7 20 C2 FC			jsr		EditorRecomputeCursorAddr
   292 FAEA 20 14 FE			jsr		ScreenShowCursorAndXitOK
   293 FAED 10 06			bpl		xit2				;!! - unconditional jump
   294
   295 FAEF			not_special:
   296 					;ok, just put the char to the screen
   297 FAEF 8C FB 02			sty		atachr
   298 FAF2 20 29 F6			jsr		ScreenPutByte.not_clear
   299 FAF5			xit2:
   300 					;swap back to main context and exit
   301 FAF5 AD FB 02			lda		atachr				;required by Monkey Wrench II
   302 FAF8 4C 9B FD			jmp		EditorSwapToScreen
   303
   304 				;---------------
