    10 E4EA			.proc CIOInit	
    11 E4EA 38				sec
    12 E4EB A2 70			ldx		#$70
    13 E4ED			iocb_loop:
    14 E4ED A9 FF			lda		#$ff
    15 E4EF 9D 40 03			sta		ichid,x
    16 E4F2 20 6D E7			jsr		CIOSetPutByteClosed
    17 E4F5 8A				txa
    18 E4F6 E9 10			sbc		#$10
    19 E4F8 AA				tax
    20 E4F9 10 F2			bpl		iocb_loop
    21 E4FB 60				rts
    22 				.endp
    23
    24 				;==============================================================================
    25 				;	Character I/O entry vector
    26 				;
    27 				;	On entry:
    28 				;		X = IOCB offset (# x 16)
    29 				;
    30 				;	Returns:
    31 				;		A = depends on operation
    32 				;		X = IOCB offset (# x 16)
    33 				;		Y = status (reflected in P)
    34 				;
    35 				;	Notes:
    36 				;		BUFADR must not be touched from CIO. DOS XE relies on this for
    37 				;		temporary storage and breaks if it is modified.
    38 				;
    39 				;	XL/XE mode notes:
    40 				;		HNDLOD is always set to $00 afterward, per Sweet 16 supplement 3.
    41 				;
    42 				;		CIO can optionally attempt a provisional open by doing a type 4 poll
    43 				;		over the SIO bus. This happens unconditionally if HNDLOD is non-zero
    44 				;		and only after the device is not found in HATABS if HNDLOD is zero.
    45 				;		If this succeeds, the IOCB is provisionally opened. Type 4 polling
    46 				;		ONLY happens for direct opens -- it does not happen for a soft open.
    47 				;
    48 E4FC			.proc CIO
    49 					;stash IOCB offset (X) and acc (A)
    50 E4FC 85 2F			sta		ciochr
    51 E4FE 86 2E			stx		icidno
    52 E500 20 11 E5			jsr		process
    53 E503			xit:
    54 					;copy status back to IOCB
    55 E503 A6 2E			ldx		icidno
    56 E505 98				tya
    57 E506 9D 43 03			sta		icsta,x
    58 E509 08				php
    59 					
    60 E50A 9C E9 02			stz		hndlod
    61
    62 E50D A5 2F			lda		ciochr
    63 E50F 28				plp
    64 E510 60				rts
    65 					
    66 E511			process:
    67 						;validate IOCB offset
    68 E511 8A					txa
    69 E512 89 8F				bit		#$8f
    70 E514 F0 1B				beq		validIOCB
    71
    72 						;check if it's the special X=$FF used by 816os for first unused
    73 						;IOCB
    74 E516 1A					inc
    75 E517 D0 0D				bne		iocb_invalid
    76
    77 						;find first unused IOCB
    78 E519 A9 00				lda		#0
    79 E51B 18					clc
    80 E51C			iocb_search_loop:
    81 E51C AA					tax
    82 E51D BC 40 03				ldy		ichid,x
    83 E520 30 0A				bmi		found_iocb
    84 E522 69 10				adc		#$10
    85 E524 10 F6				bpl		iocb_search_loop
    86
    87 E526			iocb_invalid:
    88 						;return invalid IOCB error
    89 E526 A0 86				ldy		#CIOStatInvalidIOCB
    90 E528 60					rts
    91 					
    92 E529			cmdInvalid:
    93 						;invalid command <$03
    94 E529 A0 84				ldy		#CIOStatInvalidCmd
    95 E52B 60					rts
    96
    97 E52C			found_iocb:
    98 E52C 86 2E				stx		icidno
    99 E52E A0 01				ldy		#1
   100 E530 60					rts
   101
   102 E531			validIOCB:
   103 E531 20 FA E6			jsr		CIOLoadZIOCB
   104 					
   105 					;check if we're handling the OPEN command
   106 E534 A5 22			lda		iccomz
   107 E536 C9 03			cmp		#CIOCmdOpen
   108 E538 F0 7B			beq		cmdOpen
   109 E53A 90 ED			bcc		cmdInvalid
   110 					
   111 					;check if the IOCB is open
   112 E53C A4 20			ldy		ichidz
   113 					
   114 E53E 30 15			bmi		not_open
   115 					
   116 					;check for a provisionally open IOCB
   117 E540 C8				iny
   118 E541 10 2E			bpl		isOpen
   119 					
   120 					;okay, it's provisionally open... check if it's a close
   121 E543 C9 0C			cmp		#CIOCmdClose
   122 E545 D0 03 4C B1 E6		sne:jmp	cmdCloseProvisional
   123 					
   124 					;check if we're allowed to load a handler
   125 E54A AD E9 02			lda		hndlod
   126 E54D F0 06			beq		not_open
   127 					
   128 					;try to load the handler
   129 E54F 20 AB E7			jsr		CIOLoadHandler
   130 E552 10 1D			bpl		isOpen
   131 E554 60				rts
   132 					
   133 E555			not_open:
   134 					;IOCB isn't open - issue error
   135 					;
   136 					;Special cases;
   137 					; - No error issued for close ($0C). This is needed so that extra CLOSE
   138 					;   commands from BASIC don't trip errors.
   139 					; - Get status ($0D) and special ($0E+) do soft open and close if needed.
   140 					;   $0D case is required for Top Dos 1.5a to boot; $0E+ case is encountered
   141 					;   with R: device XIO commands.
   142 					;
   143 E555 A0 01			ldy		#1
   144 E557 A5 22			lda		iccomz
   145 E559 C9 0C			cmp		#CIOCmdClose
   146 E55B F0 06			beq		ignoreOpen
   147 E55D C9 0D			cmp		#CIOCmdGetStatus
   148 E55F B0 03			bcs		preOpen				;closed IOCB is OK for get status and special
   149 E561			not_open_handler:
   150 E561 A0 85			ldy		#CIOStatNotOpen
   151 E563			ignoreOpen:
   152 E563 60				rts
   153 					
   154 E564			preOpen:
   155 					;If the device is not open when a SPECIAL command is issued, parse the path
   156 					;and soft-open the device in the zero page IOCB.
   157 E564 20 09 E7			jsr		CIOParsePath
   158
   159 					;check for special command
   160 E567 A5 22			lda		iccomz
   161 E569 C9 0D			cmp		#CIOCmdGetStatus
   162 E56B F0 40			beq		cmdGetStatusSoftOpen
   163 E56D C9 0E			cmp		#CIOCmdSpecial
   164 E56F B0 3F			bcs		cmdSpecialSoftOpen
   165 					
   166 E571			isOpen:
   167 E571 A6 22			ldx		iccomz
   168 E573 E0 0E			cpx		#CIOCmdSpecial
   169 E575 90 02 A2 0E			scc:ldx	#$0e
   170 					
   171 					;do permissions check
   172 E579 BD B8 E6			lda		perm_check_table-4,x
   173 E57C 30 04			bmi		skip_perm_check
   174 E57E 24 2A			bit		icax1z
   175 E580 F0 26			beq		perm_check_fail
   176 E582			skip_perm_check:
   177
   178 					;load command table vector
   179 E582 BD D9 E6			lda		command_table_hi-4,x
   180 E585 48				pha
   181 E586 BD CE E6			lda		command_table_lo-4,x
   182 E589 48				pha
   183 					
   184 					;preload dispatch vector and dispatch to command
   185 E58A BC C3 E6			ldy		vector_preload_table-4,x
   186 E58D			load_vector:
   187 E58D A6 20			ldx		ichidz
   188 E58F BD 1B 03 85 2C BD + 	mwa		hatabs+1,x icax3z
   189 E599 B1 2C			lda		(icax3z),y
   190 E59B AA				tax
   191 E59C 88				dey
   192 E59D B1 2C			lda		(icax3z),y
   193 E59F 85 2C			sta		icax3z
   194 E5A1 86 2D			stx		icax3z+1
   195 					
   196 					;many commands want to check length=0 on entry
   197 E5A3 A5 28			lda		icbllz
   198 E5A5 05 29			ora		icblhz
   199 E5A7 60				rts
   200
   201 E5A8			perm_check_fail:
   202 					;at this point we have A=$04 if we failed a get perm check, and A=$08
   203 					;if we failed a put perm check -- these need to be translated to Y=$83
   204 					;and Y=$87.
   205 E5A8 18				clc
   206 E5A9 69 7F			adc		#$7f
   207 E5AB A8				tay
   208 E5AC 60				rts
