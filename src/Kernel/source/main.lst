   119 FE16 B1 5E			lda		(oldadr),y
   120 FE18 85 5D			sta		oldchr
   121 FE1A AE F0 02			ldx		crsinh
   122 FE1D D0 04			bne		cursor_inhibited
   123 FE1F 49 80			eor		#$80
   124 FE21 91 5E			sta		(oldadr),y
   125 FE23			cursor_inhibited:
   126 FE23 C8				iny
   127 FE24 60				rts
   128 				.endp
