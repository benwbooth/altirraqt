   998 				;==========================================================================
   999 				; Compute the current logical column.
  1000 				;
  1001 				; Exit:
  1002 				;	A = column
  1003 				;	X = inverted row index (0-2 => $ff-$fd)
  1004 				;
  1005 FDA4			.proc	EditorGetLogicalColumn
  1006 					;get starting row of logical line
  1007 FDA4 A5 54			lda		rowcrs
  1008 FDA6 20 89 FD			jsr		EditorPhysToLogicalRow
  1009 					
  1010 					;subtract off current row
  1011 FDA9 18				clc
  1012 FDAA E5 54			sbc		rowcrs
  1013 FDAC AA				tax
  1014 					
  1015 					;multiply negated difference by 40
  1016 FDAD BD D8 FC			lda		EditorLineLengthTab-$fc,x
  1017 					
  1018 					;add in physical column
  1019 FDB0 65 55			adc		colcrs
  1020 FDB2 60				rts
  1021 				.endp
