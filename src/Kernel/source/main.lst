  1602 				;==========================================================================
  1603 				; Swap between the main screen and the split screen.
  1604 				;
  1605 				; Conventionally, the main screen is left as the selected context when
  1606 				; the display handler is not active.
  1607 				;
  1608 				; Inputs:
  1609 				;	C = 0	for main screen
  1610 				;	C = 1	for split screen
  1611 				;
  1612 				; Modified:
  1613 				;	X
  1614 				;
  1615 				; Preserved:
  1616 				;	A
  1617 				;	
  1618 				;==========================================================================
  1619 				; Swap in the text screen (main if gr.0, split otherwise).
  1620 				;
  1621 F940			.proc	EditorSwapToText
  1622 					;set C=0 (main) if gr.0, C=1 (split) otherwise
  1623 F940 A0 17			ldy		#23
  1624 F942 CC BF 02			cpy		botscr
  1625
  1626 = F945			.def :ScreenSwap = *
  1627 					;check if the correct set is in place
  1628 F945 48				pha
  1629 F946 A9 00			lda		#0
  1630 F948 65 7B			adc		swpflg
  1631 F94A F0 14			beq		already_there
  1632 					
  1633 					;Nope, we need to swap. Conveniently, the data to be swapped
  1634 					;is in a 12 byte block:
  1635 					;
  1636 					;	ROWCRS ($0054)		TXTROW ($0290)
  1637 					;	COLCRS ($0055)		TXTCOL ($0291)
  1638 					;	DINDEX ($0057)		TINDEX ($0293)
  1639 					;	SAVMSC ($0058)		TXTMSC ($0294)
  1640 					;	OLDROW ($005A)		TXTOLD ($0296)
  1641 					;	OLDCOL ($005B)		TXTOLD ($0297)
  1642 					;	OLDCHR ($005D)		TXTOLD ($0299)
  1643 					;	OLDADR ($005E)		TXTOLD ($029A)
  1644 					
  1645 F94C A2 0B			ldx		#11
  1646 F94E			swap_loop:
  1647 F94E B5 54			lda		rowcrs,x
  1648 F950 BC 90 02			ldy		txtrow,x
  1649 F953 94 54			sty		rowcrs,x
  1650 F955 9D 90 02			sta		txtrow,x
  1651 F958 CA				dex
  1652 F959 10 F3			bpl		swap_loop
  1653 					
  1654 					;invert swap flag
  1655 F95B 8A				txa
  1656 F95C 45 7B			eor		swpflg
  1657 F95E 85 7B			sta		swpflg
  1658 					
  1659 F960			already_there:
  1660 F960 68				pla
  1661 F961 60				rts
  1662 				.endp
  1663
  1664 				;==========================================================================
  1665 				; Compute character address.
  1666 				;
  1667 				; Entry:
  1668 				;	X = byte index
  1669 				;	Y = line index
  1670 				;
  1671 				; Exit:
  1672 				;	A:X = address
  1673 				;
  1674 				; Used:
  1675 				;	ADRESS
  1676 				;
  1677 F962			.proc	ScreenComputeAddr
  1678 F962 20 82 F9			jsr		ScreenComputeRangeSize
  1679 F965 85 64			sta		adress
  1680 F967 8A				txa
  1681 F968 18				clc
  1682 F969 65 64			adc		adress			;row*10,20,40+col
  1683 F96B 90 02 E6 65			scc:inc	adress+1
  1684 F96F 18				clc
  1685 F970 65 58			adc		savmsc
  1686 F972 AA				tax
  1687 F973 A5 65			lda		adress+1
  1688 F975 65 59			adc		savmsc+1
  1689 F977 60				rts
  1690 				.endp
  1691
  1692 				;==========================================================================
  1693 = F97A			ScreenComputeToAddr = ScreenComputeToAddrX0.with_x
  1694 F978			.proc	ScreenComputeToAddrX0
  1695 F978 A2 00			ldx		#0
  1696 F97A			with_x:
  1697 F97A 20 62 F9			jsr		ScreenComputeAddr
  1698 F97D 86 66			stx		toadr
  1699 F97F 85 67			sta		toadr+1
  1700 F981 60				rts
  1701 				.endp
  1702
  1703 				;==========================================================================
  1704 				; Compute size, in bytes, of a series of lines.
  1705 				;
  1706 				; Entry:
  1707 				;	Y = line count
  1708 				;
  1709 				; Exit:
  1710 				;	ADRESS+1	High byte of size
  1711 				;	A			Low byte of size
  1712 				;	
  1713 				; Preserved:
  1714 				;	X
  1715 				;
  1716 				; Modified:
  1717 				;	Y
  1718 				;
  1719 F982			.proc	ScreenComputeRangeSize
  1720 F982 A9 00 85 65			mva		#0 adress+1
  1721 F986 84 64			sty		adress
  1722 F988 A4 57			ldy		dindex
  1723 F98A B9 AE F2			lda		ScreenPixelWidthIds,y
  1724 F98D 38				sec
  1725 F98E F9 C9 F2			sbc		ScreenEncodingTab,y
  1726 F991 A8				tay
  1727 F992 C8				iny
  1728 F993 A5 64			lda		adress
  1729 F995 0A				asl
  1730 F996 26 65			rol		adress+1		;row*2
  1731 F998 0A				asl
  1732 F999 26 65			rol		adress+1		;row*4
  1733 F99B 65 64			adc		adress			;row*5
  1734 F99D 90 02 E6 65			scc:inc	adress+1
  1735 F9A1			shift_loop:
  1736 F9A1 0A				asl
  1737 F9A2 26 65			rol		adress+1		;row*10,20,40
  1738 F9A4 88				dey
  1739 F9A5 10 FA			bpl		shift_loop
  1740 F9A7 60				rts
  1741 				.endp
  1742
  1743 				;==========================================================================
  1744 				; Setup for pixel plot.
  1745 				;
  1746 				; Entry:
  1747 				;	OLDCOL, OLDROW = position
  1748 				;	DELTAC = left-justified pixel mask
  1749 				;
  1750 				; Exit:
  1751 				;	TOADR = screen row
  1752 				;	SHFAMT = byte offset within row
  1753 				;	BITMSK = shifted bit mask for pixel
  1754 				;
  1755 				; Modified:
  1756 				;	ADRESS
  1757 				;
  1758 = F9AD			ScreenAlignPixel = ScreenSetupPlotPixel.rshift_mask
  1759 F9A8			.proc ScreenSetupPlotPixel
  1760 					;;##TRACE "Folded pixel = $%02X" db(hold1)
  1761 F9A8 20 B7 F9			jsr		ScreenSetupPixelAddr
  1762 					
  1763 					;preshift bit mask
  1764 F9AB A5 77			lda		deltac
  1765 F9AD			rshift_mask:
  1766 F9AD CA				dex
  1767 F9AE 30 04			bmi		xmaskshift_done
  1768 F9B0			xmaskshift_loop:
  1769 F9B0 4A				lsr
  1770 F9B1 CA				dex
  1771 F9B2 10 FC			bpl		xmaskshift_loop
  1772 F9B4			xmaskshift_done:
  1773 F9B4 85 6E			sta		bitmsk
  1774 					
  1775 					;;##TRACE "Initial bitmasks = $%02X $%02X" db(bitmsk) db(dmask)
  1776 F9B6 60				rts
  1777 				.endp
  1778
  1779 				;==========================================================================
  1780 				; Setup for pixel addressing.
  1781 				;
  1782 				; Entry:
  1783 				;	COLCRS, ROWCRS = position (ScreenSetupPixelAddr)
  1784 				;	OLDCOL, OLDROW = position (ScreenSetupPixelAddrOld)
  1785 				;
  1786 				; Exit:
  1787 				;	TOADR = screen row
  1788 				;	SHFAMT = byte offset within row
  1789 				;	X = number of bits from left side of byte to left side of pixel
  1790 				;
  1791 F9B7			.proc ScreenSetupPixelAddr
  1792 					;compute initial address
  1793 F9B7 A4 5A			ldy		oldrow
  1794 F9B9 20 78 F9			jsr		ScreenComputeToAddrX0
  1795 					
  1796 					;;##TRACE "Initial row address = $%04X" dw(toadr)
  1797 					
  1798 					;compute initial byte offset
  1799 F9BC A5 5C			lda		oldcol+1
  1800 F9BE A6 5B			ldx		oldcol
  1801 F9C0			phase2:
  1802 F9C0 6A				ror
  1803 F9C1 86 6F			stx		shfamt
  1804 F9C3 A9 00			lda		#0
  1805 F9C5 A6 57			ldx		dindex
  1806 F9C7 BC C9 F2			ldy		ScreenEncodingTab,x
  1807 F9CA F0 06			beq		no_xshift	
  1808 F9CC			xshift_loop:
  1809 F9CC 66 6F			ror		shfamt
  1810 F9CE 6A				ror
  1811 F9CF 88				dey
  1812 F9D0 D0 FA			bne		xshift_loop
  1813 F9D2			no_xshift:
  1814 F9D2 2A				rol
  1815 F9D3 2A				rol
  1816 F9D4 2A				rol
  1817 F9D5 2A				rol
  1818 F9D6 AA				tax
  1819
  1820 					;;##TRACE "Initial row offset = $%02X" db(shfamt)
  1821 F9D7 60				rts
  1822 				.endp
  1823
  1824 				;==========================================================================
  1825 				; ScreenAdvancePosNonMode0
  1826 				;
  1827 F9D8			.proc ScreenAdvancePosNonMode0
  1828 					;advance position
  1829 F9D8 E6 55			inc		colcrs
  1830 F9DA D0 02 E6 56			sne:inc	colcrs+1
  1831 F9DE A6 57			ldx		dindex
  1832 F9E0 BC AE F2			ldy		ScreenPixelWidthIds,x
  1833 F9E3 BE C4 F2			ldx		ScreenPixelWidthsHi,y
  1834 F9E6 E4 56			cpx		colcrs+1
  1835 F9E8 D0 0F			bne		graphics_no_wrap
  1836 F9EA BE BF F2			ldx		ScreenPixelWidthsLo,y
  1837 F9ED E4 55			cpx		colcrs
  1838 F9EF D0 08			bne		graphics_no_wrap
  1839
  1840 F9F1			graphics_eol:
  1841 					;move to left side and then one row down -- note that this may
  1842 					;push us into an invalid coordinate, which will result on an error
  1843 					;on the next call if not corrected
  1844 F9F1 A0 00			ldy		#0
  1845 F9F3 84 55			sty		colcrs
  1846 F9F5 84 56			sty		colcrs+1
  1847 F9F7 E6 54			inc		rowcrs
  1848 F9F9			graphics_no_wrap:
  1849 F9F9 A0 01			ldy		#1
  1850 F9FB 60				rts
  1851 				.endp
