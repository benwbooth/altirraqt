   477 				;==========================================================================
   478 				; Invoke device vector.
   479 				;
   480 				; Entry (standard):
   481 				;	A, X = ignored
   482 				;	Y = offset to high vector byte in device table
   483 				;
   484 				; Entry (invoke_vector):
   485 				;	A = byte to pass to PUT CHAR vector
   486 				;	X, Y = ignored
   487 				;
   488 				; Exit:
   489 				;	A = byte returned from GET CHAR vector
   490 				;	Y = status
   491 				;
   492 E6E8			.proc CIOInvoke
   493 E6E8 20 8D E5			jsr		CIO.load_vector		
   494 E6EB			invoke_vector:
   495 E6EB 85 2F			sta		ciochr
   496 E6ED			invoke_vector_ciochr:
   497 E6ED A5 2D			lda		icax3z+1
   498 E6EF 48				pha
   499 E6F0 A5 2C			lda		icax3z
   500 E6F2 48				pha
   501 E6F3 A0 92			ldy		#CIOStatNotSupported
   502 E6F5 A6 2E			ldx		icidno
   503 E6F7 A5 2F			lda		ciochr
   504 E6F9 60				rts
   505 				.endp
   506
   507 				;==========================================================================
   508 				; Copy IOCB to ZIOCB.
   509 				;
   510 				; Entry:
   511 				;	X = IOCB
   512 				;
   513 				; [OSManual p236] "Although both the outer level IOCB and the Zero-page
   514 				; IOCB are defined to be 16 bytes in size, only the first 12 bytes are
   515 				; moved by CIO."	
   516 				;
   517 E6FA			.proc CIOLoadZIOCB
   518 					;We used to do a trick here where we would count Y from $F4 to $00...
   519 					;but we can't do that because the 65C816 doesn't wrap abs,Y within
   520 					;bank 0 even in emulation mode. Argh!
   521 					
   522 E6FA A0 00			ldy		#0
   523 E6FC			copyToZIOCB:
   524 E6FC BD 40 03			lda		ichid,x
   525 E6FF 99 20 00			sta		ziocb,y
   526 E702 E8				inx
   527 E703 C8				iny
   528 E704 C0 0C			cpy		#12	
   529 E706 D0 F4			bne		copyToZIOCB
   530 E708 60				rts
   531 				.endp
   532
   533 				;==========================================================================
   534 E709			.proc CIOParsePath
   535 					;default to device #1
   536 E709 A2 01			ldx		#1
   537
   538 					;pull first character of filename and stash it
   539 E70B A1 23			lda		(icbalz-1,x)
   540 E70D 85 2D			sta		icax4z
   541 						
   542 					;Check for a device number.
   543 					;
   544 					; - D1:-D9: is supported. D0: also gives unit 1, and any digits beyond
   545 					;   the first are ignored.
   546 					;
   547 					; We don't validate the colon anymore -- Atari OS allows opening just "C" to get
   548 					; to the cassette.
   549 					;
   550 E70F A0 01			ldy		#1
   551 E711 B1 24			lda		(icbalz),y
   552 E713 38				sec
   553 E714 E9 30			sbc		#'0'
   554 E716 F0 06			beq		nodevnum
   555 E718 C9 0A			cmp		#10
   556 E71A B0 02			bcs		nodevnum
   557 E71C AA				tax
   558 					
   559 E71D C8				iny
   560 					
   561 E71E			nodevnum:
   562 E71E 86 21			stx		icdnoz
   563 					
   564 				.if _KERNEL_XLXE
   565 					;check if we are doing a true open and if we should do a type 4 poll
   566 E720 A5 22			lda		iccomz
   567 E722 C9 03			cmp		#CIOCmdOpen
   568 E724 D0 3D			bne		skip_poll
   569 					
   570 					;clear DVSTAT+0/+1 to indicate no poll
   571 E726 A9 00			lda		#0
   572 E728 8D EA 02			sta		dvstat
   573 E72B 8D EB 02			sta		dvstat+1
   574 					
   575 					;check if we should do an unconditional poll (HNDLOD nonzero).
   576 E72E AD E9 02			lda		hndlod
   577 E731 D0 05			bne		unconditional_poll
   578 					
   579 					;search handler table
   580 E733 20 78 E7			jsr		CIOFindHandler
   581 E736 F0 34			beq		found
   582 					
   583 E738			unconditional_poll:
   584 					;do type 4 poll
   585 E738 20 89 E7			jsr		CIOPollForDevice
   586 E73B 30 2B			bmi		unknown_device
   587 					
   588 					;mark provisionally open
   589 E73D A6 2E			ldx		icidno
   590 E73F A9 7F 9D 40 03		mva		#$7f ichid,x
   591 E744 A5 2D 9D 4C 03		mva		icax4z icax3,x
   592 E749 AD EC 02 9D 4D 03		mva		dvstat+2 icax4,x
   593 E74F A9 D7 9D 46 03 A9 + 	mwa		#CIOPutByteLoadHandler-1 icptl,x
   594 E759 A5 21 9D 41 03		mva		icdnoz icdno,x
   595
   596 					;do direct exit, bypassing regular open path
   597 E75E 68				pla
   598 E75F 68				pla
   599 E760 A0 01			ldy		#1
   600 E762 60				rts
   601
   602 E763			skip_poll:
   603 				.endif
   604
   605 					;search handler table
   606 E763 20 78 E7			jsr		CIOFindHandler
   607 E766 F0 04			beq		found
   608 					
   609 E768			unknown_device:
   610 					;return unknown device error
   611 E768 A0 82			ldy		#CIOStatUnkDevice
   612 E76A 68				pla
   613 E76B 68				pla
   614 E76C			found:
   615 E76C 60				rts
   616 				.endp
   617
   618 				;==========================================================================
   619 E76D			.proc CIOSetPutByteClosed
   620 E76D A9 60			lda		#<[CIO.not_open_handler-1]
   621 E76F 9D 46 03			sta		icptl,x
   622 E772 A9 E5			lda		#>[CIO.not_open_handler-1]
   623 E774 9D 47 03			sta		icpth,x
   624 E777 60				rts
   625 				.endp
   626
   627 				;==========================================================================
   628 				; Attempt to find a handler entry in HATABS.
   629 				;
   630 E778			.proc CIOFindHandler
   631 					;search for handler
   632 E778 A5 2D			lda		icax4z
   633 E77A A2 21			ldx		#11*3
   634 E77C			findHandler:
   635 E77C DD 1A 03			cmp		hatabs,x
   636 E77F F0 05			beq		foundHandler
   637 E781 CA				dex
   638 E782 CA				dex
   639 E783 CA				dex
   640 E784 10 F6			bpl		findHandler
   641 E786			foundHandler:
   642 					;store handler ID
   643 E786 86 20			stx		ichidz
   644 E788 60				rts
   645 				.endp
   646
   647 				;==========================================================================
   648 				; Poll SIO bus for CIO device
   649 				;
   650 				; Issues a type 4 poll ($4F/$40/devname/devnumber).
   651 				;
   652 				.if _KERNEL_XLXE
   653 E789			.proc CIOPollForDevice
   654 E789 A5 2D			lda		icax4z
   655 E78B 8D 0A 03			sta		daux1
   656 E78E A5 21			lda		icdnoz
   657 E790 8D 0B 03			sta		daux2
   658 					
   659 E793 A2 09			ldx		#9
   660 E795 BD A1 E7 9D 00 03 + 	mva:rpl	cmd_tab,x ddevic,x-
   661 					
   662 E79E 4C 59 E4			jmp		siov
   663 					
   664 E7A1			cmd_tab:
   665 E7A1 4F				dta		$4f		;device
   666 E7A2 01				dta		$01		;unit
   667 E7A3 40				dta		$40		;command
   668 E7A4 40				dta		$40		;status (transfer flags)
   669 E7A5 EA				dta		<dvstat	;dbuflo
   670 E7A6 02				dta		>dvstat	;dbufhi
   671 E7A7 40				dta		$40		;dtimlo
   672 E7A8 00				dta		$00		;unused
   673 E7A9 04				dta		$04		;dbytlo
   674 E7AA 00				dta		$00		;dbythi
   675 				.endp
   676 				.endif
   677
   678 				;==========================================================================
   679 				; Load handler for a provisionally open IOCB.
   680 				;
   681 				.if _KERNEL_XLXE
   682 E7AB			.proc CIOLoadHandler
   683 					;load handler over SIO bus
   684 E7AB AD EC 02 8D D1 02 + 	mwa		dvstat+2 loadad
   685 E7B7 A6 2E			ldx		icidno
   686 E7B9 BD 4D 03 8D 00 03		mva		icax4,x ddevic
   687 E7BF 20 8F C5			jsr		PHLoadHandler
   688 E7C2 B0 11			bcs		fail
   689 					
   690 					;let's see if we can look up the handler now
   691 E7C4 A6 2E			ldx		icidno
   692 E7C6 BD 4C 03 85 2D		mva		icax3,x icax4z
   693 E7CB 20 78 E7			jsr		CIOFindHandler
   694 E7CE D0 05			bne		fail
   695 					
   696 					;follow through with open
   697 E7D0 20 C0 E5			jsr		CIO.open_entry
   698 E7D3 10 02			bpl		ok
   699 E7D5			fail:
   700 E7D5 A0 82			ldy		#CIOStatUnkDevice
   701 E7D7			ok:
   702 E7D7 60				rts
   703 				.endp
   704 				.endif
   705
   706 				;==========================================================================
   707 				; PUT BYTE handler for provisionally open IOCBs.
   708 				;
   709 				; This handler is used when an IOCB has been provisionally opened pending
   710 				; a handler load over the SIO bus. It is used when a direct call is made
   711 				; through ICPTL/ICPTH. If HNDLOD=0, the call fails as handler loading is
   712 				; not set up; if it is nonzero, the handler is loaded over the SIO bus and
   713 				; then the PUT BYTE call continues if everything is good.
   714 				;
   715 				.if _KERNEL_XLXE
   716 E7D8			.proc CIOPutByteLoadHandler
   717 					;save off A/X
   718 E7D8 85 2F			sta		ciochr
   719 E7DA 86 2E			stx		icidno
   720 						
   721 					;check if we're allowed to load a handler and bail if not
   722 E7DC AD E9 02			lda		hndlod
   723 E7DF F0 10			beq		load_error
   724
   725 					;copy IOCB to ZIOCB
   726 E7E1 20 FA E6			jsr		CIOLoadZIOCB
   727
   728 					;try to load the handler
   729 E7E4 20 AB E7			jsr		CIOLoadHandler
   730 E7E7 30 08			bmi		load_error
   731 					
   732 					;all good... let's invoke the standard handler
   733 E7E9 A0 07			ldy		#7
   734 E7EB 20 E8 E6			jsr		CIOInvoke
   735 E7EE 4C F3 E7			jmp		xit
   736 					
   737 E7F1			load_error:
   738 E7F1 A0 82			ldy		#CIOStatUnkDevice
   739 E7F3			xit:
   740 E7F3 08				php
   741 E7F4 A5 2F			lda		ciochr
   742 E7F6 A6 2E			ldx		icidno
   743 E7F8 28				plp
   744 E7F9 60				rts
   745 				.endp
   746 				.endif
   234 					.else
   235 					icl		'cio.s'
   236 					.endif
