Macro: _KERNEL_REPORT_MODULE_SIZE [Source: /home/ben/src/altirraqt/src/Kernel/source/main.xasm]
     1 					.echo	'    ', *, ' -> ', *-?@_kernel_lastpt, '(', $F0E3-$EF41, ')', '    ', 'Cassette Handler'
     1 				    $EEB7 -> $0192($01A2)    Cassette Handler
     3 = EEB7				.def ?@_kernel_lastpt = *
Source: /home/ben/src/altirraqt/src/Kernel/source/main.xasm
   259 					
   260 					.ifdef _KERNEL_816
   261 EEB7				icl		'init816.s'
Source: /home/ben/src/altirraqt/src/Kernel/source/Shared/init816.s
     1 				;	Altirra - Atari 800/800XL emulator
     2 				;	Kernel ROM replacement - 65C816 Initialization
