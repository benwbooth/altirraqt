   376 				;==========================================================================
   377 				; Sound a bell using the console speaker (cassette version)
   378 				;
   379 				; Modified:
   380 				;	A, X, Y
   381 				;
   382 EE9A			.proc CassetteBell
   383 EE9A A0 00			ldy		#0
   384 EE9C 98				tya
   385 EE9D			soundloop:
   386 EE9D A2 0A			ldx		#10
   387 EE9F 48				pha
   388 EEA0			delay:
   389 EEA0 AD 0B D4			lda		vcount
   390 EEA3 CD 0B D4 F0 FB		cmp:req	vcount
   391 EEA8 CA				dex
   392 EEA9 D0 F5			bne		delay
   393 EEAB 68				pla
   394 EEAC 49 08			eor		#$08
   395 EEAE 8D 1F D0			sta		consol
   396 EEB1 D0 EA			bne		soundloop
   397 EEB3 88				dey
   398 EEB4 D0 E7			bne		soundloop
   399 EEB6 60				rts
   400 				.endp
