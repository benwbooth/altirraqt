    10 EC23			.proc DiskInit
    11 					.if _KERNEL_XLXE
    12 					;set disk sector size to 128 bytes
    13 EC23 A9 80 8D D5 02 A9 + 	mwa		#$80	dsctln
    14 					.endif
    15 EC2D 60				rts
    16 				.endp
    17
    18 				;==========================================================================
    19 				; Disk handler routine (pointed to by DSKINV)
    20 				;
    21 				; Exit:
    22 				;	A = command byte (undocumented; required by Pooyan)
    23 				;	Y = status
    24 				;	N = 1 if error, 0 if success (high bit of Y)
    25 				;	C = 1 if command is >=$21 (undocumented; required by Arcade Machine)
    26 				;
    27 EC2E			.proc DiskHandler
    28 EC2E A9 31 8D 00 03		mva		#$31	ddevic
    29 EC33 A9 0F 8D 06 03		mva		#$0f	dtimlo
    30 					
    31 					;check for status command
    32 EC38 AD 02 03			lda		dcomnd
    33 EC3B 8D 3B 02			sta		ccomnd
    34 EC3E C9 53			cmp		#$53
    35 EC40 D0 20			bne		notStatus
    36
    37 EC42 A9 EA			lda		#<dvstat
    38 EC44 8D 04 03			sta		dbuflo
    39 EC47 A9 02			lda		#>dvstat
    40 EC49 8D 05 03			sta		dbufhi
    41 EC4C 0A				asl							;hack to save a byte to get $04 since >dvstat is $02
    42 EC4D 8D 08 03			sta		dbytlo
    43 EC50 A9 00			lda		#0
    44 EC52 8D 09 03			sta		dbythi
    45 					
    46 EC55 20 80 EC			jsr		do_read
    47 EC58 30 07			bmi		xit
    48 					
    49 					;update format timeout
    50 EC5A AE EC 02 8E 46 02		mvx		dvstat+2 dsktim
    51 EC60 AA				tax
    52 EC61			xit:
    53 EC61 60				rts
    54 					
    55 EC62			notStatus:
    56
    57 					;set disk sector length
    58 					.if _KERNEL_XLXE
    59 EC62 AC D5 02 8C 08 03 + 	mwy		dsctln	dbytlo
    60 					.else
    61 					mwy		#$80 dbytlo
    62 					.endif
    63 					
    64 					;check for put/write
    65 					.if _KERNEL_XLXE
    66 EC6E C9 50			cmp		#$50
    67 EC70 F0 1D			beq		do_write
    68 					.endif
    69 EC72 C9 57			cmp		#$57
    70 EC74 F0 19			beq		do_write
    71 					
    72 					;check for format, or else assume it's a read command ($52) or similar
    73 EC76 C9 21			cmp		#$21
    74 EC78 D0 06			bne		do_read
    75
    76 					;it's format... use the format timeout
    77 EC7A AD 46 02 8D 06 03		mva		dsktim dtimlo
    78
    79 EC80			do_read:
    80 EC80 A9 40			lda		#$40
    81 EC82			do_io:
    82 EC82 8D 03 03			sta		dstats
    83 EC85 20 59 E4			jsr		siov
    84 					
    85 					;load disk command back into A (required by Pooyan)
    86 					;emulate compare against format command (required by Arcade Machine)
    87 					;sort-of emulate compare against status (required by Micropainter)
    88 EC88 AD 02 03			lda		dcomnd
    89 EC8B C0 00			cpy		#0					;!! Atari800WinPlus's SIO patch doesn't set STATUS
    90 EC8D 38				sec
    91 EC8E 60				rts
    92
    93 EC8F			do_write:
    94 EC8F A9 80			lda		#$80
    95 EC91 D0 EF			bne		do_io
    96 				.endp
