  1040 				; Copy TOADR to FRMADR and add 40 to TOADR.
  1041 				;
  1042 FDC2			.proc EditorNextLineAddr
  1043 FDC2 A5 66			lda		toadr
  1044 FDC4 85 68			sta		frmadr
  1045 FDC6 18 69 28			add		#40
  1046 FDC9 85 66			sta		toadr
  1047 FDCB A5 67			lda		toadr+1
  1048 FDCD 85 69			sta		frmadr+1
  1049 FDCF 69 00			adc		#0
  1050 FDD1 85 67			sta		toadr+1
  1051 FDD3 60				rts
  1052 				.endp
