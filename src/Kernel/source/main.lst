   306 FAFB 1B				dta		$1b
   307 FAFC 1C				dta		$1c
   308 FAFD 1D				dta		$1d
   309 FAFE 1E				dta		$1e
   310 FAFF 1F				dta		$1f
   311 FB00 7D				dta		$7d
   312 FB01 7E				dta		$7e
   313 FB02 7F				dta		$7f
   314 FB03 9C				dta		$9c
   315 FB04 9D				dta		$9d
   316 FB05 9E				dta		$9e
   317 FB06 9F				dta		$9f
   318 FB07 FD				dta		$fd
   319 FB08 FE				dta		$fe
   320 FB09 FF				dta		$ff
   321 FB0A			special_code_tab_end:
   322 FB0A 9B				dta		$9b				;this is only for the K: check
   323 FB0B			special_code_tab_end_2:
   324
   325 				;----------------
   326
   327 FB0B			special_dispatch_lo_tab:
   328 FB0B 19				dta		<(special_escape-1)
   329 FB0C 22				dta		<(special_up-1)
   330 FB0D 2C				dta		<(special_down-1)
   331 FB0E C2				dta		<(special_left-1)
   332 FB0F CF				dta		<(special_right-1)
   333 FB10 1F				dta		<(special_clear-1)
   334 FB11 47				dta		<(special_backspace-1)
   335 FB12 88				dta		<(special_tab-1)
   336 FB13 D8				dta		<(special_delete_line-1)
   337 FB14 DE				dta		<(special_insert_line-1)
   338 FB15 75				dta		<(special_clear_tab-1)
   339 FB16 6D				dta		<(special_set_tab-1)
   340 FB17 68				dta		<(special_bell-1)
   341 FB18 E5				dta		<(special_delete_char-1)
   342 FB19 F1				dta		<(special_insert_char-1)
   343 					
   344 				.if [((special_escape-1)^(special_insert_char-1))&$ff00]
   345 					.error 'Special character routines cross a page boundary: ',special_escape,'-',special_insert_char
   346 				.endif
