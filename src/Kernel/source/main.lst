   475 					;-------------------------------------------------------------------------
   476 					; Pre-boot hook (AltirraOS-specific)
   477 					;
   478
   479 					.ifdef	_KERNEL_PRE_BOOT_HOOK
   480 					jsr		InitPreBootHook
   481 					.endif
