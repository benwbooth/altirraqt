    72 				; AFP [D800]	Convert ASCII string at INBUFF[CIX] to FR0
    73 				;
    74 D800				org		$d800
    75 = D800			_afp = afp
    76 D800			.proc afp
    77 = 00E6			dotflag = fr2
    78 = 00E7			xinvert = fr2+1
    79 = 00E8			cix0 = fr2+2
    80 = 00E9			sign = fr2+3
    81 = 00EA			digit2 = fr2+4
    82
    83 					;skip initial spaces
    84 D800 20 A1 DB			jsr		skpspc
    85
    86 					;init FR0 and one extra mantissa byte
    87 D803 A9 7F			lda		#$7f
    88 D805 85 D4			sta		fr0
    89 D807 85 EA			sta		digit2
    90 					
    91 D809 A2 D5			ldx		#fr0+1
    92 D80B 20 46 DA			jsr		zf1
    93
    94 					;clear decimal flag
    95 D80E 85 E6			sta		dotflag
    96 D810 85 E9			sta		sign
    97 					
    98 					;check for sign
    99 D812 A4 F2			ldy		cix
   100 D814 B1 F3			lda		(inbuff),y
   101 D816 C9 2B			cmp		#'+'
   102 D818 F0 06			beq		isplus
   103 D81A C9 2D			cmp		#'-'
   104 D81C D0 03			bne		postsign
   105 D81E 66 E9			ror		sign
   106 D820			isplus:
   107 D820 C8				iny
   108 D821			postsign:	
   109 D821 84 E8			sty		cix0
   110
   111 					;skip leading zeroes
   112 D823 A9 30			lda		#'0'
   113 D825 20 A5 DB			jsr		fp_skipchar
   114 					
   115 					;check if next char is a dot, indicating mantissa <1
   116 D828 B1 F3			lda		(inbuff),y
   117 D82A C9 2E			cmp		#'.'
   118 D82C D0 10			bne		not_tiny
   119 D82E C8				iny
   120 					
   121 					;set dot flag
   122 D82F 66 E6			ror		dotflag
   123
   124 					;increment anchor so we don't count the dot as a digit for purposes
   125 					;of seeing if we got any digits
   126 D831 E6 E8			inc		cix0
   127 					
   128 					;skip zeroes and adjust exponent
   129 D833 A9 30			lda		#'0'
   130 D835			tiny_denorm_loop:
   131 D835 D1 F3			cmp		(inbuff),y
   132 D837 D0 05			bne		tiny_denorm_loop_exit
   133 D839 C6 D4			dec		fr0
   134 D83B C8				iny
   135 D83C D0 F7			bne		tiny_denorm_loop
   136 D83E			tiny_denorm_loop_exit:
   137 					
   138 D83E			not_tiny:
   139
   140 					;grab digits left of decimal point
