   924 = FD71			EditorGetCurLogicalLineInfo = _EditorGetLogicalLineInfo
   925 = FD73			EditorGetLogicalLineInfo = _EditorGetLogicalLineInfo.use_a
   926 FD71			.proc	_EditorGetLogicalLineInfo
   927 FD71 A5 54			lda		rowcrs
   928 FD73			use_a:
   929 FD73 48				pha
   930 FD74 4A				lsr
   931 FD75 4A				lsr
   932 FD76 4A				lsr
   933 FD77 A8				tay
   934 FD78 68				pla
   935 FD79 29 07			and		#7
   936 FD7B AA				tax
   937 FD7C BD C1 E4			lda		ReversedBitMasks,x
   938 FD7F 60				rts
   939 				.endp
