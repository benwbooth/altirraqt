  1026 FDB4 29 07			and		#7
  1027 FDB6 AA				tax
  1028 FDB7 BD C1 E4			lda		ReversedBitMasks,x
  1029 FDBA 48				pha
  1030 FDBB 98				tya
  1031 FDBC 4A				lsr
  1032 FDBD 4A				lsr
  1033 FDBE 4A				lsr
  1034 FDBF AA				tax
  1035 FDC0 68				pla
  1036 FDC1 60				rts
  1037 				.endp
