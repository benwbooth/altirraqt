    23 FE4B A9 40 8D BE 02		mva		#$40	shflok
    24 					
    25 					;set keyboard definition table pointer
    26 					.if _KERNEL_XLXE
    27 FE50 A9 24 85 79 A9 FF + 	mwa		#KeyCodeToATASCIITable keydef
    28 					.endif
    29 FE58 60				rts
    30 				.endp
