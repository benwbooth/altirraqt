   959 				;==========================================================================
   960 				; Get the starting physical line for a logical line.
   961 				;
   962 				; Entry:
   963 				;	A = physical line
   964 				;
   965 				; Exit:
   966 				;	A = logical line start
   967 				;
   968 				; Modified:
   969 				;	ADRESS
   970 				;
   971 = FD89			EditorPhysToLogicalRow = EditorGetCurLogicalRow.use_line
   972 FD87			.proc	EditorGetCurLogicalRow
   973 FD87 A5 54			lda		rowcrs
   974 FD89			use_line:
   975 FD89 85 64			sta		adress
   976 FD8B			test_loop:
   977 FD8B A5 64			lda		adress
   978 FD8D 20 80 FD			jsr		EditorTestLogicalLineBit
   979 FD90 D0 04			bne		found
   980 FD92 C6 64			dec		adress
   981 FD94 D0 F5			bne		test_loop
   982 FD96			found:
   983 FD96 A5 64			lda		adress
   984 FD98 60				rts
   985 				.endp
