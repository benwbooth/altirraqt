   210 				;--------------------------------------------------------------------------
   211 E5AD			cmdGetStatusSoftOpen:
   212 E5AD A0 09			ldy		#9
   213 E5AF 2C				dta		{bit $0100}
   214 E5B0			cmdSpecialSoftOpen:
   215 E5B0 A0 0B			ldy		#11
   216 E5B2			invoke_and_soft_close_xit:
