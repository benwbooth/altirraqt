   778 				;==========================================================================
   779 				; Delete a logical line on screen, and scroll the remainder of the screen
   780 				; upward.
   781 				;
   782 				; Inputs:
   783 				;	A = physical line row to delete
   784 				;
   785 				; Outputs:
   786 				;	DELTAR = number of lines scrolled
   787 				;
   788 = FCD0			EditorDeleteLine = EditorDeleteLine0.use_line
   789 FCCE			.proc	EditorDeleteLine0
   790 FCCE A9 00			lda		#0
   791 FCD0			use_line:
   792 FCD0 85 51			sta		hold1
   793 FCD2 A2 00			ldx		#0
   794 FCD4 86 76			stx		deltar
   795 						
   796 FCD6			scroll_loop:
   797 					;compute base address and set that as destination
   798 FCD6 A4 51			ldy		hold1
   799
   800 				.if _KERNEL_XLXE
   801 FCD8 38				sec
   802 FCD9 D0 21			bne		nofine
   803 FCDB AE 6E 02			ldx		fine
   804 FCDE F0 1C			beq		nofine
   805 FCE0 A2 00			ldx		#0
   806 FCE2			xloop:
   807 FCE2 A5 14			lda		rtclok+2
   808 FCE4 C5 14 F0 FC			cmp:req	rtclok+2
   809 FCE8 E8				inx
   810 FCE9 8E 05 D4			stx		vscrol
   811 FCEC E0 07			cpx		#7
   812 FCEE D0 F2			bne		xloop
   813 FCF0 A9 10			lda		#32/2
   814 FCF2 CD 0B D4 90 FB		cmp:rcc	vcount
   815 FCF7 CD 0B D4 B0 FB		cmp:rcs	vcount
   816 FCFC			nofine:
   817 FCFC 08				php					;C=0 for fine scroll, C=1 for coarse scroll
   818 				.endif
   819
   820 					;set TOADR to the line to be deleted
   821 FCFD 20 78 F9			jsr		ScreenComputeToAddrX0
   822 					
   823 FD00 A6 51			ldx		hold1
   824 FD02 10 0C			bpl		line_loop_start
   825 					
   826 FD04			line_loop:
   827 					;bump line: FRMADR <- TOADR, TOADR += 40
   828 FD04 20 C2 FD			jsr		EditorNextLineAddr
   829 					
   830 					;move line -- note that we are copying backwards (TOADR to FRMADR)!
   831 FD07 A0 27			ldy		#39
   832 FD09 B1 66 91 68 88 10 + 	mva:rpl	(toadr),y (frmadr),y-
   833 					
   834 FD10			line_loop_start:
   835 FD10 E8				inx
   836 FD11 EC BF 02			cpx		botscr
   837 FD14 D0 EE			bne		line_loop
   838 					
   839 					;clear the last line
   840 FD16 A0 27			ldy		#39
   841 FD18 A9 00			lda		#0
   842 FD1A 91 66 88 10 FB		sta:rpl	(toadr),y-
   843 					
   844 				.if _KERNEL_XLXE
   845 FD1F 28				plp
   846 FD20 B0 03			bcs		nofinescroll2
   847 FD22 8D 05 D4			sta		vscrol
   848 FD25			nofinescroll2:
   849 				.endif
   850 					
   851 FD25 20 5A FD			jsr		adjust_lines
   852 					
   853 					;delete bits out of the logical mask until we get to the next
   854 					;logical line, computing the number of lines to scroll
   855 FD28 A5 51			lda		hold1
   856 FD2A 20 73 FD			jsr		EditorGetLogicalLineInfo
   857 FD2D BE 57 FD			ldx		update_table,y		;get number of masks to shift
   858 FD30 38				sec							;setup to add a new logical line at the end
   859 FD31 F0 09			beq		do_mask				;jump to masking if we're on byte 2
   860 FD33 2E B4 02			rol		logmap+2			;shift byte 2
   861 FD36 CA				dex							;
   862 FD37 F0 03			beq		do_mask				;jump to masking if we're on byte 1
   863 FD39 2E B3 02			rol		logmap+1			;shift byte 1
   864 FD3C			do_mask:
   865 FD3C 85 64			sta		adress				;stash mask
   866 FD3E 49 FF			eor		#$ff				;invert mask
   867 FD40 39 B2 02			and		logmap,y			;kill target bit
   868 FD43 85 65			sta		adress+1			;stash modified mask
   869 FD45 C6 64			dec		adress				;form mask for LSBs below bit
   870 FD47 25 64			and		adress				;isolate those bits
   871 FD49 65 65			adc		adress+1			;shift those up and the bit from the next byte in
   872 FD4B 99 B2 02			sta		logmap,y			;write to logmap
   873
   874 FD4E E6 76			inc		deltar				;increment line count
   875 FD50 E6 64			inc		adress				;revert mask
   876 FD52 24 64			bit		adress				;test if we still have a logical line
   877
   878 					;loop back if we need to delete more physical lines
   879 FD54 F0 80			beq		scroll_loop
   880 					
   881 					;all done
   882 FD56 60				rts
   883 					
   884 FD57			update_table:
   885 FD57 02 01 00			dta		2,1,0
   886
   887 FD5A			adjust_lines:
   888 FD5A A5 52			lda		lmargn				;prep for line adjustments
   889 					
   890 					;adjust the read row if it is affected by the deletion
   891 FD5C A2 6C			ldx		#<bufstr
   892 FD5E 20 63 FD			jsr		adjust_line
   893
   894 					;adjust the cursor row if it is affected by the deletion
   895 FD61 A2 54			ldx		#<rowcrs
   896 FD63			adjust_line:
   897 FD63 B4 00			ldy		0,x						;get row
   898 FD65 C4 51			cpy		hold1					;compare against deletion pos
   899 FD67 90 07			bcc		adjust_line_above		;nothing to do if it's above del range
   900 FD69 D0 03			bne		adjust_line_below		;skip col adjust if it's below del range
   901 FD6B 95 01			sta		1,x						;within range - move cursor to left mgn
   902 FD6D 60				rts
   903 FD6E			adjust_line_below:
   904 FD6E D6 00			dec		0,x
   905 FD70			adjust_line_above:
   906 FD70 60				rts	
   907 				.endp
