    10 FF24			KeyCodeToATASCIITable:
    11 					;The values in this table must match the Atari OS definitions for
    12 					;compatibility with programs that modify KEYDEF. The special codes
    13 					;are publicly defined in the XL Addendum, of which we currently use a
    14 					;subset:
    15 					;
    16 					;	$80 - invalid key
    17 					;	$81 - inverse video
    18 					;	$82 - caps lock
    19 					;	$83 - shift caps lock
    20 					;	$84 - control caps lock
    21 					;	$85 - EOF (Ctrl+3)
    22
    23 					;lowercase
    24 FF24 6C 6A 3B 80 80 6B + 	dta		$6C, $6A, $3B, $80, $80, $6B, $2B, $2A	;L   J   ;:  F1  F2  K   +\  *^
    25 FF2C 6F 80 70 75 9B 69 + 	dta		$6F, $80, $70, $75, $9B, $69, $2D, $3D	;O       P   U   Ret I   -_  =|
    26 FF34 76 80 63 80 80 62 + 	dta		$76, $80, $63, $80, $80, $62, $78, $7A	;V   Hlp C   F3  F4  B   X   Z
    27 FF3C 34 80 33 36 1B 35 + 	dta		$34, $80, $33, $36, $1B, $35, $32, $31	;4$      3#  6&  Esc 5%  2"  1!
    28 FF44 2C 20 2E 6E 80 6D + 	dta		$2C, $20, $2E, $6E, $80, $6D, $2F, $81	;,[  Spc .]  N       M   /?  Inv
    29 FF4C 72 80 65 79 7F 74 + 	dta		$72, $80, $65, $79, $7F, $74, $77, $71	;R       E   Y   Tab T   W   Q
    30 FF54 39 80 30 37 7E 38 + 	dta		$39, $80, $30, $37, $7E, $38, $3C, $3E	;9(      0)  7'  Bks 8@  <   >
    31 FF5C 66 68 64 80 82 67 + 	dta		$66, $68, $64, $80, $82, $67, $73, $61	;F   H   D       Cps G   S   A
    32 					
    33 					;SHIFT
    34 FF64 4C 4A 3A 80 80 4B + 	dta		$4C, $4A, $3A, $80, $80, $4B, $5C, $5E	;L   J   ;:  F1  F2  K   +\  *^
    35 FF6C 4F 80 50 55 9B 49 + 	dta		$4F, $80, $50, $55, $9B, $49, $5F, $7C	;O       P   U   Ret I   -_  =|
    36 FF74 56 80 43 80 80 42 + 	dta		$56, $80, $43, $80, $80, $42, $58, $5A	;V   Hlp C   F3  F4  B   X   Z
    37 FF7C 24 80 23 26 1B 25 + 	dta		$24, $80, $23, $26, $1B, $25, $22, $21	;4$      3#  6&  Esc 5%  2"  1!
    38 FF84 5B 20 5D 4E 80 4D + 	dta		$5B, $20, $5D, $4E, $80, $4D, $3F, $80	;,[  Spc .]  N       M   /?  Inv
    39 FF8C 52 80 45 59 9F 54 + 	dta		$52, $80, $45, $59, $9F, $54, $57, $51	;R       E   Y   Tab T   W   Q
    40 FF94 28 80 29 27 9C 40 + 	dta		$28, $80, $29, $27, $9C, $40, $7D, $9D	;9(      0)  7'  Bks 8@  <   >
    41 FF9C 46 48 44 80 83 47 + 	dta		$46, $48, $44, $80, $83, $47, $53, $41	;F   H   D       Cps G   S   A
    42 					
    43 					;CTRL
    44 FFA4 0C 0A 7B 80 80 0B + 	dta		$0C, $0A, $7B, $80, $80, $0B, $1E, $1F	;L   J   ;:  F1  F2  K   +\  *^
    45 FFAC 0F 80 10 15 9B 09 + 	dta		$0F, $80, $10, $15, $9B, $09, $1C, $1D	;O       P   U   Ret I   -_  =|
    46 FFB4 16 80 03 80 80 02 + 	dta		$16, $80, $03, $80, $80, $02, $18, $1A	;V   Hlp C   F3  F4  B   X   Z
