   257 ED25				icl		'cassette.s'
Source: /home/ben/src/altirraqt/src/Kernel/source/Shared/cassette.s
     1 				;	Altirra - Atari 800/800XL/5200 emulator
     2 				;	Modular Kernel ROM - Cassette tape support
     3 				;	Copyright (C) 2008-2016 Avery Lee
     4 				;
     5 				;	Copying and distribution of this file, with or without modification,
     6 				;	are permitted in any medium without royalty provided the copyright
     7 				;	notice and this notice are preserved.  This file is offered as-is,
     8 				;	without any warranty.
     9
    10 				;==========================================================================
    11 ED25			.proc CassetteInit
    12 						;Set CBAUDL/CBAUDH to $05CC, the nominal POKEY divisor for 600
    13 						;baud. We don't care about this, but it's documented in the OS
    14 						;Manual.
    15 ED25 A9 CC 8D EE 02 A9 + 		mwa		#$05CC cbaudl
    16 ED2F 60					rts
    17 				.endp
    18
    19 				;==========================================================================
    20 				; Cassette open routine.
    21 				;
    22 				; XL/XE OS behavior notes:
    23 				;	- Attempting to open for none (AUX1=$00) or read/write (AUX1=$0C)
    24 				;	  results in a Not Supported error (146).
    25 				;	- Open for read gives one beep, while open for write gives two beeps.
    26 				;	- Break will break out of the wait.
    27 				;	- Ctrl+3 during the keypress causes an EOF error (!). This is a side
    28 				;	  effect of reusing the keyboard handler.
    29 				;
    30 				; CSOPIV behavior:
    31 				;	- Does NOT set FTYPE (continuous mode flag).
    32 				;	- Sets read mode (WMODE).
    33 				;	- Does NOT require ICAX1Z or ICAX2Z to be set.
    34 				;
    35 = ED43			CassetteOpenRead = CassetteOpen.do_open_read
    36 ED30			.proc CassetteOpen
    37 					;stash continuous mode flag
    38 ED30 A5 2B			lda		icax2z			;!! FIRST TWO BYTES CHECKED BY ARCHON
    39 ED32 85 3E			sta		ftype
    40 					
    41 					;check mode byte for read/write modes
    42 ED34 A2 80			ldx		#$80
    43 ED36 A5 2A			lda		icax1z
    44 ED38 29 0C			and		#$0c
    45 ED3A C9 04			cmp		#$04			;read?
    46 ED3C F0 05			beq		found_read_mode
    47 ED3E C9 08			cmp		#$08			;write?
    48 ED40 F0 03			beq		found_write_mode
    49 					
    50 					;invalid mode -- return not supported
    51 ED42 60				rts
    52 					
    53 ED43			do_open_read:
    54 ED43			found_read_mode:
    55 ED43 A2 00			ldx		#$00
    56 ED45			found_write_mode:
    57 ED45 8E 89 02			stx		wmode
    58
    59 					;set cassette buffer size to 128 bytes and mark it empty
    60 ED48 A9 80			lda		#$80
    61 ED4A 85 3D			sta		bptr
    62 ED4C 8D 8A 02			sta		blim
    63 					
    64 					;clear EOF flag
    65 ED4F 0A				asl
    66 ED50 85 3F			sta		feof
    67 					
    68 					;request one beep for read, or two for write
    69 ED52 2C 89 02			bit		wmode
    70 ED55 10 05			bpl		one_ping_only
    71 					
    72 ED57 06 3D			asl		bptr			;!! - set bptr=0 when starting write
    73
    74 ED59 20 9A EE			jsr		CassetteBell
    75
    76 ED5C			one_ping_only:
    77 ED5C 20 9A EE			jsr		CassetteBell
    78 					
    79 					;wait for a key press
    80 ED5F 20 5E FE			jsr		KeyboardGetByte
    81 ED62 30 20			bmi		aborted
    82
    83 					;need to set up POKEY for writes now to write leader
    84 ED64 2C 89 02			bit		wmode
    85 ED67 10 08			bpl		no_write_init
    86 ED69 A9 FF			lda		#$ff
    87 ED6B 8D 0F 03			sta		casflg
    88 ED6E 20 66 E9			jsr		SIOSendEnable.no_irq_setup
    89 ED71			no_write_init:
    90 					
    91 					;turn on motor (continuous mode or not)
    92 ED71 A9 34			lda		#$34
    93 ED73 8D 02 D3			sta		pactl
    94 					
    95 					;wait for leader (9.6 seconds read, 19.2s write)
    96 ED76 A2 00			ldx		#0
    97 ED78 2C 89 02			bit		wmode
    98 ED7B 30 02 A2 01			smi:ldx	#1
    99 ED7F 20 74 EE			jsr		CassetteWait
   100 					
   101 					;all done
   102 ED82 A0 01			ldy		#1
   103 ED84			aborted:
   104 ED84 60				rts
   105 				.endp
   106
   107 				;==========================================================================
   108 ED85			.proc CassetteClose
   109 					;check if we are in write mode
   110 ED85 AD 89 02			lda		wmode			;!! FIRST TWO BYTES CHECKED BY ARCHON
   111 ED88 10 0A			bpl		notwrite
   112 					
   113 					;check if we have data to write
   114 ED8A A5 3D			lda		bptr
   115 ED8C F0 03			beq		nopartial
   116 					
   117 					;flush partial record ($FA)
   118 ED8E 20 F7 ED			jsr		CassetteFlush
   119 						
   120 ED91			nopartial:
   121 					;write EOF record ($FE)
   122 ED91 20 F7 ED			jsr		CassetteFlush
   123 					
   124 ED94			notwrite:
   125 					;stop the motor
   126 ED94 A9 3C			lda		#$3c
   127 ED96 8D 02 D3			sta		pactl
   128 					
   129 					;kill audio
   130 ED99 A0 00			ldy		#0
   131 ED9B 8C 01 D2			sty		audc1
   132 ED9E 8C 03 D2			sty		audc2
   133 EDA1 8C 07 D2			sty		audc4
   134 					
   135 					;all done
   136 EDA4 C8				iny
   137 EDA5 60				rts
   138 				.endp
   139
   140 				;==========================================================================
   141 				; CassetteReadBlock
   142 				;
   143 				; Read the next block from the C: device, and then fetch the next character
   144 				; from the cassette buffer. Pointed to by RBLOKV.
   145 				;
   146 				; Input:
   147 				;	- FTYPE bit 7 set to stop motor afterward (short IRG), cleared to leave
   148 				;	  motor running.
   149 				;
   150 				; Output:
   151 				;	- Block read to CASBUF.
   152 				;	- FEOF set to $FF if end block found ($FE), otherwise unchanged.
   153 				;	- BPTR set to $01 on success, $00 on EOF
   154 				;	- BLIM set to block length on success, $00 on EOF, otherwise unchanged.
   155 				;	- A = next character read from buffer, if successful.
   156 				;
   157 				; Notes:
   158 				;	- If the motor is not already running, it is started.
   159 				;	- It is possible for this to read another block, if an empty block is
   160 				;	  read ($FA/$00).
   161 				;
   162 				;==========================================================================
   163 				; CassetteGetByte
   164 				;
   165 				; Get Byte handler for C: device.
   166 				;
   167 EDA6			.proc CassetteGetByte
   168 					;check if we have an EOF condition
   169 EDA6 A5 3F			lda		feof			;!! FIRST TWO BYTES CHECKED BY ARCHON
   170 EDA8 D0 17			bne		xit_eof
   171 					
   172 EDAA			fetchbyte:
   173 					;check if we can still fetch a byte
   174 EDAA A6 3D			ldx		bptr
   175 EDAC EC 8A 02			cpx		blim
   176 EDAF F0 13			beq		nobytes
   177
   178 EDB1 BD 00 04			lda		casbuf+3,x
   179 EDB4 E6 3D			inc		bptr
   180 EDB6 A0 01			ldy		#1
   181 EDB8			error:
   182 EDB8 60				rts
   183
   184 EDB9			eof:
   185 					;set EOF flag
   186 EDB9 A0 FF 84 3F			mvy		#$ff feof
   187
   188 					;clear buffer length
   189 EDBD C8				iny
   190 EDBE 8C 8A 02			sty		blim
   191
   192 					;return EOF status
   193 EDC1			xit_eof:
   194 EDC1 A0 88			ldy		#CIOStatEndOfFile
   195 EDC3 60				rts
   196
   197 EDC4			nobytes:
   198 					;fetch more bytes
   199 = EDC4			.def :CassetteReadBlock
   200 EDC4 A2 40			ldx		#$40
   201 EDC6 A0 52			ldy		#'R'
   202
   203 EDC8 20 27 EE			jsr		CassetteDoIO
   204 EDCB 30 EB			bmi		error
   205
   206 					;reset buffer pointer
   207 EDCD A9 00 85 3D			mva		#$00 bptr
   208
   209 					;check for EOF
   210 EDD1 AD FF 03			lda		casbuf+2
   211 EDD4 C9 FE			cmp		#$fe
   212 EDD6 F0 E1			beq		eof
   213
   214 EDD8			init_block:
   215 					;assume full block first (128 bytes)
   216 EDD8 A2 80			ldx		#$80
   217 					
   218 					;check if it actually is one -- officially $fc is complete (128 bytes)
   219 					;and $fa is partial, but all other values are treated as $fc
   220 EDDA C9 FA			cmp		#$fa
   221 EDDC D0 03			bne		full_block
   222
   223 					;set length of partial block
   224 EDDE AE 7F 04			ldx		casbuf+130
   225 					
   226 EDE1			full_block:
   227 					;reset block length and loop back
   228 EDE1 8E 8A 02			stx		blim
   229 EDE4 4C AA ED			jmp		fetchbyte
   230 				.endp
   231
   232 				;==========================================================================
   233 EDE7			.proc CassettePutByte
   234 					;put a byte into the buffer
   235 EDE7 A6 3D			ldx		bptr			;!! FIRST TWO BYTES CHECKED BY ARCHON
   236 EDE9 9D 00 04			sta		casbuf+3,x
   237 					
   238 					;bump and check if it's time to write
   239 EDEC E8				inx
   240 EDED 86 3D			stx		bptr
   241 EDEF EC 8A 02			cpx		blim
   242 EDF2 B0 03			bcs		CassetteFlush
   243 					
   244 					;all done
   245 EDF4 A0 01			ldy		#1
   246 EDF6 60				rts
   247 				.endp
   248
   249 				;==========================================================================
   250 EDF7			.proc CassetteFlush
   251 EDF7 A9 00			lda		#0
   252
   253 					;set control byte based on buffer level
   254 EDF9 A2 FE			ldx		#$fe			;empty -> EOF
   255 EDFB A4 3D			ldy		bptr			;get buffer level
   256 EDFD D0 08			bne		not_empty		;skip not empty
   257 					
   258 					;clear buffer for EOF
   259 EDFF 99 00 04 C8 10 FA		sta:rpl	casbuf+3,y+
   260 EE05 30 0C			bmi		is_empty		;!! - unconditional
   261 					
   262 EE07			not_empty:
   263 EE07 A2 FC			ldx		#$fc			;load complete code
   264 EE09 CC 8A 02			cpy		blim			;check if buffer is full
   265 EE0C B0 05			bcs		is_complete		;skip if so
   266 EE0E A2 FA			ldx		#$fa			;load partial code
   267 EE10 8C 7F 04			sty		casbuf+130		;store level in last byte
   268 EE13			is_complete:
   269 EE13			is_empty:
   270
   271 					;store code
   272 EE13 8E FF 03			stx		casbuf+2
   273 					
   274 					;reset buffer level
   275 EE16 85 3D			sta		bptr
   276 					
   277 					;setup sync bytes
   278 EE18 A9 55			lda		#$55
   279 EE1A 8D FD 03			sta		casbuf
   280 EE1D 8D FE 03			sta		casbuf+1
   281 					
   282 					;issue write request and exit
   283 EE20 A2 80			ldx		#$80
   284 EE22 A0 50			ldy		#'P'
   285 EE24 4C 27 EE			jmp		CassetteDoIO
   286 				.endp
   287
   288 				;==========================================================================
   289 = E4C9			CassetteGetStatus = CIOExitSuccess
   290 = E4CB			CassetteSpecial = CIOExitNotSupported
   291
   292 				;==========================================================================
   293 				; CassetteDoIO
   294 				;
   295 				;	X = DSTATS value
   296 				;	Y = SIO command byte
   297 				;
   298 				; Note that SOUNDR must take effect each time a cassette I/O operation
   299 				; occurs.
   300 				;
   301 EE27			.proc CassetteDoIO
   302 					;start the motor if not already running
   303 EE27 A9 34			lda		#$34
   304 EE29 8D 02 D3			sta		pactl
   305
   306 					;set up SIO read/write
   307 EE2C 8E 03 03			stx		dstats
   308 EE2F 8C 02 03			sty		dcomnd
   309 EE32 A9 FD 8D 04 03 A9 + 	mwa		#casbuf dbuflo
   310 EE3C A9 83 8D 08 03 A9 + 	mwa		#131 dbytlo
   311 EE46 A9 60 8D 00 03		mva		#$60 ddevic
   312 EE4B A9 00 8D 01 03		mva		#0 dunit
   313 EE50 A5 3E 8D 0B 03		mva		ftype daux2
   314
   315 					;do it
   316 EE55 20 59 E4			jsr		siov
   317 					
   318 					;check if we are in continuous mode (again)
   319 EE58 A5 3E			lda		ftype
   320 EE5A 30 0F			bmi		rolling_stop
   321 					
   322 					;not in continuous mode -- wait for post-write tone if writing
   323 EE5C 2C 89 02			bit		wmode
   324 EE5F 10 05			bpl		no_pwt
   325 EE61 A2 06			ldx		#6
   326 EE63 20 74 EE			jsr		CassetteWait
   327 EE66			no_pwt:
   328 					
   329 					;stop the motor
   330 EE66 A9 3C			lda		#$3c
   331 EE68 8D 02 D3			sta		pactl
   332 					
   333 EE6B			rolling_stop:
   334 EE6B A4 30			ldy		status
   335 EE6D 60				rts
   336 				.endp
   337
   338 				;==========================================================================
   339 				;Entry:
   340 				;	X = delay type
   341 				;
   342 = EE74			CassetteWait = CassetteWaitLongShortCheck.normal_entry
   343 EE6E			.proc CassetteWaitLongShortCheck
   344 EE6E 2C 0B 03			bit		daux2
   345 EE71 10 01 E8			spl:inx
   346 EE74			normal_entry:
   347 EE74 20 27 E9			jsr		SIOSetTimeoutVector
   348 EE77 BC 8C EE			ldy		wait_table_lo,x
   349 EE7A BD 93 EE			lda		wait_table_hi,x
   350 EE7D AA				tax
   351 EE7E A9 01			lda		#1
   352 EE80 8D 17 03			sta		timflg
   353 EE83 20 5B C1			jsr		VBISetVector
   354 EE86 AD 17 03 D0 FB		lda:rne	timflg
   355 EE8B 60				rts
   356 					
   357 EE8C			wait_table_lo:
   358 EE8C 80				dta		<$0480			;$00 - write file leader (19.2 seconds NTSC)
   359 EE8D 40				dta		<$0240			;$01 - read leader delay (9.6 seconds NTSC)
   360 EE8E B4				dta		<$00B4			;$02 - long pre-record write tone (3.0s NTSC)
   361 EE8F 0F				dta		<$000F			;$03 - short pre-record write tone (0.25s NTSC)
   362 EE90 78				dta		<$0078			;$04 - long read IRG (2.0s NTSC)
   363 EE91 0A				dta		<$000A			;$05 - short read IRG (0.16s NTSC)
   364 EE92 3C				dta		<$003C			;$06 - post record gap (1s NTSC)
   365
   366 EE93			wait_table_hi:
   367 EE93 04				dta		>$0480			;$00 - write file leader (19.2 seconds NTSC)
   368 EE94 02				dta		>$0240			;$01 - read leader delay (9.6 seconds NTSC)
   369 EE95 00				dta		>$00B4			;$02 - long pre-record write tone (3.0s NTSC)
   370 EE96 00				dta		>$000F			;$03 - short pre-record write tone (0.25s NTSC)
   371 EE97 00				dta		>$0078			;$04 - long read IRG (2.0s NTSC)
   372 EE98 00				dta		>$000A			;$05 - short read IRG (0.16s NTSC)
   373 EE99 00				dta		>$003C			;$06 - post record gap (1s NTSC)
   374 				.endp
