     9
    10 EEB7			.nowarn .proc _InitReset
    11 EEB7			run_diag:
    12 						; start diagnostic cartridge
    13 EEB7 6C FE BF				jmp		($bffe)
    14
    15 = EEBA			.def :InitReset
    16 						;mask interrupts and initialize CPU
    17 EEBA 78					sei
    18 EEBB D8					cld
    19 EEBC A2 FF				ldx		#$ff
    20 EEBE 9A					txs
    21 					
    22 						;wait for everything to stabilize (0.1s)
    23 EEBF A0 8C				ldy		#140
    24 EEC1 E8					inx					;!! x=0
    25 EEC2			stabilize_loop:
    26 EEC2 CA D0 FD				dex:rne
    27 EEC5 88					dey
    28 EEC6 D0 FA				bne		stabilize_loop
    29 					
    30 						.if _KERNEL_XLXE
    31 						;check if we successfully completed cold start
    32 						;
    33 						;!! This is required to work on Atari800WinPlus, which doesn't clear memory on
    34 						;   cold reset!
    35 EEC8 AD 44 02				lda		coldst
    36 EECB D0 10				bne		cold_boot
    37 					
    38 						;check for warmstart signature (XL/XE)
    39 EECD A2 02				ldx		#2
    40 EECF			warm_check:
    41 EECF BD 3D 03				lda		pupbt1,x
    42 EED2 DD 48 F0				cmp		InitBootSignature,x
    43 EED5 D0 06				bne		cold_boot
    44 EED7 CA					dex
    45 EED8 10 F5				bpl		warm_check
    46 					
    47 EEDA 4C 56 EF				jmp		InitWarmStart
    48 						.endif
    49
    50 = EEDD			.def :InitColdStart
    51 EEDD				cold_boot:
    52 						; 1. initialize CPU
    53 EEDD 78					sei
    54 EEDE D8					cld
    55 EEDF A2 FF				ldx		#$ff
    56 EEE1 9A					txs
    57 					
    58 						; 2. clear warmstart flag
    59 EEE2 E8					inx
    60 EEE3 86 08				stx		warmst
    61 					
    62 						; 3. test for diagnostic cartridge
    63 EEE5 AD FC BF				lda		$bffc
    64 EEE8 D0 17				bne		not_diag
    65 EEEA A2 FF				ldx		#$ff
    66 EEEC EC FF BF				cpx		$bfff			;prevent diagnostic cart from activating if addr is $FFxx
    67 EEEF F0 10				beq		not_diag
    68 EEF1 8E FC BF				stx		$bffc
    69 EEF4 CD FC BF				cmp		$bffc
    70 EEF7 8D FC BF				sta		$bffc
    71 EEFA D0 05				bne		not_diag
    72 					
    73 						; is it enabled?
    74 EEFC 2C FD BF				bit		$bffd
    75 EEFF 30 B6				bmi		run_diag
    76 						
    77 EF01			not_diag:
    78 					
    79 EF01 20 87 EF				jsr		InitHardwareReset
    80
    81 						;check for OPTION and enable BASIC (note that we do NOT set BASICF just yet)
    82 EF04 A9 04				lda		#4
    83 EF06 2C 1F D0				bit		consol
    84 EF09 F0 12				beq		no_basic
    85
    86 EF0B A2 FD				ldx		#$fd
    87 					
    88 						;check for keyboard present + SELECT or no keyboard + no SELECT and enable game if so
    89 EF0D AD 12 D0				lda		trig2		;check keyboard present (1 = present)
    90 EF10 0A					asl
    91 EF11 4D 1F D0				eor		consol		;XOR against select (0 = pressed)
    92 EF14 29 02				and		#$02	
    93 EF16 F0 02 A2 BF				seq:ldx	#$bf
    94 EF1A 8E 01 D3				stx		portb		;enable GAME or BASIC
    95
    96 EF1D			no_basic:
    97 						; 4. measure memory -> tramsz
    98 EF1D 20 B6 EF				jsr		InitMemory
    99 					
   100 						; 6. clear memory from $0008 up to [tramsz,0]
   101 EF20 A6 06				ldx		tramsz
   102 EF22 A0 08				ldy		#8
   103 EF24 A9 00 85 66				mva		#0 a1
   104 EF28 85 67				sta		a1+1
   105 EF2A			clearloop:
   106 EF2A 91 66 C8 D0 FB			sta:rne	(a1),y+
   107 EF2F E6 67				inc		a1+1
   108 EF31 CA					dex
   109 EF32 D0 F6				bne		clearloop
   110 					
   111 						;Blip the self test ROM for a second -- this is one way that Altirra detects
   112 						;that Option has been used by the OS. The XL/XE OS does this as part of its
   113 						;ROM checksum routine (which we don't bother with).
   114 EF34 AE 01 D3				ldx		portb
   115 EF37 8A					txa
   116 EF38 29 7F				and		#$7f
   117 EF3A 8D 01 D3				sta		portb
   118 EF3D 8E 01 D3				stx		portb
   119
   120 						; 7. set dosvec to blackboard routine
   121 				.if _KERNEL_USE_BOOT_SCREEN
   122 EF40 A9 9B 85 0A A9 E4 + 		mwa		#SelfTestEntry dosvec
   123 				.else
   124 						mwa		#Blackboard dosvec
   125 				.endif
   126 					
   127 						; 8. set coldstart flag
   128 EF48 CE 44 02				dec		coldst		;!! coldst=0 from clear loop above, now $ff
   129 					
   130 				.if _KERNEL_XLXE
   131 						; set BASIC flag
   132 EF4B AD 01 D3				lda		portb
   133 EF4E 29 02				and		#$02
   134 EF50 8D F8 03				sta		basicf
   135 				.endif
   136
   137 						; 9. set screen margins
   138 						; 10. initialize RAM vectors
   139 						; 11. set misc database values
   140 						; 12. enable IRQ interrupts
   141 						; 13. initialize device table
   142 						; 14. initialize cartridges
   143 						; 15. use IOCB #0 to open screen editor (E)
   144 						; 16. wait for VBLANK so screen is initialized
   145 						; 17. do cassette boot, if it was requested
   146 						; 18. do disk boot
   147 						; 19. reset coldstart flag
   148 						; 20. run cartridges or blackboard
   149 EF53 4C 4E F0				jmp		InitEnvironment
   150 				.endp
   151
   152 				;==============================================================================
   153 EF56			.proc InitWarmStart
   154 						; A. initialize CPU
   155 						; Undocumented: Check if cold start completed (COLDST=0); if not, force
   156 						; a cold start. ACTris 2.1 relies on this since its boot doesn't reset
   157 						; COLDST.
   158 						;
   159 EF56 78					sei								;!! FIRST TWO BYTES CHECKED BY ARCHON
   160 EF57 AD 44 02				lda		coldst
   161 EF5A D0 81				bne		InitColdStart
   162 EF5C D8					cld
   163 EF5D A2 FF				ldx		#$ff
   164 EF5F 9A					txs
   165
   166 						; B. set warmstart flag
   167 EF60 86 08				stx		warmst
   168 					
   169 						; reinitialize hardware without doing a full clear
   170 EF62 20 87 EF				jsr		InitHardwareReset
   171 					
   172 						.if _KERNEL_XLXE
   173 						; reinitialize BASIC
   174 EF65 AD F8 03				lda		basicf
   175 EF68 D0 05 A9 FD 8D 01 + 		sne:mva #$fd portb
   176 						.endif
   177 					
   178 						; C. check for diag, measure memory, clear hw registers
   179 EF6F 20 B6 EF				jsr		InitMemory
   180 					
   181 						; D. zero 0010-007F and 0200-03EC (must not clear BASICF).
   182 EF72 A2 60				ldx		#$60
   183 EF74 A9 00				lda		#0
   184 EF76 95 0F CA D0 FB			sta:rne	$0f,x-
   185 					
   186 EF7B			dbclear:
   187 EF7B 9D 00 02				sta		$0200,x
   188 EF7E 9D ED 02				sta		$02ed,x
   189 EF81 E8					inx
   190 EF82 D0 F7				bne		dbclear
   191 					
   192 						; E. steps 9-16 above
   193 						; F. if cassette boot was successful on cold boot, execute cassette init
   194 						; G. if disk boot was successful on cold boot, execute disk init
   195 						; H. same as steps 19 and 20
   196 EF84 4C 4E F0				jmp		InitEnvironment
   197 				.endp
   198
   199 				;==============================================================================
   200 EF87			.proc InitHardwareReset
   201 						; clear all hardware registers
   202 EF87 A2 00				ldx		#0
   203 EF89			hwclear:
   204 EF89 9E 00 D0				stz		$d000,x
   205 EF8C 9E 00 D2				stz		$d200,x
   206 EF8F 9E 00 D4				stz		$d400,x
   207 EF92 E8					inx
   208 EF93 D0 F4				bne		hwclear
   209
   210 						;initialize PIA
   211 EF95 A9 3C				lda		#$3c
   212 EF97 A0 38				ldy		#$38
   213
   214 EF99 8C 02 D3				sty		pactl		;switch to DDRA
   215 EF9C 9C 00 D3				stz		porta		;portA -> input
   216 EF9F 8D 02 D3				sta		pactl		;switch to IORA
   217 EFA2 9C 00 D3				stz		porta		;portA -> $00
   218 EFA5 8D 03 D3				sta		pbctl		;switch to IORB
   219 EFA8 CA					dex
   220 EFA9 8E 01 D3				stx		portb		;portB -> $FF
   221 EFAC 8C 03 D3				sty		pbctl		;switch to DDRB
   222 EFAF 8E 01 D3				stx		portb		;portB -> all output
   223 EFB2 8D 03 D3				sta		pbctl		;switch to IORB
   224 EFB5 60					rts
   225 				.endp
