  1370 				;==========================================================================
  1371 				; Clear the screen.
  1372 				;
  1373 				; Used:
  1374 				;	ADRESS
  1375 				;	TOADR
  1376 				;
  1377 				; Quirks:
  1378 				;	Clears the split-screen text area even if the main screen (S:) receives
  1379 				;	the clear. The In-Store Demonstration Cart depends on this. The cursor
  1380 				;	state of the split screen is NOT reset, so if the cursor was over a
  1381 				;	non-blank character, that character will be restored when the cursor
  1382 				;	moves.
  1383 				;
  1384 				;	The logical line map is always reset.
  1385 				;
  1386 F849			.proc ScreenClear
  1387 					;first, set up for clearing the split-screen window (4*40 bytes main)
  1388 F849 A0 04			ldy		#4
  1389 					
  1390 					;check if we are in the split screen text window
  1391 F84B A6 7B			ldx		swpflg
  1392 F84D D0 08			bne		is_text_window
  1393 					
  1394 					;nope, it's the main screen... compute size
  1395 F84F A4 57			ldy		dindex
  1396 F851 BE 99 F2			ldx		ScreenHeightShifts,y
  1397 F854 BC A9 F2			ldy		ScreenHeights,x
  1398 F857			is_text_window:
  1399 F857 20 82 F9			jsr		ScreenComputeRangeSize
  1400
  1401 					;add 160 bytes to size if not GR.0 -- important to avoid clearing
  1402 					;beyond GR.0 screen (the font breaks in BIKERDAV.BAS otherwise!)
  1403 F85A 18				clc
  1404 F85B A6 57			ldx		dindex
  1405 F85D F0 02			beq		is_gr0
  1406 F85F 69 A0			adc		#160
  1407 F861			is_gr0:
  1408 F861 A8				tay
  1409 F862 A5 65			lda		adress+1
  1410 F864 69 00			adc		#0
  1411
  1412 F866 AA				tax
  1413 F867 65 59			adc		savmsc+1
  1414 F869 85 67			sta		toadr+1
  1415 F86B A5 58 85 66			mva		savmsc toadr
  1416
  1417 					;As it turns out, there are no cases where the main screen
  1418 					;is an exact number of pages... so we can simply plow into
  1419 					;the clear loop.
  1420 F86F A9 00			lda		#0
  1421 F871			loop:
  1422 F871 88				dey
  1423 F872 91 66			sta		(toadr),y
  1424 F874 D0 FB			bne		loop
  1425 F876 C6 67			dec		toadr+1
  1426 F878 CA				dex
  1427 F879 10 F6			bpl		loop
  1428
  1429 					;reset coordinates and cursor (we're going to wipe the cursor)
  1430 F87B 85 56			sta		colcrs+1
  1431 F87D 85 54			sta		rowcrs
  1432 F87F 85 5D			sta		oldchr
  1433 					
  1434 					;always reset the logical line map
  1435 F881 A6 57			ldx		dindex
  1436 F883 D0 02			bne		is_graphic_screen
  1437 F885 A5 52			lda		lmargn
  1438 F887			is_graphic_screen:
  1439 F887 85 55			sta		colcrs
  1440
  1441 					;always reset the logical line map and exit
  1442 F889 4C E8 FD			jmp		ScreenResetLogicalLineMap
  1443 				.endp
  1444
  1445 				;==========================================================================
  1446 				; Insert a physical line at the current location.
  1447 				;
  1448 				; Entry:
  1449 				;	ROWCRS = row before which to insert new line
  1450 				;	C = 0 if physical line only, C = 1 if should start new logical line
  1451 				;
  1452 				; Modified:
  1453 				;	HOLD1, ADRESS
  1454 				;
  1455 = F88D			ScreenInsertLine = ScreenInsertPhysLine.use_c
  1456 F88C			.proc ScreenInsertPhysLine
  1457 F88C 18				clc
  1458 F88D			use_c:
  1459 					;save new logline flag
  1460 F88D 08				php
  1461 					
  1462 					;compute addresses
  1463 F88E AC BF 02			ldy		botscr
  1464 F891 88				dey
  1465 F892 20 78 F9			jsr		ScreenComputeToAddrX0
  1466 F895 20 C2 FD			jsr		EditorNextLineAddr
  1467 					
  1468 					;copy lines
  1469 F898 AE BF 02			ldx		botscr
  1470 F89B D0 09			bne		line_loop_start
  1471 F89D			line_loop:
  1472 F89D A0 27			ldy		#39
  1473 F89F			char_loop:
  1474 F89F B1 68			lda		(frmadr),y
  1475 F8A1 91 66			sta		(toadr),y
  1476 F8A3 88				dey
  1477 F8A4 10 F9			bpl		char_loop
  1478 F8A6			line_loop_start:	
  1479 F8A6 A5 68			lda		frmadr
  1480 F8A8 85 66			sta		toadr
  1481 F8AA 38				sec
  1482 F8AB E9 28			sbc		#40
  1483 F8AD 85 68			sta		frmadr
  1484 F8AF A5 69			lda		frmadr+1
  1485 F8B1 85 67			sta		toadr+1
  1486 F8B3 E9 00			sbc		#0
  1487 F8B5 85 69			sta		frmadr+1
  1488 					
  1489 F8B7 CA				dex
  1490 F8B8 E4 54			cpx		rowcrs
  1491 F8BA D0 E1			bne		line_loop
  1492 					
  1493 F8BC			no_copy:
  1494 					;clear the current line
  1495 F8BC A0 27			ldy		#39
  1496 F8BE A9 00			lda		#0
  1497 F8C0			clear_loop:
  1498 F8C0 91 66			sta		(toadr),y
  1499 F8C2 88				dey
  1500 F8C3 10 FB			bpl		clear_loop
  1501 					
  1502 					;insert bit into logical line mask
  1503 F8C5 20 71 FD			jsr		EditorGetCurLogicalLineInfo
  1504 					
  1505 F8C8 28				plp
  1506 F8C9 B0 02 A9 00			scs:lda	#0
  1507 F8CD 85 51			sta		hold1
  1508
  1509 F8CF A9 00			lda		#0
  1510 F8D1 38				sec
  1511 F8D2 FD C1 E4			sbc		ReversedBitMasks,x			;-bit
  1512 F8D5 0A				asl
  1513 F8D6 39 B2 02			and		logmap,y
  1514 F8D9 18				clc
  1515 F8DA 79 B2 02			adc		logmap,y
  1516 F8DD 6A				ror
  1517 F8DE 05 51			ora		hold1
  1518 F8E0 99 B2 02			sta		logmap,y
  1519 					
  1520 F8E3 88				dey
  1521 F8E4 10 03 6E B3 02		spl:ror	logmap+1
  1522 F8E9 88				dey
  1523 F8EA 10 03 6E B4 02		spl:ror	logmap+2
  1524 F8EF 60				rts
  1525 				.endp
