    10 				;==========================================================================
    11 				; Disk boot routine.
    12 				;
    13 				; Exit:
    14 				;	DBUFLO/DBUFHI = $0400	(Undoc; required by Ankh and the 1.atr SMB demo)
    15 				;	Last sector in $0400	(Undoc; required by Ankh)
    16 				;
    17 F13B			.proc BootDisk
    18 					;issue a status request first to see if the disk is active; if this
    19 					;doesn't come back, don't bother trying to read
    20 F13B A9 53			lda		#$53
    21 F13D 8D 02 03			sta		dcomnd
    22 F140 A2 01			ldx		#1
    23 F142 8E 01 03			stx		dunit
    24 F145 20 53 E4			jsr		dskinv
    25 F148 10 01			bpl		status_ok
    26 F14A			xit:
    27 F14A 60				rts
    28
    29 F14B			status_ok:
    30 				.if _KERNEL_USE_BOOT_SCREEN
    31 F14B 20 6E F1			jsr		try_read_sector1
    32 F14E 10 15			bpl		try_boot_loop_postsector1
    33 F150			enter_exit_boot_screen:
    34 F150 AD 01 D3			lda		portb
    35 F153 49 80			eor		#$80
    36 F155 8D 01 D3			sta		portb
    37 F158 30 06			bmi		try_boot_loop
    38 F15A 20 02 50			jsr		BootScreen.boot_entry
    39 F15D 4C 50 F1			jmp		enter_exit_boot_screen
    40
    41 F160			try_boot_loop:
    42 F160 20 6E F1			jsr		try_read_sector1
    43 F163 30 03			smi
    44 F165			try_boot_loop_postsector1:
    45 F165 20 8A F1			jsr		try_boot
    46 F168 20 38 F2			jsr		BootShowError
    47 F16B 4C 60 F1			jmp		try_boot_loop
    48
    49 				.else
    50 				try_boot_loop:
    51 				.endif
    52
    53 F16E			try_read_sector1:
    54 					;read first sector to $0400
    55 F16E A2 01			ldx		#1
    56 F170 8E 01 03			stx		dunit
    57 F173 8E 0A 03			stx		daux1
    58 F176 CA				dex
    59 F177 8E 04 03			stx		dbuflo
    60 F17A 8E 0B 03			stx		daux2
    61 F17D A9 52 8D 02 03		mva		#$52	dcomnd
    62 F182 A9 04 8D 05 03		mva		#$04	dbufhi
    63
    64 				.if _KERNEL_USE_BOOT_SCREEN
    65 F187 4C 53 E4			jmp		dskinv
    66 				.else
    67 					jsr		dskinv
    68 					bmi		fail
    69 				.endif
    70
    71 F18A			try_boot:
    72 F18A A2 0C			ldx		#dosini
    73 F18C 20 F4 F1			jsr		BootInitHeaders
    74
    75 					;load remaining sectors
    76 F18F			sectorloop:
    77 					;copy sector from $0400 to destination (required by Ankh; see above)
    78 					;bump destination address for next sector copy
    79 F18F 20 23 F2			jsr		BootCopyBlock
    80
    81 					;exit if this was the last sector (note that 0 means to load 256 sectors!)
    82 F192 CE 41 02			dec		dbsect
    83 F195 F0 10			beq		loaddone
    84 					
    85 					;increment sector (yes, this can overflow to 256)
    86 F197 EE 0A 03 D0 03 EE + 	inw		daux1
    87
    88 					;read next sector
    89 F19F 20 53 E4			jsr		dskinv
    90 					
    91 					;keep going if we succeeded
    92 F1A2 10 EB			bpl		sectorloop
    93 					
    94 					;read failed
    95 F1A4			fail:
    96 				.if _KERNEL_USE_BOOT_SCREEN
    97 F1A4 4C 38 F2			jmp		BootShowError
    98 				.else
    99 					jsr		BootShowError
   100 					jmp		try_boot_loop
   101 				.endif
   102
   103 F1A7			loaddone:
   104 F1A7 20 11 F2			jsr		BootRunLoader
   105 F1AA B0 F8			bcs		fail
   106 					
   107 					;Diskette Boot Process, step 7 (p.161 of the OS Manual) is misleading. It
   108 					;says that DOSVEC is invoked after DOSINI, but actually that should NOT
   109 					;happen here -- it happens AFTER cartridges have had a chance to run.
   110 					;This is necessary for BASIC to gain control before DOS goes to load
   111 					;DUP.SYS.
   112 F1AC 20 34 F1			jsr		InitDiskBoot
   113
   114 					;Must not occur until after init routine is called -- SpartaDOS 3.2 does
   115 					;an INC on this flag and never exits.
   116 F1AF A9 01 85 09			mva		#1 boot?
   117 				.if _KERNEL_USE_BOOT_SCREEN
   118 F1B3 68				pla
   119 F1B4 68				pla
   120 				.endif
   121 F1B5 60				rts
   122 				.endp
   123
   124
   125 				;============================================================================
   126
   127 F1B6			.proc BootCassette
   128 					;set continuous mode -- must do this as CSOPIV doesn't
   129 F1B6 A9 80			lda		#$80
   130 F1B8 85 3E			sta		ftype
   131
   132 					;open cassette device
   133 F1BA 20 7D E4			jsr		csopiv
   134 					
   135 					;read first block
   136 F1BD 20 7A E4			jsr		rblokv
   137 F1C0 30 13			bmi		load_failure
   138 					
   139 F1C2 A2 02			ldx		#casini
   140 F1C4 20 F4 F1			jsr		BootInitHeaders
   141 					
   142 F1C7			block_loop:
   143 					;copy 128 bytes from CASBUF+3 ($0400) to destination
   144 					;update destination pointer
   145 F1C7 20 23 F2			jsr		BootCopyBlock
   146
   147 					;Read next block.
   148 					;
   149 					;We always need to do one more to catch the EOF block, which is
   150 					;required by STDBLOAD2. It does not matter whether this last read
   151 					;succeeds -- timeout, checksum error, not EOF, doesn't matter to
   152 					;the stock OS.
   153 F1CA 20 7A E4			jsr		rblokv
   154 					
   155 F1CD CE 41 02			dec		dbsect
   156 F1D0 F0 0E			beq		load_done
   157
   158 F1D2 98				tya
   159 F1D3 10 F2			bpl		block_loop
   160
   161 F1D5			load_failure:
   162 F1D5 A9 00			lda		#0
   163 F1D7 8D E9 03			sta		ckey
   164 F1DA 20 74 ED			jsr		CassetteClose
   165 F1DD 4C 38 F2			jmp		BootShowError
   166
   167 F1E0			load_done:
   168 					;run loader
   169 F1E0 20 11 F2			jsr		BootRunLoader
   170 F1E3 B0 F0			bcs		load_failure
   171
   172 					;run cassette init routine
   173 F1E5 20 37 F1			jsr		InitCassetteBoot
   174
   175 					;clear cassette boot key flag
   176 F1E8 A9 00			lda		#0
   177 F1EA 8D E9 03			sta		ckey
   178
   179 					;set cassette boot flag
   180 F1ED A9 02 85 09			mva		#2 boot?
   181 					
   182 					;run application
   183 F1F1 6C 0A 00			jmp		(dosvec)
   184 				.endp
   185
   186 				;============================================================================
   187 F1F4			.proc BootInitHeaders
   188 					;copy the first four bytes to DFLAGS, DBSECT, and BOOTAD
   189 F1F4 A0 FC			ldy		#$fc
   190 F1F6 B9 04 03 99 44 01 + 	mva:rne	$0400-$fc,y dflags-$fc,y+
   191 					
   192 					;copy boot address in BOOTAD to BUFADR
   193 F1FF 85 16			sta		bufadr+1
   194 F201 AD 42 02			lda		bootad
   195 F204 85 15			sta		bufadr
   196 					
   197 					;copy init vector
   198 F206 AD 04 04 95 00 AD + 	mwa		$0404 0,x
   199 F210 60				rts
   200 				.endp
   201
   202 				;============================================================================
   203 F211			.proc BootRunLoader
   204 					;Some tape versions of River Raid is sensitive to both the A
   205 					;register value on boot and RAMLO, for some reason. For compatibility,
   206 					;we need to return the high byte in A and RAMLO needs to contain the
   207 					;run address.
   208
   209 F211 AD 42 02			lda		bootad
   210 F214 18 69 06			add		#$06			;loader is at load address + 6
   211 F217 85 04			sta		ramlo
   212 F219 AD 43 02			lda		bootad+1
   213 F21C 69 00			adc		#0
   214 F21E 85 05			sta		ramlo+1
   215 F220 6C 04 00			jmp		(ramlo)
   216 				.endp
   217
   218 				;============================================================================
   219 F223			.proc BootCopyBlock
   220 F223 A0 7F			ldy		#$7f
   221 F225 B9 00 04 91 15 88 + 	mva:rpl	$0400,y (bufadr),y-
   222
   223 F22D A5 15			lda		bufadr
   224 F22F 49 80			eor		#$80
   225 F231 85 15			sta		bufadr
   226 F233 30 02 E6 16			smi:inc	bufadr+1
   227 F237 60				rts
   228 				.endp
   229
   230 				;============================================================================
   231
   232 F238			.proc BootShowError
   233 F238 A2 F5			ldx		#$f5
   234 F23A			msgloop:
   235 F23A 8A				txa
   236 F23B 48				pha
   237 F23C BD 53 F1			lda		errormsg-$f5,x
   238 F23F 20 B5 FA			jsr		EditorPutByte
   239 F242 68				pla
   240 F243 AA				tax
   241 F244 E8				inx
   242 F245 D0 F3			bne		msgloop
   243 F247 60				rts
   244 					
   245 F248			errormsg:
   246 F248 42 4F 4F 54 20 45 + 	dta		'BOOT ERROR',$9B
   247 				.endp
