   254 EC93				icl		'printer.s'
Source: /home/ben/src/altirraqt/src/Kernel/source/Shared/printer.s
     1 				;	Altirra - Atari 800/800XL/5200 emulator
     2 				;	Modular Kernel ROM - Printer Handler
     3 				;	Copyright (C) 2008-2016 Avery Lee
     4 				;
     5 				;	Copying and distribution of this file, with or without modification,
     6 				;	are permitted in any medium without royalty provided the copyright
     7 				;	notice and this notice are preserved.  This file is offered as-is,
     8 				;	without any warranty.
     9
    10 				;==========================================================================
    11 EC93			.proc PrinterInit
    12 					;set printer timeout to default
    13 EC93 A9 1E 8D 14 03		mva		#30 ptimot
    14 EC98 60				rts
    15 				.endp
    16
    17 				;==========================================================================
    18 				; Printer close
    19 				;
    20 				; Flushes any remaining bytes left in the printer buffer to the printer,
    21 				; if any.
    22 				;
    23 				; Compatibility quirks:
    24 				;	- OS-B fills with $20, while the XL/XE OS fills with $9B.
    25 				;	- If the buffer was exactly filled without an EOL and is thus empty at
    26 				;	  the time of close, no additional EOL is sent. This is arguably a
    27 				;	  bug as it can cause line splicing with the 1025.
    28 				;
    29 = ECBB			PrinterClose = _PrinterPutByte.close_entry
    30
    31 				;==========================================================================
    32 				; Printer put byte
    33 				;
    34 				; Writes a byte into the printer buffer. If the printer buffer is full
    35 				; or an EOL was added, the printer buffer is sent to the printer.
    36 				;
    37 				; Compatibility quirks:
    38 				;	- Must be usable without prior Open, or Monkey Wrench II breaks.
    39 				;	- On an EOL, the remainder of the buffer is padded with $20 before
    40 				;	  being sent to the printer, on both OS-B and the XL/XE OS.
    41 				;	- ICAX2Z can be changed on the fly to switch between normal and
    42 				;	  sideways orientation, as it is checked on each put byte.
    43 				;	- If the buffer contains more than 29 characters and the mode is
    44 				;	  switched dynamically from Sideways to Normal mode, OS-B and XLOSv2
    45 				;	  will miss the stop and overrun the printer buffer. On XLOSv2,
    46 				;	  this generally results in a GINTLK hang. We handle this somewhat
    47 				;	  more gracefully but still treat it as a Don't Do That(tm).
    48 				;	- ICAX2Z=0 must be interpreted as Normal, because BASIC uses it
    49 				;	  with LPRINT, and the 1025 will NAK any other orientation.
    50 				;
    51 = EC99			PrinterPutByte = _PrinterPutByte.put_entry
    52
    53 EC99			.proc _PrinterPutByte
    54 EC99			put_entry:
    55 					;Check for sideways mode and compute line size - we must do this on every
    56 					;write as Monkey Wrench II depends on being able to call P: put byte
    57 					;without an open (still broken program behavior, just less crashy now).
    58 EC99 A2 28			ldx		#40
    59 EC9B A4 2B			ldy		icax2z
    60 EC9D C0 53			cpy		#$53
    61 EC9F D0 02 A2 1D			sne:ldx	#29
    62 ECA3 8E DF 02			stx		pbufsz
    63
    64 					;increment and load buffer index
    65 ECA6 EE DE 02			inc		pbpnt
    66 ECA9 AE DE 02			ldx		pbpnt
    67
    68 					;put char
    69 ECAC 9D BF 03			sta		prnbuf-1,x
    70 					
    71 					;if we wrote an EOL, force flush now
    72 ECAF C9 9B			cmp		#$9b
    73 ECB1 F0 10			beq		fill_spaces
    74 							
    75 					;check for end of line and flush if so
    76 ECB3 EC DF 02			cpx		pbufsz
    77 ECB6 B0 16			bcs		fill_done
    78
    79 					;exit success
    80 ECB8			xit:
    81 ECB8 A0 01			ldy		#1
    82 ECBA 60				rts
    83 					
    84 ECBB			close_entry:
    85 					;check if we have anything in the buffer
    86 ECBB AE DE 02			ldx		pbpnt
    87 					
    88 					;exit if buffer is empty
    89 ECBE F0 F8			beq		xit
    90 					
    91 					;If we're building for 800 target, emulate OS-B and fill with $20.
    92 					;If we're building for XL/XE target, emulate XLOSv2 and fill with $9B.
    93 				.if _KERNEL_XLXE
    94 ECC0 A9 9B			lda		#$9b
    95 ECC2 2C				dta		{bit $0100}
    96 				.endif
    97
    98 					;fill remainder of buffer with spaces
    99 ECC3			fill_spaces:
   100 ECC3 A9 20			lda		#$20
   101 ECC5			fill_loop:
   102 ECC5 9D C0 03			sta		prnbuf,x
   103 ECC8 E8				inx
   104 ECC9 EC DF 02			cpx		pbufsz
   105 ECCC 90 F7			bcc		fill_loop
   106 ECCE			fill_done:
   107 					
   108 					;send line to printer
   109 ECCE A0 0A			ldy		#10
   110 ECD0 B9 F3 EC 99 FF 02 + 	mva:rne	iocbdat-1,y ddevic-1,y-
   111
   112 					;empty buffer
   113 ECD9 8C DE 02			sty		pbpnt
   114
   115 					;set line length
   116 ECDC 8E 08 03			stx		dbytlo
   117
   118 					;Compute AUX1 byte from length.
   119 					;
   120 					;Note that the OS manual is wrong -- this byte needs to go into AUX1 and
   121 					;not AUX2 as the manual says.
   122 					;
   123 					;	normal   (40): 00101000 -> 01001110 ($4E 'N')
   124 					;	sideways (29): 00011101 -> 01010011 ($53 'S')
   125 ECDF BD D6 EC			lda		mode_s-29,x
   126 ECE2 8D 0A 03			sta		daux1			;set AUX1 to indicate width to device
   127 					
   128 					;send to printer and exit
   129 ECE5			do_io:
   130 				.if _KERNEL_XLXE
   131 ECE5 A5 21 8D 01 03		mva		icdnoz dunit
   132 				.endif
   133 ECEA AD 14 03 8D 06 03		mva		ptimot dtimlo
   134 ECF0 4C 59 E4			jmp		siov
   135
   136 ECF3			mode_s:
   137 ECF3 53				dta		'S'
   138 ECF4			iocbdat:
   139 ECF4 40				dta		$40			;device
   140 ECF5 01				dta		$01			;unit
   141 ECF6 57				dta		$57			;command 'W'
   142 ECF7 80				dta		$80			;input/output mode (write)
   143 ECF8 C0 03			dta		a(prnbuf)	;buffer address
   144 ECFA 00 00			dta		a(0)		;timeout
   145 ECFC 00 00			dta		a(0)		;buffer length
   146 ECFE			mode_n:
   147 ECFE 4E				dta		'N'
   148
   149 				.if mode_n-mode_s != 11
   150 				.error "N/S lookup misaligned"
   151 				.endif
   152 				.endp
   153
   154 				;==============================================================================
   155 				;==========================================================================
   156 ECFF			.proc PrinterOpen
   157 ECFF A9 00			lda		#0
   158 ED01 8D DE 02			sta		pbpnt
   159
   160 					;fall through to status to update printer timeout
   161
   162 = ED04			.def :PrinterGetStatus
   163 					;setup parameter block
   164 ED04 A2 09			ldx		#9
   165 ED06 BD 1B ED 9D 00 03 + 	mva:rpl	iocbdat,x ddevic,x-
   166
   167 					;issue status call
   168 ED0F 20 E5 EC			jsr		_PrinterPutByte.do_io
   169 ED12 30 06			bmi		error
   170 					
   171 					;update timeout
   172 ED14 AD EC 02 8D 14 03		mva		dvstat+2 ptimot
   173 					
   174 ED1A			error:
   175 ED1A 60				rts
   176
   177 ED1B			iocbdat:
   178 ED1B 40				dta		$40			;device
   179 ED1C 01				dta		$01			;unit
   180 ED1D 53				dta		$53			;command 'S'
   181 ED1E 40				dta		$40			;input/output mode (read)
   182 ED1F EA 02			dta		a(dvstat)	;buffer address
   183 ED21 00 00			dta		a(0)		;timeout
   184 ED23 04 00			dta		a(4)		;buffer length
   185 				.endp
   186
   187 				;==============================================================================
   188 = E4CB			PrinterGetByte = CIOExitNotSupported
   189 = E4CB			PrinterSpecial = CIOExitNotSupported
