    10 E7FA			.proc SIOInit
    11 					;turn off POKEY init mode so polynomial counters and audio run
    12 E7FA A9 03 8D 0F D2		mva		#3 skctl
    13 E7FF 8D 32 02			sta		sskctl
    14 					
    15 					;enable noisy sound (yes, this is actually documented as being inited to
    16 					;3)
    17 E802 85 41			sta		soundr
    18 E804 60				rts
    19 				.endp
    20
    21 				;==============================================================================
    22 E805			.proc SIO
    23 					;set retry counters
    24 E805 A9 01 8D BD 02		mva		#$01 dretry
    25 					
    26 					;enter critical section
    27 E80A 85 42			sta		critic
    28 					
    29 				.if _KERNEL_PBI_SUPPORT
    30 					;attempt PBI transfer
    31 E80C 20 30 C3			jsr		PBIAttemptSIO
    32 E80F 90 03 4C 00 E9		scc:jmp	xit_pbi
    33 				.endif
    34
    35 					;we must not save STACKP until after PBI devices are polled -- the
    36 					;BlackBox PBI routines depend on being able to reuse this location
    37 E814 BA				tsx
    38 E815 8E 18 03			stx		stackp
    39 					
    40 					;Set timeout timer address -- MUST be done on each call to SIO, or
    41 					;Cross-Town Crazy Eight hangs on load due to taking over this vector
    42 					;previously. This is guaranteed by the OS Manual in Appendix L, H27.
    43 E818 20 27 E9			jsr		SIOSetTimeoutVector
    44
    45 					;check for cassette -- needs to match $60 or else Prisma: Alien Ambush
    46 					;fails to load.
    47 E81B A2 00			ldx		#0
    48 E81D AD 00 03			lda		ddevic
    49 E820 C9 60			cmp		#$60
    50 E822 D0 01 CA			sne:dex
    51 E825 8E 0F 03			stx		casflg
    52
    53 					;init POKEY hardware
    54 E828 20 7A E9			jsr		SIOInitHardware
    55
    56 					;go do cassette now
    57 E82B 2C 0F 03			bit		casflg
    58 E82E 10 03			bpl		retry_command
    59 E830 4C F3 EA			jmp		SIOCassette	
    60 					
    61 E833			retry_command:
    62 					;We try 13 times to get a command accepted by a device; after that it
    63 					;counts as a device failure and we try one more round of 13 tries.
    64 E833 A9 0D 8D 9C 02		mva		#$0d cretry
    65 					
    66 E838			retry_command_2:
    67 					;init command buffer
    68 E838 AD 00 03			lda		ddevic
    69 E83B 18				clc
    70 E83C 6D 01 03			adc		dunit
    71 E83F 38				sec
    72 E840 E9 01			sbc		#1
    73 E842 8D 3A 02			sta		cdevic
    74
    75 E845 AD 02 03 8D 3B 02		mva		dcomnd		ccomnd
    76 E84B AD 0A 03 8D 3C 02		mva		daux1		caux1
    77 E851 AD 0B 03 8D 3D 02		mva		daux2		caux2
    78 						
    79 					;assert command line
    80 E857 A9 34 8D 03 D3		mva		#$34		pbctl
    81
    82 					;wait ~600us to ensure 750us minimum delay (~1k cycles or ~10 scanlines)
    83 E85C A2 05			ldx		#5
    84 E85E AC 0B D4			ldy		vcount
    85 E861			cmddelay:
    86 E861 CC 0B D4 F0 FB		cpy:req	vcount
    87 E866 C8				iny
    88 E867 CA				dex
    89 E868 D0 F7			bne		cmddelay
    90
    91 					;send command frame
    92 E86A A9 00 85 3C			mva		#0			nocksm
    93 E86E A9 02			lda		#>cdevic
    94 E870 85 33			sta		bufrhi
    95 E872 85 35			sta		bfenhi
    96 E874 A9 3A 85 32			mva		#<cdevic	bufrlo
    97 E878 A9 3E 85 34			mva		#<caux2+1	bfenlo
    98 E87C 20 DF E9			jsr		SIOSend
    99 E87F 30 67			bmi		xit
   100 						
   101 					;wait for the ACK
   102 E881 20 32 E9			jsr		SIOWaitForACK
   103 E884 10 0A			bpl		ackOK
   104 					
   105 E886			command_error:
   106 E886 20 4F EA			jsr		SIOReceiveStop
   107 E889 CE 9C 02			dec		cretry
   108 E88C 10 AA			bpl		retry_command_2
   109 E88E 30 4D			bmi		transfer_error
   110
   111 E890			ackOK:
   112
   113 					;check if we should send a data frame
   114 E890 2C 03 03			bit		dstats
   115 E893 10 0D			bpl		no_send_frame
   116 					
   117 					;setup buffer pointers
   118 E895 20 C9 E9			jsr		SIOSetupBufferPointers
   119 					
   120 					;send data frame	
   121 E898 20 DF E9			jsr		SIOSend
   122 E89B 30 4B			bmi		xit
   123 					
   124 					;wait for ACK
   125 E89D 20 32 E9			jsr		SIOWaitForACK
   126 E8A0 30 E4			bmi		command_error
   127
   128 E8A2			no_send_frame:
   129 					
   130 					;setup for receiving complete
   131 E8A2 A2 FF			ldx		#$ff
   132 E8A4 86 3C			stx		nocksm
   133
   134 					;setup frame delay for complete
   135 E8A6 AD 06 03			lda		dtimlo
   136 E8A9 6A				ror
   137 E8AA 6A				ror
   138 E8AB 48				pha
   139 E8AC 6A				ror
   140 E8AD 29 C0			and		#$c0
   141 E8AF A8				tay
   142 E8B0 68				pla
   143 E8B1 29 3F			and		#$3f
   144 E8B3 AA				tax
   145
   146 E8B4 A9 01			lda		#1
   147 E8B6 8D 17 03			sta		timflg
   148 E8B9 20 5C E4			jsr		setvbv
   149
   150 E8BC A2 3E			ldx		#<temp
   151 E8BE 86 32			stx		bufrlo
   152 E8C0 E8				inx
   153 E8C1 86 34			stx		bfenlo
   154 E8C3 A2 02			ldx		#>temp
   155 E8C5 86 33			stx		bufrhi
   156 E8C7 86 35			stx		bfenhi
   157 E8C9 20 10 EA			jsr		SIOReceive
   158 E8CC 30 0F			bmi		transfer_error
   159 					
   160 					;Check if we received a C ($43) or E ($45) -- we must NOT abort immediately
   161 					;on a device error, as the device still sends back data we need to read, and
   162 					;Music Studio relies on the data coming back from a CRC error.
   163 					;
   164 					;We also need to accept ACK ($41) here, due to a bug in the stock OS that
   165 					;we need to replicate. The Zero Adjust step in the Indus GT diagnostics
   166 					;fails if we don't replicate this bug.
   167 					;
   168 E8CE AD 3E 02			lda		temp
   169 E8D1 C9 45			cmp		#$45
   170 E8D3 F0 37			beq		completeOK
   171 E8D5 09 02			ora		#$02
   172 E8D7 C9 43			cmp		#$43
   173 E8D9 F0 31			beq		completeOK
   174 					
   175 					;we received crap... fail it now
   176 E8DB			device_error:
   177 E8DB A0 90			ldy		#SIOErrorDeviceError
   178 					
   179 E8DD			transfer_error:
   180 E8DD 20 4F EA			jsr		SIOReceiveStop
   181
   182 E8E0 CE BD 02			dec		dretry
   183 E8E3 30 03			bmi		device_retries_exhausted
   184 E8E5 4C 33 E8			jmp		retry_command
   185
   186 E8E8			device_retries_exhausted:
   187 E8E8			xit:
   188 E8E8 AE 0F 03			ldx		casflg
   189 E8EB D0 0C			bne		leave_cassette_audio_on
   190 E8ED 8E 01 D2			stx		audc1
   191 E8F0 8E 03 D2			stx		audc2
   192 E8F3 8E 05 D2			stx		audc3
   193 E8F6 8E 07 D2			stx		audc4
   194 E8F9			leave_cassette_audio_on:
   195
   196 				.ifdef _KERNEL_816
   197 					;we may be in native mode, so we can't f-up the high byte of the stack pointer
   198 E8F9 A9 01			lda		#1
   199 E8FB EB				xba
   200 E8FC AD 18 03			lda		stackp
   201 E8FF 1B				tcs
   202 				.else
   203 					ldx		stackp
   204 					txs
   205 				.endif
   206
   207 E900			xit_pbi:
   208 E900 A9 00			lda		#0
   209 E902 85 42			sta		critic
   210
   211 E904 C0 00			cpy		#0			;!! - A=0 must be preserved for LiteDOS
   212 E906 8C 03 03			sty		dstats
   213 E909 84 30			sty		status
   214 E90B 60				rts
   215
   216 E90C			completeOK:		
   217 					;check if we should read a data frame
   218 E90C 2C 03 03			bit		dstats
   219 E90F 50 08			bvc		no_receive_frame
   220 					
   221 					;setup buffer pointers
   222 E911 20 C9 E9			jsr		SIOSetupBufferPointers
   223
   224 					;receive the rest of the frame
   225 E914 20 10 EA			jsr		SIOReceive
   226 E917 30 C4			bmi		transfer_error
   227
   228 E919			no_receive_frame:
   229 					;now we can finally shut off the receive IRQ
   230 E919 20 4F EA			jsr		SIOReceiveStop
   231
   232 					;Now check whether we got a device error earlier. If we did, return
   233 					;that instead of success. Check for Error, because we need to accept
   234 					;either ACK or Complete as stated above.
   235 E91C AD 3E 02			lda		temp
   236 E91F C9 45			cmp		#'E'
   237 E921 F0 B8			beq		device_error
   238 					
   239 					;nope, we're good... exit OK.
   240 E923 A0 01			ldy		#SIOSuccess
   241 E925 D0 C1			bne		xit
   242 				.endp
   243
   244 				;==============================================================================
   245 E927			.proc SIOSetTimeoutVector
   246 E927 A9 ED 8D 26 02 A9 + 	mwa		#SIOCountdown1Handler	cdtma1
   247 E931 60				rts
   248 				.endp
   249
   250 				;==============================================================================
   251 E932			.proc SIOWaitForACK
   252 					;setup 2 frame delay for ack
   253 E932 A2 FF			ldx		#$ff
   254 E934 86 3C			stx		nocksm
   255 E936 E8				inx					;X=0 (MSB of timeout duration)
   256 E937 A9 01			lda		#1			;set timer 1
   257 E939 8D 17 03			sta		timflg
   258 E93C A0 02			ldy		#2			;LSB of timeout duration
   259 E93E 84 33			sty		bufrhi		;>temp = 2
   260 E940 84 35			sty		bfenhi		;>temp+1 = 2
   261 E942 20 5C E4			jsr		setvbv
   262
   263 					;setup for receiving ACK
   264 E945 A2 3E			ldx		#<temp
   265 E947 86 32			stx		bufrlo
   266 E949 E8				inx
   267 E94A 86 34			stx		bfenlo		;#<[temp+1]
   268
   269 E94C 20 10 EA			jsr		SIOReceive
   270 					
   271 					;check if we had a receive error
   272 E94F 30 09			bmi		xit
   273 					
   274 					;check if we got an ACK
   275 E951 AD 3E 02			lda		temp
   276 E954 C9 41			cmp		#'A'
   277 E956 F0 02			beq		xit
   278 					
   279 					;doh
   280 E958 A0 8B			ldy		#SIOErrorNAK
   281 E95A			xit:
   282 E95A 60				rts
   283 				.endp
   284
   285 				;==============================================================================
   286 				;SIO send enable routine
   287 				;
   288 				; This is one of those routines that Atari inadvisably exposed in the OS jump
   289 				; table even though they shouldn't. Responsibilities of this routine are:
   290 				;
   291 				;	- Hit SKCTL to reset serial hardware and init for sending
   292 				;	- Hit SKRES to clear status
   293 				;	- Enable send interrupts
   294 				;	- Configure AUDF3/AUDF4 frequency (19200 baud or 600 baud)
   295 				;	- Set AUDC3/AUDC4 for noisy or non-noisy audio
   296 				;	- Set AUDCTL
   297 				;
   298 				; It does not init any of the SIO variables, only hardware/shadow state.
   299 				;
   300 = E97A			SIOInitHardware = SIOSendEnable.init_hardware
   301 E95B			.proc SIOSendEnable
   302 					;enable serial output ready IRQ and suppress serial output complete IRQ
   303 E95B A5 10			lda		pokmsk
   304 E95D 09 10			ora		#$10
   305 E95F 29 F7			and		#$f7
   306 E961 85 10			sta		pokmsk
   307 E963 8D 0E D2			sta		irqen
   308
   309 E966			no_irq_setup:
   310 					;clear forced break mode and reset serial clocking mode to timer 4
   311 					;synchronous; also enable two-tone mode if in cassette mode
   312 E966 AD 32 02			lda		sskctl
   313 E969 29 0F			and		#$0f
   314 E96B 09 20			ora		#$20
   315 E96D AE 0F 03			ldx		casflg
   316 E970 F0 02 09 08			seq:ora	#$08
   317 E974 8D 32 02			sta		sskctl
   318 E977 8D 0F D2			sta		skctl
   319
   320 E97A			init_hardware:
   321 					;clock channel 3 and 4 together at 1.79MHz
   322 					;configure pokey timers 3 and 4 for 19200 baud (1789773/(2*40+7) = 19040)
   323 E97A A2 08			ldx		#8
   324 					
   325 					;check if we are doing a cassette transfer; if so, use the cassette
   326 					;register table instead
   327 E97C AD 0F 03			lda		casflg
   328 E97F F0 02			beq		not_cassette
   329 					
   330 E981 A2 11			ldx		#17
   331 					
   332 E983			not_cassette:
   333
   334 = E983			.def :SIOInitPOKEYWithRegOffsetX
   335 					;load POKEY audio registers
   336 E983 A0 08			ldy		#8
   337 E985 BD AE E9 CA 99 00 + 	mva:rpl	regdata_normal,x- audf1,y-
   338
   339 					;go noisy audio if requested
   340 E98F A5 41			lda		soundr
   341 E991 F0 17			beq		no_noise
   342 					
   343 E993 A9 A8			lda		#$a8
   344 E995 8D 07 D2			sta		audc4
   345 E998 AE 0F 03			ldx		casflg
   346 E99B F0 0D			beq		no_noise
   347 E99D A9 10			lda		#$10
   348 E99F 2C 32 02			bit		sskctl
   349 E9A2 D0 06			bne		no_noise
   350 E9A4 8D 01 D2			sta		audc1
   351 E9A7 8D 03 D2			sta		audc2
   352
   353 E9AA			no_noise:
   354
   355 					;reset serial status
   356 E9AA 8D 0A D2			sta		skres
   357 E9AD 60				rts
   358
   359 E9AE			regdata:
   360 E9AE			regdata_normal:
   361 E9AE 00				dta		$00		;audf1
   362 E9AF A0				dta		$a0		;audc1
   363 E9B0 00				dta		$00		;audf2
   364 E9B1 A0				dta		$a0		;audc2
   365 E9B2 28				dta		$28		;audf3
   366 E9B3 A0				dta		$a0		;audc3
   367 E9B4 00				dta		$00		;audf4
   368 E9B5 A0				dta		$a0		;audc4
   369 E9B6 28				dta		$28		;audctl
   370 					
   371 E9B7			regdata_cassette_write:
   372 E9B7 05				dta		$05		;audf1
   373 E9B8 A0				dta		$a0		;audc1
   374 E9B9 07				dta		$07		;audf2
   375 E9BA A0				dta		$a0		;audc2
   376 E9BB CC				dta		$cc		;audf3
   377 E9BC A0				dta		$a0		;audc3
   378 E9BD 05				dta		$05		;audf4
   379 E9BE A0				dta		$a0		;audc4
   380 E9BF 28				dta		$28		;audctl
   381
   382 E9C0			regdata_cassette_read:
   383 E9C0 00				dta		$00		;audf1
   384 E9C1 A0				dta		$a0		;audc1
   385 E9C2 00				dta		$00		;audf2
   386 E9C3 A0				dta		$a0		;audc2
   387 E9C4 CC				dta		$cc		;audf3
   388 E9C5 A0				dta		$a0		;audc3
   389 E9C6 05				dta		$05		;audf4
   390 E9C7 A0				dta		$a0		;audc4
   391 E9C8 28				dta		$28		;audctl
   392 				.endp
   393
   394 				;==============================================================================
   395 E9C9			.proc SIOSetupBufferPointers
   396 E9C9 18				clc
   397 E9CA AD 04 03			lda		dbuflo
   398 E9CD 85 32			sta		bufrlo
   399 E9CF 6D 08 03			adc		dbytlo
   400 E9D2 85 34			sta		bfenlo
   401 E9D4 AD 05 03			lda		dbufhi
   402 E9D7 85 33			sta		bufrhi
   403 E9D9 6D 09 03			adc		dbythi
   404 E9DC 85 35			sta		bfenhi
   405 E9DE 60				rts
   406 				.endp
   407
   408 				;==============================================================================
   409 				;SIO send routine
   410 				;
   411 E9DF			.proc SIOSend
   412 					;configure serial port for synchronous transmission
   413 					;enable transmission IRQs
   414 E9DF 78				sei
   415 E9E0 20 5B E9			jsr		SIOSendEnable
   416 					
   417 E9E3 A0 00			ldy		#0
   418 E9E5 84 3A			sty		xmtdon
   419 E9E7 84 30			sty		status
   420 E9E9 84 3B			sty		chksnt
   421 					
   422 					;send first byte and set checksum (must be atomic)
   423 E9EB B1 32			lda		(bufrlo),y
   424 E9ED 8D 0D D2			sta		serout
   425 E9F0 85 31			sta		chksum
   426
   427 					;unmask IRQs
   428 E9F2 58				cli
   429 					
   430 					;wait for transmit to complete or Break to be pressed
   431 E9F3			wait:
   432 E9F3 A5 11			lda		brkkey
   433 E9F5 F0 06			beq		break_detected
   434 E9F7 A5 3A			lda		xmtdon
   435 E9F9 F0 F8			beq		wait
   436 E9FB D0 06			bne		send_completed
   437
   438 E9FD			break_detected:
   439 E9FD A0 80			ldy		#$80
   440 E9FF 84 30			sty		status
   441 EA01 C6 11			dec		brkkey			;reset brkkey to $FF (init value)
   442 					
   443 EA03			send_completed:
   444 					;shut off transmission IRQs
   445 EA03 78				sei
   446 EA04 A5 10			lda		pokmsk
   447 EA06 29 E7			and		#$e7
   448 EA08 85 10			sta		pokmsk
   449 EA0A 8D 0E D2			sta		irqen
   450 EA0D 58				cli
   451
   452 					;we're done
   453 EA0E 98				tya
   454 EA0F 60				rts
   455 				.endp
   456
   457 				;==============================================================================
   458 				; SIO receive routine
   459 				;
   460 				; The exit and entry paths of this routine are time critical when receiving
   461 				; the Complete/Error byte and data frame since there may be no delay at all
   462 				; in between. The exit path needs to exit with the receive IRQ hot but IRQs
   463 				; masked; the entry path in turn needs to keep the IRQ enabled but not unmask
   464 				; IRQs until ready to receive.
   465 				;
   466 EA10			.proc SIOReceive
   467 EA10 A9 00			lda		#0
   468 EA12			use_checksum:
   469 EA12 85 31			sta		chksum
   470 EA14 A2 00			ldx		#0
   471 EA16 86 39			stx		recvdn			;receive done flag = false
   472 EA18 86 38			stx		bufrfl			;buffer full flag = false
   473 EA1A E8				inx
   474 EA1B 86 30			stx		status			;set status to success (1)
   475
   476 					;configure serial port for asynchronous receive
   477 					;enable receive IRQ
   478 EA1D 78				sei
   479 EA1E AD 32 02			lda		sskctl
   480 EA21 29 8F			and		#$8f
   481 EA23 09 10			ora		#$10
   482 EA25 8D 32 02			sta		sskctl
   483 EA28 8D 0F D2			sta		skctl
   484 EA2B A5 10			lda		pokmsk
   485 EA2D 09 20			ora		#$20
   486 EA2F 85 10			sta		pokmsk
   487 EA31 8D 0E D2			sta		irqen
   488 EA34 58				cli
   489 					
   490 					;Negate command line (if it isn't already negated).
   491 					;
   492 					;Note that we DON'T do this until we are entirely ready to receive,
   493 					;because as soon as we do this we can get data.
   494 EA35 A9 3C 8D 03 D3		mva		#$3c pbctl
   495
   496 					;wait for receive to complete
   497 EA3A			wait:
   498 EA3A AD 17 03			lda		timflg			;check for timeout
   499 EA3D F0 0C			beq		timeout			;bail if so
   500 EA3F A4 30			ldy		status			;check for another error code
   501 EA41 30 06			bmi		error			;bail if so
   502 EA43 A5 39			lda		recvdn			;check for receive complete
   503 EA45 F0 F3			beq		wait			;keep waiting if not
   504 EA47 A4 30			ldy		status			;set flags from status, and reload in case recvdn
   505 											;was hit first after IRQ set status
   506 					
   507 EA49			error:
   508 					;Mask interrupts, but exit with them masked. We do this in order to
   509 					;handle the transition from Complete to data frame during receive. There
   510 					;is no guaranteed device delay in between these and some disk drives
   511 					;send back-to-back bytes. In addition, there are demos that have DLIs
   512 					;active during SIO loads. Therefore, we avoid turning off the receive
   513 					;interrupt and instead hold it off to give us the best chance of snagging
   514 					;the first and second bytes successfully, even if delayed.
   515 EA49 78				sei
   516 EA4A 60				rts
   517 					
   518 EA4B			timeout:
   519 EA4B A0 8A			ldy		#SIOErrorTimeout
   520 EA4D 78				sei
   521 EA4E 60				rts
   522 				.endp
   523
   524 				;==============================================================================
   525 EA4F			.proc SIOReceiveStop
   526 					;shut off receive IRQs
   527 EA4F A5 10			lda		pokmsk
   528 EA51 29 D7			and		#$d7
   529 EA53 85 10			sta		pokmsk
   530 EA55 8D 0E D2			sta		irqen
   531 EA58 58				cli
   532 EA59 60				rts
   533 				.endp
   534
   535 				;==============================================================================
   536 				; SIO serial input routine
   537 				;
   538 				; DOS 2.0S replaces (VSERIN), so it's critical that this routine follow the
   539 				; rules compatible with DOS. The rules are as follows:
   540 				;
   541 				;	BUFRLO/BUFRHI:	Points to next byte to read. Note that this is different
   542 				;					from (VSEROR)!
   543 				;	BFENLO/BFENHI:	Points one after last byte in buffer.
   544 				;	BUFRFL:			Set when all data bytes have been read.
   545 				;	NOCKSM:			Set if no checksum byte is expected. Cleared after checked.
   546 				;	RECVDN:			Set when receive is complete, including any checksum.	
   547 				;
   548 EA5A			.proc SIOInputReadyHandler
   549 EA5A A5 38			lda		bufrfl
   550 EA5C D0 2A			bne		receiveChecksum
   551
   552 					;receive data byte
   553 EA5E 98				tya
   554 EA5F 48				pha
   555 EA60 AD 0D D2			lda		serin
   556 EA63 A0 00			ldy		#$00
   557 EA65 91 32			sta		(bufrlo),y
   558 EA67 18				clc
   559 EA68 65 31			adc		chksum
   560 EA6A 69 00			adc		#$00
   561 EA6C 85 31			sta		chksum
   562
   563 					;restore Y now
   564 EA6E 68				pla
   565 EA6F A8				tay
   566 					
   567 					;bump buffer pointer
   568 EA70 E6 32 D0 02 E6 33		inw		bufrlo
   569 					
   570 					;check for EOB
   571 EA76 A5 32			lda		bufrlo
   572 EA78 C5 34			cmp		bfenlo
   573 EA7A A5 33			lda		bufrhi
   574 EA7C E5 35			sbc		bfenhi
   575 EA7E 90 06			bcc		xit
   576
   577 EA80 C6 38			dec		bufrfl					;!! - this was $00 coming in
   578 					
   579 					;should there be a checksum?
   580 EA82 A5 3C			lda		nocksm
   581 EA84 D0 15			bne		skipChecksum
   582 EA86			xit:
   583 EA86 68				pla
   584 EA87 40				rti
   585 					
   586 EA88			receiveChecksum:
   587 					;read and compare checksum
   588 EA88 AD 0D D2			lda		serin
   589 EA8B C5 31			cmp		chksum
   590 EA8D D0 06			bne		checksum_fail
   591 					
   592 EA8F			signal_end:
   593 					;set receive done flag
   594 EA8F A9 FF 85 39			mva		#$ff	recvdn
   595
   596 					;exit
   597 EA93 68				pla
   598 EA94 40				rti
   599
   600 EA95			checksum_fail:
   601 EA95 A9 8F			lda		#SIOErrorChecksum
   602 EA97 85 30			sta		status
   603 EA99 D0 F4			bne		signal_end				;!! - unconditional
   604 					
   605 EA9B			skipChecksum:
   606 					;set receive done flag
   607 EA9B 85 39			sta		recvdn
   608 					
   609 					;clear no checksum flag
   610 EA9D A9 00			lda		#0
   611 EA9F 85 3C			sta		nocksm
   612 EAA1 68				pla
   613 EAA2 40				rti
   614 				.endp
   615
   616 				;==============================================================================
   617 				; SIO serial output ready routine
   618 				;
   619 				; DOS 2.0S replaces (VSEROR), so it's critical that this routine follow the
   620 				; rules compatible with DOS. The rules are as follows:
   621 				;
   622 				;	BUFRLO/BUFRHI:	On entry, points to one LESS than the next byte to write.
   623 				;	BFENLO/BFENHI:	Points to byte immediately after buffer.
   624 				;	CHKSUM:			Holds running checksum as bytes are output.
   625 				;	CHKSNT:			$00 if checksum not yet sent, $FF if checksum sent.
   626 				;	POKMSK:			Used to enable the serial output complete IRQ after sending
   627 				;					checksum.
   628 				;
   629 EAA3			.proc SIOOutputReadyHandler
   630 					;increment buffer pointer
   631 EAA3 E6 32			inc		bufrlo
   632 EAA5 D0 02			bne		addrcc
   633 EAA7 E6 33			inc		bufrhi
   634 EAA9			addrcc:
   635
   636 					;compare against buffer end
   637 EAA9 A5 32			lda		bufrlo
   638 EAAB C5 34			cmp		bfenlo
   639 EAAD A5 33			lda		bufrhi
   640 EAAF E5 35			sbc		bfenhi			;set flags according to (dst - end)
   641 EAB1 B0 13			bcs		doChecksum
   642
   643 					;save Y
   644 EAB3 98				tya
   645 EAB4 48				pha
   646
   647 					;send out next byte
   648 EAB5 A0 00			ldy		#0
   649 EAB7 B1 32			lda		(bufrlo),y
   650 EAB9 8D 0D D2			sta		serout
   651 					
   652 					;update checksum
   653 EABC 65 31			adc		chksum
   654 EABE 69 00			adc		#0
   655 EAC0 85 31			sta		chksum
   656
   657 					;restore registers and exit
   658 EAC2 68				pla
   659 EAC3 A8				tay
   660 EAC4 68				pla
   661 EAC5 40				rti
   662 					
   663 EAC6			doChecksum:
   664 					;send checksum
   665 EAC6 A5 31			lda		chksum
   666 EAC8 8D 0D D2			sta		serout
   667 					
   668 					;set checksum sent flag
   669 EACB A9 FF 85 3B			mva		#$ff	chksnt
   670 					
   671 					;enable output complete IRQ and disable serial output IRQ
   672 EACF A5 10			lda		pokmsk
   673 EAD1 09 08			ora		#$08
   674 EAD3 29 EF			and		#$ef
   675 EAD5 85 10			sta		pokmsk
   676 EAD7 8D 0E D2			sta		irqen
   677 					
   678 EADA 68				pla
   679 EADB 40				rti
   680 				.endp
   681
   682 				;==============================================================================
   683 EADC			.proc SIOOutputCompleteHandler
   684 					;check that we've sent the checksum
   685 EADC A5 3B			lda		chksnt
   686 EADE F0 0B			beq		xit
   687 					
   688 					;we're done sending the checksum
   689 EAE0 85 3A			sta		xmtdon
   690 					
   691 					;need to shut off this interrupt as it is not latched
   692 EAE2 A5 10			lda		pokmsk
   693 EAE4 29 F7			and		#$f7
   694 EAE6 85 10			sta		pokmsk
   695 EAE8 8D 0E D2			sta		irqen
   696
   697 EAEB			xit:
   698 EAEB 68				pla
   699 EAEC 40				rti
   700 				.endp
   701
   702 				;==============================================================================
   703 EAED			.proc SIOCountdown1Handler
   704 					;signal operation timeout
   705 EAED A9 00 8D 17 03		mva		#0	timflg
   706 EAF2 60				rts
   707 				.endp
   708
   709 				;==============================================================================
   710 EAF3			.proc SIOCassette
   711 					;check if it's read sector
   712 EAF3 AD 02 03			lda		dcomnd
   713 EAF6 C9 52			cmp		#$52
   714 EAF8 F0 0F			beq		isread
   715 					
   716 					;check if it's put sector
   717 EAFA C9 50			cmp		#$50
   718 EAFC F0 05			beq		iswrite
   719
   720 					;nope, bail	
   721 EAFE A0 8B			ldy		#SIOErrorNAK
   722 EB00 4C E8 E8			jmp		SIO.xit
   723 					
   724 EB03			iswrite:
   725 EB03 20 0F EB			jsr		SIOCassetteWriteFrame
   726 EB06 4C E8 E8			jmp		SIO.xit
   727
   728 EB09			isread:
   729 EB09 20 20 EB			jsr		SIOCassetteReadFrame
   730 EB0C 4C E8 E8			jmp		SIO.xit
   731 				.endp
   732
   733 				;==============================================================================
   734 EB0F			.proc SIOCassetteWriteFrame
   735 					;wait for pre-record write tone or IRG read delay
   736 EB0F A2 02			ldx		#2
   737 EB11 20 6E EE			jsr		CassetteWaitLongShortCheck
   738
   739 					;set up to transmit
   740 EB14 20 5B E9			jsr		SIOSendEnable
   741 					
   742 					;setup buffer pointers
   743 EB17 20 C9 E9			jsr		SIOSetupBufferPointers
   744 					
   745 					;send data frame
   746 EB1A 20 DF E9			jsr		SIOSend
   747 					
   748 					;all done
   749 EB1D 4C E8 E8			jmp		SIO.xit
   750 				.endp
   751
   752 				;==============================================================================
   753 				; Read cassette frame
   754 				;
   755 				; Wait for long/short IRG, measure baud rate from sync mark, and read frame.
   756 				;
   757 				; When reading a cassette frame, the audio configuration is expected to be
   758 				; as follows:
   759 				;
   760 				;	Channel 1: Inaudible (31.5KHz)
   761 				;	Channel 2: Inaudible (31.5KHz)
   762 				;	Channel 3: Silent
   763 				;	Channel 4: Audible if enabled in SOUNDR (600Hz modulated by async read)
   764 				;
   765 				; This is necessary for proper tape loading sounds.
   766 				;
   767 EB20			.proc SIOCassetteReadFrame
   768 					;wait for pre-record write tone or IRG read delay
   769 EB20 A2 04			ldx		#4
   770 EB22 20 6E EE			jsr		CassetteWaitLongShortCheck
   771
   772 					;set to 600 baud, turn on async read to shut off annoying tone
   773 EB25 A2 1A			ldx		#SIOSendEnable.regdata_cassette_read-SIOSendEnable.regdata+8
   774 EB27 20 83 E9			jsr		SIOInitPOKEYWithRegOffsetX
   775 					
   776 EB2A AD 32 02			lda		sskctl
   777 EB2D 29 8F			and		#$8f
   778 EB2F 09 10			ora		#$10
   779 EB31 8D 32 02			sta		sskctl
   780
   781 					;set timeout (approx; no NTSC/PAL switching yet)
   782 EB34 A9 01			lda		#1
   783 EB36 8D 17 03			sta		timflg
   784 EB39 A2 0E			ldx		#>3600
   785 EB3B A0 10			ldy		#<3600
   786 EB3D 20 5B C1			jsr		VBISetVector
   787
   788 					;wait for beginning of frame
   789 EB40 A9 10			lda		#$10		;test bit 4 of SKSTAT
   790 EB42			waitzerostart:
   791 EB42 AC 17 03			ldy		timflg
   792 EB45 F0 2B			beq		timeout
   793 EB47 2C 0F D2			bit		skstat
   794 EB4A D0 F6			bne		waitzerostart
   795 					
   796 					;take first time measurement
   797 EB4C 20 0C EC			jsr		readtimer
   798 EB4F 8C 0D 03			sty		timer1+1
   799 EB52 8D 0C 03			sta		timer1
   800
   801 					;wait for 19 bit transitions
   802 EB55 A9 10			lda		#$10		;test bit 4 of SKSTAT
   803 EB57 A2 0A			ldx		#10			;test 10 pairs of bits
   804 EB59			waitone:
   805 EB59 AC 17 03			ldy		timflg
   806 EB5C F0 14			beq		timeout
   807 EB5E 2C 0F D2			bit		skstat
   808 EB61 F0 F6			beq		waitone
   809 EB63 CA				dex
   810 EB64 F0 11			beq		waitdone
   811 EB66			waitzero:
   812 EB66 AC 17 03			ldy		timflg
   813 EB69 F0 07			beq		timeout
   814 EB6B 2C 0F D2			bit		skstat
   815 EB6E D0 F6			bne		waitzero
   816 EB70 F0 E7			beq		waitone
   817 					
   818 EB72			timeout:
   819 EB72 A0 8A			ldy		#SIOErrorTimeout
   820 EB74 4C E8 E8			jmp		SIO.xit	
   821
   822 EB77			waitdone:
   823 					
   824 					;take second time measurement
   825 EB77 20 0C EC			jsr		readtimer
   826 EB7A 8D 10 03			sta		timer2
   827 EB7D 8C 11 03			sty		timer2+1
   828 					
   829 					;compute baud rate and adjust pokey divisor
   830 					;
   831 					; counts = (pal ? 156 : 131)*rtdelta + vdelta;
   832 					; lines = counts * 2
   833 					; lines_per_bit = lines / 19
   834 					; cycles_per_bit = lines_per_bit * 114
   835 					; pokey_divisor = cycles_per_bit / 2 - 7
   836 					;
   837 					; -or-
   838 					;
   839 					; pokey_divisor = counts * 2 * 114 / 19 / 2 - 7
   840 					;               = counts * 6 - 7
   841 					;
   842 					;16 bits at 600 baud is nominally 209 scanline pairs. This means that we
   843 					;don't have to worry about more than two frames, which is at least 262
   844 					;scanline pairs or less than 480 baud.
   845 					
   846 					;set frame height - 262 scanlines for NTSC, 312 for PAL
   847 EB80 A2 83			ldx		#131
   848 EB82 AD 14 D0			lda		pal
   849 EB85 4A				lsr
   850 EB86 D0 02 A2 9C			sne:ldx	#156
   851 EB8A 8E 15 03			stx		temp3
   852 					
   853 					;compute line difference
   854 EB8D AD 0C 03			lda		timer1
   855 EB90 20 1A EC			jsr		correct_time
   856 EB93 85 34			sta		bfenlo
   857 					
   858 EB95 AD 10 03			lda		timer2
   859 EB98 20 1A EC			jsr		correct_time
   860 EB9B 18				clc							;!! this decrements one line from the line delta
   861 EB9C E5 34			sbc		bfenlo
   862 EB9E 85 34			sta		bfenlo
   863 EBA0 A0 00			ldy		#0
   864 EBA2 B0 01 88			scs:dey
   865 					
   866 					;compute frame difference
   867 EBA5 AD 11 03			lda		timer2+1
   868 EBA8 38 ED 0D 03			sub		timer1+1
   869 EBAC AA				tax
   870 					
   871 					;accumulate frame difference
   872 EBAD F0 0C			beq		no_frames
   873 EBAF A5 34			lda		bfenlo
   874 EBB1			add_frame_loop:
   875 EBB1 18				clc
   876 EBB2 6D 15 03			adc		temp3
   877 EBB5 90 01 C8			scc:iny
   878 EBB8 CA				dex
   879 EBB9 D0 F6			bne		add_frame_loop
   880 EBBB			no_frames:
   881 EBBB 84 35			sty		bfenhi
   882
   883 					;compute lines*6 - 7 = (lines-1)*6 - 1
   884 EBBD 0A				asl							;(lines-1)*2 (lo)
   885 EBBE 26 35			rol		bfenhi				;(lines-1)*2 (hi)
   886 EBC0 85 34			sta		bfenlo
   887 EBC2 A4 35			ldy		bfenhi				;
   888 EBC4 06 34			asl		bfenlo				;(lines-1)*4 (lo)
   889 EBC6 26 35			rol		bfenhi				;(lines-1)*4 (hi)
   890 EBC8 65 34			adc		bfenlo				;(lines-1)*6 (lo)
   891 EBCA AA				tax							;
   892 EBCB 98				tya							;
   893 EBCC 65 35			adc		bfenhi				;(lines-1)*6 (hi) (and c=0)
   894 EBCE CA				dex							;-1 line, bringing us to -7
   895 EBCF 8E 04 D2			stx		audf3
   896 EBD2 8E EE 02			stx		cbaudl
   897 EBD5 E8				inx
   898 EBD6 D0 02 E9 00			sne:sbc	#0
   899 EBDA 8D 06 D2			sta		audf4
   900 EBDD 8D EF 02			sta		cbaudh
   901 						
   902 					;Reset pokey serial input shift hw.
   903 					;
   904 					;Clearing bits 0-1 sets init mode, which resets the serial I/O shift
   905 					;register machines and is the main thing we need. Bits 4-6 are of lesser
   906 					;importance as they only reset the phase of the serial clocks.
   907 					;
   908 EBE0 AE 32 02			ldx		sskctl
   909 EBE3 8A				txa
   910 EBE4 29 8C			and		#$8c
   911 EBE6 8D 0F D2			sta		skctl
   912 					
   913 					;reset serial port status
   914 EBE9 8D 0A D2			sta		skres
   915 					
   916 					;re-enable serial input hw
   917 EBEC 8E 0F D2			stx		skctl
   918 					
   919 EBEF 20 C9 E9			jsr		SIOSetupBufferPointers
   920 					
   921 					;stuff two $55 bytes into the buffer, which we "read" above
   922 EBF2 A9 55			lda		#$55
   923 EBF4 A0 00			ldy		#0
   924 EBF6 A2 02			ldx		#2
   925 EBF8			aaloop:
   926 EBF8 91 32			sta		(bufrlo),y
   927 EBFA E6 32 D0 02 E6 33		inw		bufrlo
   928 EC00 CA D0 F5			dex:bne	aaloop
   929 					
   930 					;reset checksum for two $55 bytes and receive frame
   931 EC03 0A				asl
   932 EC04 85 31			sta		chksum
   933 					
   934 EC06 20 12 EA			jsr		SIOReceive.use_checksum
   935 EC09 4C 4F EA			jmp		SIOReceiveStop
   936
   937 				;-------------------------------------------------------------------------
   938 				; We have to be VERY careful when reading (RTCLOK+2, VCOUNT), because
   939 				; the VBI can strike in between. First, we double-check RTCLOK+2 to see
   940 				; if it has changed. If so, we retry the read. Second, we check if
   941 				; VCOUNT=124, which corresponds to lines 248/249. This can correspond to
   942 				; either before or after the VBI -- with CRITIC off the VBI ends around
   943 				; (249, 20-50) -- so we don't know which side of the frame boundary we're
   944 				; on.
   945 				;
   946 EC0C			readtimer:
   947 EC0C A4 14			ldy		rtclok+2
   948 EC0E AD 0B D4			lda		vcount
   949 EC11 C4 14			cpy		rtclok+2
   950 EC13 D0 F7			bne		readtimer
   951 EC15 C9 7C			cmp		#124
   952 EC17 F0 F3			beq		readtimer
   953 EC19 60				rts
   954 					
   955 EC1A			correct_time:
   956 EC1A 38				sec
   957 EC1B E9 7C			sbc		#124
   958 EC1D B0 03			bcs		time_ok
   959 EC1F 6D 15 03			adc		temp3
   960 EC22			time_ok:
   961 EC22 60				rts
   962 						
   963 				.endp
   964
