   353 				;---------------
   354 FB20			special_clear:
   355 FB20 4C 49 F8			jmp		ScreenClear
   356 					
   357 				;---------------
   358 FB23			special_up:
   359 FB23 A6 54			ldx		rowcrs
   360 FB25 D0 03			bne		isup2
   361 FB27 AE BF 02			ldx		botscr
   362 FB2A			isup2:
   363 FB2A CA				dex
   364 FB2B 10 0A			bpl		vmoveexit
   365 					
   366 				;---------------
   367 FB2D			special_down:
   368 FB2D A6 54			ldx		rowcrs
   369 FB2F E8				inx
   370 FB30 EC BF 02			cpx		botscr
   371 FB33 90 02 A2 00			scc:ldx	#0
   372 					
   373 FB37			vmoveexit:
   374 FB37 86 54			stx		rowcrs
   375 					
   376 					;check if we have moved into a different logical line -- if so,
   377 					;we need to reset the read row
   378 FB39 8A				txa
   379 FB3A 20 89 FD			jsr		EditorPhysToLogicalRow
   380 FB3D C5 6C			cmp		bufstr
   381 FB3F F0 06			beq		moveexit
   382 					
   383 					;we switched rows -- reset read row
   384 FB41 85 6C			sta		bufstr
   385 FB43 A5 52 85 6D			mva		lmargn bufstr+1
   386 					
   387 FB47			moveexit:
   388 FB47 60				rts
   389
   390 				;---------------
   391 FB48			special_backspace:
   392 					;check if we are at the left column
   393 FB48 A5 52			lda		lmargn
   394 FB4A C5 55			cmp		colcrs
   395 FB4C B0 0B			bcs		sbks_wrap
   396 					
   397 					;nope, we can just back up
   398 FB4E C6 55			dec		colcrs
   399 					
   400 					;recompute pos and clear character
   401 FB50			sbks_recomp:
   402 FB50 20 C2 FC			jsr		EditorRecomputeCursorAddr
   403 FB53 A0 00			ldy		#0
   404 FB55 98				tya
   405 FB56 91 5E			sta		(oldadr),y
   406 FB58			sbks_xit:
   407 FB58 60				rts
   408 					
   409 FB59			sbks_wrap:
   410 					;check if we're at the start of the logical line
   411 FB59 A5 54			lda		rowcrs
   412 FB5B 20 80 FD			jsr		EditorTestLogicalLineBit
   413 FB5E D0 F8			bne		sbks_xit
   414 					
   415 					;no, so we need to wrap to the right column of the prev line...
   416 FB60 C6 54			dec		rowcrs
   417 FB62 A5 53			lda		rmargn
   418 FB64 85 55			sta		colcrs
   419 					
   420 					;recompute everything and exit
   421 FB66 4C 50 FB			jmp		sbks_recomp
