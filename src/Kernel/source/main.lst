   857
   858 					;We use FR0:FR3 as a double-precision accumulator, and copy the
   859 					;original multiplicand value in FR0 to FR1. The multiplier in
   860 					;FR1 is converted to binary digit pairs into FR2.
   861 					
   862 = 00DF			_offset = _fr3+5
   863 = 00E6			_offset2 = fr2
   864
   865 					;if FR0 is zero, we're done
   866 DADB A5 D4			lda		fr0
   867 DADD F0 F5			beq		fp_exit_success
   868 					
   869 					;if FR1 is zero, zero FR0 and exit
   870 DADF A5 E0			lda		fr1
   871 DAE1 18				clc
   872 DAE2 F0 17			beq		fp_exit_zero
   873 					
   874 					;move fr0 to fr2
   875 DAE4 20 7C DE			jsr		fp_fmul_fr0_to_binfr2
   876 					
   877 					;compute new exponent and stash
   878 DAE7 A5 E0			lda		fr1
   879 DAE9 18				clc
   880 DAEA 20 03 DB			jsr		fp_adjust_exponent.fmul_entry
   881 					
   882 DAED 85 D4			sta		fr0
   883 DAEF E6 D4			inc		fr0
   884
   885 					;clear accumulator through to exponent byte of fr1
