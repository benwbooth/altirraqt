   942 				; Test whether a physical line is the start of a logical line.
   943 				;
   944 				; Entry:
   945 				;	A = line
   946 				;
   947 				; Exit:
   948 				;	Z = 1 if so, 0 if not
   949 				;
   950 				; Modified:
   951 				;	all registers
   952 				;
   953 FD80			.proc	EditorTestLogicalLineBit
   954 FD80 20 73 FD			jsr		EditorGetLogicalLineInfo
   955 FD83 39 B2 02			and		logmap,y
   956 FD86 60				rts
   957 				.endp
