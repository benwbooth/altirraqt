   131 				; Close screen (S:).
   132 				;
   133 				; This is a no-op in OS-B mode. In XL/XE mode, it reopens the device in
   134 				; Gr.0 if fine scrolling is on, since this is necessary to clear the DLI.
   135 				; This happens even if S: doesn't correspond to the text window. Only
   136 				; the high bit of FINE is checked.
   137 				;
   138 				.if !_KERNEL_XLXE
   139 				ScreenClose = CIOExitSuccess
   140 				.else
   141 FE25			.proc ScreenClose
   142 FE25 2C 6E 02			bit		fine
   143 FE28 30 03			bmi		disable_fine_scrolling
   144 					
   145 FE2A A0 01			ldy		#1
   146 FE2C 60				rts
   147
   148 FE2D			disable_fine_scrolling:
   149 					;turn off DLI
   150 FE2D A9 40 8D 0E D4		mva		#$40 nmien
   151 					
   152 					;restore vdslst
   153 FE32 A2 55			ldx		#<IntExitHandler_None
   154 FE34 A9 C0			lda		#>IntExitHandler_None
   155 FE36 20 9F F5			jsr		ScreenOpenGr0.write_vdslst
   156 					
   157 FE39 4C EE F3			jmp		ScreenOpenGr0
   158 				.endp
   159 				.endif
