    10 				;==========================================================================
    11 				;
    12 				; Known problems:
    13 				;	Currently incompatible with BASIC XE due to it relying on $DE-DF not
    14 				;	being modified by FADD/FSUB.
    15 				;
    16 				;==========================================================================
    17 				; Math pack memory usage constraints
    18 				;                                                                            INBUFF          DEGFLG
    19 				;                                                                  NSIGN  DIGRT          ZTEMP3
    20 				;                                                                EEXP  FCHRFLG       ZTEMP4        FPTR2       FPSCR
    21 				;                                                              FRX   ESIGN CIX   ZTEMP1        FLPTR     PLYARG      FPSCR1
    22 				;              $D4     $D8     $DC     $E0     $E4     $E8     $EC     $F0     $F4     $F8     $FC     | $05E0 $05E6 $05EC
    23 				;              . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . | ..................
    24 				;              [-- FR0 --] [-- FRE --] [-- FR1 --] [-- FR2 --]               [-] [-] [-] [-]   [-] [-] |
    25 				; FADD/FSUB    M M M M M M M . . . !!! M M M M M M . . . . . . . . . ! ! . . . . . . M M M . ! . . . . |
    26 				; FMUL         M M M M M M M M M M M M M r r r r r M M M M M M M M M ! ! . . . . M M M . . . ! . . . . |
    27 				; FDIV         M M M M M M M M M M M M M r r r r r M M M M M M M M M ! ! . . . . M . M . . . ! . . . . |
    28 				; PLYEVL       M M M M M M M M M M M M M M M M M M M M M M M M M M M M ! . . . . M M M M M . ! M M M M | MMMMMM............
    29 				; EXP/EXP10    M M M M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . M M M M M . ! M M M M | MMMMMM............
    30 				; LOG/LOG10    M M M M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . M M M M M . ! M M M M | MMMMMMMMMMMM......
    31 				; REDRNG       M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . . . . M . M . . . ! M M M M | MMMMMMMMMMMM......
    32 				;
    33 				; AFP          M M M M M M M . . . . . . . . . . . . . . . . . M M M M M M M . . . . . . . . ! . . . . |
    34 				; FASC         r r r r r r . . . . . . . . . . . . . . . . . . . M . . . . M M M . . M . . . ! . . . . |
    35 				; IPF          M M M M M M . . . . !!! . . . . . . . . . . . . . . . . . . . . . . . . M M . ! . . . . |
    36 				; FPI          M M M M M M . . . . . . !!!!!!!!!!! . . . . . . M . . . . . . . . M . M M M M ! . . . . |
    37 				;
    38 				; M = modified by original math pack
    39 				; r = read by original math pack
    40 				; ! = program known to rely on not being modified
    41 				;
    42 				; Notes:
    43 				; [1] BASIC XE relies on $DE/DF not being touched by FADD, or FOR/NEXT
    44 				;     breaks.
    45 				; [2] MAC/65 relies on $DE/DF not being touched by IPF.
    46 				; [3] DARG relies on FPI not touching FR1.
    47 				; [4] ACTris 1.2 relies on FASC not touching lower parts of FR2.
    48 				; [5] Atari BASIC SQR() uses ESIGN ($EF).
    49 				; [6] Atari BASIC SIN() uses FCHRFLG ($F0).
    50 				;
    51
    52 = 00EC			_fpcocnt = $00ec			;FP: temporary storage - polynomial coefficient counter
    53 = 00F8			_fptemp0 = $00f8			;FP: temporary storage - transcendental temporary (officially ZTEMP4+1)
    54 = 00F9			_fptemp1 = $00f9			;FP: temporary storage - transcendental temporary (officially ZTEMP3)
    55
    56 				.macro	ckaddr
    57 				.if * <> %%1
    58 						.error	'Incorrect address: ',*,' != ',%%1
    59 				.endif
    60 				.endm
    61
    62 				.macro	fixadr
    63 				.if * < %%1
    64 						.print (%%1-*),' bytes free before ',%%1
    65 						org		%%1
    66 				.elif * > %%1
    67 						.error 'Out of space: ',*,' > ',%%1,' (',*-%%1,' bytes over)'
    68 						.endif
    69 				.endm
    70
