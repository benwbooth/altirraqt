   220 				; Open command ($03).
   221 				;
   222 E5B5			cmdOpen:
   223 					;check if the IOCB is already open
   224 E5B5 A4 20			ldy		ichidz
   225 E5B7 C8				iny
   226 E5B8 F0 03			beq		notAlreadyOpen
   227 					
   228 					;IOCB is already open - error
   229 E5BA A0 81			ldy		#CIOStatIOCBInUse
   230 E5BC 60				rts
   231 					
   232 E5BD			notAlreadyOpen:
   233 					;attempt to parse and open -- note that this will fail out directly
   234 					;on an unknown device or provisional open
   235 E5BD 20 09 E7			jsr		CIOParsePath
   236
   237 E5C0			open_entry:
   238 					;request open
   239 E5C0 A0 01			ldy		#1
   240 E5C2 20 E8 E6			jsr		CIOInvoke
   241
   242 					;move handler ID and device number to IOCB
   243 E5C5 A6 2E			ldx		icidno
   244 E5C7 A5 20 9D 40 03		mva		ichidz ichid,x
   245 E5CC A5 21 9D 41 03		mva		icdnoz icdno,x
   246
   247 E5D1 98				tya
   248 E5D2 10 01			bpl		openOK
   249 E5D4 60				rts
   250 					
   251 E5D5			openOK:
   252
   253 					;copy PUT BYTE vector for Atari Basic
   254 E5D5 A6 20			ldx		ichidz
   255 E5D7 BD 1B 03 85 2C BD + 	mwa		hatabs+1,x icax3z
   256 E5E1 A0 06			ldy		#6
   257 E5E3 B1 2C			lda		(icax3z),y
   258 E5E5 A6 2E			ldx		icidno
   259 E5E7 9D 46 03			sta		icptl,x
   260 E5EA C8				iny
   261 E5EB B1 2C			lda		(icax3z),y
   262 E5ED 9D 47 03			sta		icpth,x
   263 E5F0 A0 01			ldy		#1
   264 E5F2 60				rts
   265
   266 = E6EB			cmdGetStatus = CIOInvoke.invoke_vector
   267 E5F3			cmdSpecial:
   268 E5F3 20 EB E6			jsr		CIOInvoke.invoke_vector
   269
   270 					;need to copy AUX1/2 back for R:
   271 E5F6 A6 2E			ldx		icidno
   272 E5F8 A5 2A 9D 4A 03		mva		icax1z icax1,x
   273 E5FD A5 2B 9D 4B 03		mva		icax2z icax2,x
   274 E602 60				rts
   275 					
   276 				;--------------------------------------------------------------------------
   277 E603			cmdGetRecord:
   278 					;check if buffer is full on entry
   279 E603 F0 16			beq		cmdGetRecordBufferFull
   280 E605			cmdGetRecordLoop:
   281 E605			cmdGetRecordGetByte:
   282 					;fetch byte
   283 E605 20 EB E6			jsr		CIOInvoke.invoke_vector
   284 E608 C0 00			cpy		#0
   285 E60A 30 1C			bmi		cmdGetRecordXit
   286 					
   287 					;store byte (even if EOL)
   288 E60C A2 00			ldx		#0
   289 E60E 81 24			sta		(icbalz,x)
   290
   291 					;check for EOL
   292 E610 49 9B			eor		#$9b
   293 E612 C9 01			cmp		#1
   294
   295 					;increment buffer pointer and decrement length
   296 E614 20 9B E6			jsr		advance_pointers
   297
   298 					;skip buffer full check if we had an EOL
   299 E617 90 0F			bcc		cmdGetRecordXit
   300
   301 					;loop back for more bytes if buffer not full
   302 E619 D0 EA			bne		cmdGetRecordLoop
   303 					
   304 E61B			cmdGetRecordBufferFull:
   305 					;read byte to discard
   306 E61B 20 EB E6			jsr		CIOInvoke.invoke_vector
   307 E61E C0 00			cpy		#0
   308 E620 30 06			bmi		cmdGetRecordXit
   309
   310 					;continue if not EOL
   311 E622 C9 9B			cmp		#$9b
   312 E624 D0 F5			bne		cmdGetRecordBufferFull
   313
   314 					;return truncated record
   315 E626 A0 89			ldy		#CIOStatTruncRecord
   316
   317 E628			cmdGetRecordXit:
   318 E628			cmdGetPutDone:
   319 					;update byte count in IOCB
   320 E628 A6 2E			ldx		icidno
   321 E62A 38				sec
   322 E62B BD 48 03			lda		icbll,x
   323 E62E E5 28			sbc		icbllz
   324 E630 9D 48 03			sta		icbll,x
   325 E633 BD 49 03			lda		icblh,x
   326 E636 E5 29			sbc		icblhz
   327 E638 9D 49 03			sta		icblh,x
   328
   329 					;NOMAM 2013 BASIC Ten-Liners disk requires ICBALZ to be untouched :P
   330 E63B BD 44 03 85 24 BD + 	mwa		icbal,x icbalz
   331 					
   332 					;Pacem in Terris requires Y=1 exit.
   333 					;DOS 3.0 with 128K/XE mode requires Y=3 for EOF imminent.
   334 E645 60				rts
   335 					
   336 				;--------------------------------------------------------------------------
   337 E646			cmdGetChars:
   338 E646 F0 15			beq		cmdGetCharsSingle
   339 E648			cmdGetCharsLoop:
   340 E648 20 EB E6			jsr		CIOInvoke.invoke_vector
   341 E64B C0 00			cpy		#0
   342 E64D 30 0B			bmi		cmdGetCharsError
   343 E64F A2 00			ldx		#0
   344 E651 85 2F			sta		ciochr					;required by HOTEL title screen
   345 E653 81 24			sta		(icbalz,x)
   346 E655 20 9B E6			jsr		advance_pointers
   347 E658 D0 EE			bne		cmdGetCharsLoop
   348 E65A			cmdGetCharsError:
   349 E65A 4C 28 E6			jmp		cmdGetPutDone
   350 					
   351 E65D			cmdGetCharsSingle:
   352 E65D 20 EB E6			jsr		CIOInvoke.invoke_vector
   353 E660 85 2F			sta		ciochr
   354 E662 60				rts
   355 					
   356 				;--------------------------------------------------------------------------
   357 				; PUT RECORD handler ($09)
   358 				;
   359 				; Exit:
   360 				;	ICBAL/ICBAH: Not changed
   361 				;	ICBLL/ICBLH: Number of bytes processed
   362 				;
   363 				; If the string does not contain an EOL character, one is printed at the
   364 				; end. Also, in this case CIOCHR must reflect the last character in the
   365 				; buffer and not the EOL. (Required by Atari DOS 2.5 RAMDISK banner)
   366 				;
   367 				; If length=0, the character in the A register is output without an EOL.
   368 				; This behavior is required by the graphics library for Mad Pascal.
   369 				;
   370 E663			cmdPutRecord:
   371 E663 F0 33			beq		cmdPutCharsSingle
   372 E665			cmdPutRecordLoop:
   373 E665 A0 00			ldy		#0
   374 E667 B1 24			lda		(icbalz),y
   375 E669 20 EB E6			jsr		CIOInvoke.invoke_vector
   376 E66C 98				tya
   377 E66D 30 12			bmi		cmdPutRecordError
   378 E66F 20 9B E6			jsr		advance_pointers
   379 E672 F0 08			beq		cmdPutRecordEOL
   380 E674 A9 9B			lda		#$9b
   381 E676 C5 2F			cmp		ciochr
   382 E678 F0 07			beq		cmdPutRecordDone
   383 E67A D0 E7			bne		cmdPutRecord
   384 					
   385 E67C			cmdPutRecordEOL:
   386 E67C A9 9B			lda		#$9b
   387 E67E 20 EB E6			jsr		CIOInvoke.invoke_vector
   388 E681			cmdPutRecordError:
   389 E681			cmdPutRecordDone:
   390 E681 4C 28 E6			jmp		cmdGetPutDone
   391 					
   392 				;--------------------------------------------------------------------------
   393 E684			cmdPutChars:
   394 E684 F0 12			beq		cmdPutCharsSingle
   395 E686			cmdPutCharsLoop:
   396 E686 A0 00			ldy		#0
   397 E688 B1 24			lda		(icbalz),y
   398 E68A 20 EB E6			jsr		CIOInvoke.invoke_vector
   399 E68D 98				tya
   400 E68E 30 F1			bmi		cmdPutRecordError
   401 E690 20 9B E6			jsr		advance_pointers
   402 E693 D0 F1			bne		cmdPutCharsLoop
   403 E695 4C 28 E6			jmp		cmdGetPutDone
   404 E698			cmdPutCharsSingle:
   405 E698 4C ED E6			jmp		CIOInvoke.invoke_vector_ciochr
   406 					
   407 				;--------------------------------------------------------------------------
   408
   409 E69B			advance_pointers:
   410 E69B E6 24 D0 02 E6 25		inw		icbalz
   411 E6A1 A5 28 D0 02 C6 29 + 	dew		icbllz
   412 E6A9 D0 02 A5 29			sne:lda	icblhz
   413 E6AD 60				rts
   414
   415 				;--------------------------------------------------------------------------
   416 E6AE			cmdClose:
   417 E6AE 20 EB E6			jsr		CIOInvoke.invoke_vector
   418 E6B1			cmdCloseProvisional:	
   419 E6B1 A6 2E			ldx		icidno
   420 E6B3 20 6D E7			jsr		CIOSetPutByteClosed
   421 E6B6 A9 FF 9D 40 03		mva		#$ff	ichid,x
   422 E6BB 60				rts
   423
   424 E6BC			perm_check_table:
   425 E6BC 04				dta		$04					;$04 (get record)
   426 E6BD 04				dta		$04					;$05 (get record)
   427 E6BE 04				dta		$04					;$06 (get chars)
   428 E6BF 04				dta		$04					;$07 (get chars)
   429 E6C0 08				dta		$08					;$08 (put record)
   430 E6C1 08				dta		$08					;$09 (put record)
   431 E6C2 08				dta		$08					;$0A (put chars)
   432 E6C3 08				dta		$08					;$0B (put chars)
   433 E6C4 FF				dta		$ff					;$0C (close)
   434 E6C5 FF				dta		$ff					;$0D (get status)
   435 E6C6 FF				dta		$ff					;$0E (special)
   436
   437 E6C7			vector_preload_table:
   438 E6C7 05				dta		$05					;$04 (get record)
   439 E6C8 05				dta		$05					;$05 (get record)
   440 E6C9 05				dta		$05					;$06 (get chars)
   441 E6CA 05				dta		$05					;$07 (get chars)
   442 E6CB 07				dta		$07					;$08 (put record)
   443 E6CC 07				dta		$07					;$09 (put record)
   444 E6CD 07				dta		$07					;$0A (put chars)
   445 E6CE 07				dta		$07					;$0B (put chars)
   446 E6CF 03				dta		$03					;$0C (close)
   447 E6D0 09				dta		$09					;$0D (get status)
   448 E6D1 0B				dta		$0b					;$0E (special)
   449
   450 E6D2			command_table_lo:
   451 E6D2 02				dta		<(cmdGetRecord-1)	;$04
   452 E6D3 02				dta		<(cmdGetRecord-1)	;$05
   453 E6D4 45				dta		<(cmdGetChars-1)	;$06
   454 E6D5 45				dta		<(cmdGetChars-1)	;$07
   455 E6D6 62				dta		<(cmdPutRecord-1)	;$08
   456 E6D7 62				dta		<(cmdPutRecord-1)	;$09
   457 E6D8 83				dta		<(cmdPutChars-1)	;$0A
   458 E6D9 83				dta		<(cmdPutChars-1)	;$0B
   459 E6DA AD				dta		<(cmdClose-1)		;$0C
   460 E6DB EA				dta		<(cmdGetStatus-1)	;$0D
   461 E6DC F2				dta		<(cmdSpecial-1)		;$0E
   462
   463 E6DD			command_table_hi:
   464 E6DD E6				dta		>(cmdGetRecord-1)	;$04
   465 E6DE E6				dta		>(cmdGetRecord-1)	;$05
   466 E6DF E6				dta		>(cmdGetChars-1)	;$06
   467 E6E0 E6				dta		>(cmdGetChars-1)	;$07
   468 E6E1 E6				dta		>(cmdPutRecord-1)	;$08
   469 E6E2 E6				dta		>(cmdPutRecord-1)	;$09
   470 E6E3 E6				dta		>(cmdPutChars-1)	;$0A
   471 E6E4 E6				dta		>(cmdPutChars-1)	;$0B
   472 E6E5 E6				dta		>(cmdClose-1)		;$0C
   473 E6E6 E6				dta		>(cmdGetStatus-1)	;$0D
   474 E6E7 E5				dta		>(cmdSpecial-1)		;$0E
   475 				.endp
