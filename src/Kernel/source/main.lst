   354 F00D A0 06			ldy		#6
   355 F00F 29 0E			and		#$0e
   356 F011 D0 02			bne		is_ntsc
   357 F013 E8				inx
   358 F014 88				dey
   359 F015			is_ntsc:
   360 F015 86 62			stx		palnts
   361 F017 8C DA 02			sty		keyrep
   362 F01A BD EE EF 8D D9 02		mva		krpdel_table,x krpdel
   363 				.endif
   364 					
   365 					; 10. initialize RAM vectors
