   180 				;==============================================================================
   181 				; Keyboard IRQ
   182 				;
   183 				; HELP button ($11, $51, and $91):
   184 				; - Affects SRTIMR, ATRACT, KEYDEL, and HELPFG
   185 				; - Does NOT affect CH, CH1
   186 				;
   187 FED5			.proc	KeyboardIRQ
   188 					;reset software repeat timer
   189 				.if _KERNEL_XLXE
   190 FED5 AD D9 02 8D 2B 02		mva		krpdel	srtimr
   191 				.else
   192 					mva		#$30	srtimr
   193 				.endif
   194 					
   195 					;read new key
   196 FEDB AD 09 D2			lda		kbcode
   197
   198 				.if _KERNEL_XLXE
   199 					;save key
   200 FEDE 48				pha
   201
   202 					;check for HELP
   203 FEDF 29 3F			and		#$3f
   204 FEE1 C9 11			cmp		#$11
   205 FEE3 D0 06			bne		not_help
   206
   207 					;restore HELP key with original modifiers
   208 FEE5 68				pla
   209 FEE6 8D DC 02			sta		helpfg
   210 FEE9 D0 1C			bne		xit2
   211
   212 FEEB			not_help:
   213 					;restore key
   214 FEEB 68				pla
   215 				.endif
   216 					
   217 					;check if it is the same as the prev key
   218 FEEC CD F2 02			cmp		ch1
   219 FEEF D0 08			bne		debounced
   220
   221 					;reject key if debounce timer is still running	
   222 FEF1 AD F1 02			lda		keydel
   223 FEF4 D0 16			bne		xit
   224 FEF6 AD F2 02			lda		ch1	
   225 FEF9			debounced:
   226
   227 					;check for Ctrl+1 to toggle display activity
   228 FEF9 C9 9F			cmp		#$9f
   229 FEFB F0 11			beq		is_suspend
   230
   231 					;store key
   232 FEFD 8D FC 02			sta		ch
   233 FF00 8D F2 02			sta		ch1
   234
   235 					;reset attract
   236 FF03 A9 00 85 4D			mva		#0		atract
   237 					
   238 FF07			xit2:
   239 					;reset key delay
   240 FF07 A9 03 8D F1 02		mva		#3 keydel
   241
   242 FF0C			xit:
   243 					;all done
   244 FF0C 68				pla
   245 FF0D 40				rti	
   246
   247 FF0E			is_suspend:
   248 					;toggle stop/start flag
   249 FF0E AD FF 02			lda		ssflag
   250 FF11 49 FF			eor		#$ff
   251 FF13 8D FF 02			sta		ssflag
   252 FF16 B0 EF			bcs		xit2			;!! carry set from cmp #$9f!
   253 				.endp
   254
   255 				;==============================================================================
   256 FF18			.proc	KeyboardBreakIRQ
   257 FF18 A9 00 85 11			mva		#0		brkkey
   258
   259 					;need to clear the suspend flag as BREAK automatically nukes a pending Ctrl+1
   260 FF1C 8D FF 02			sta		ssflag
   261 					
   262 					;interestingly, the default break handler forces the cursor back on.
   263 FF1F 8D F0 02			sta		crsinh
   264 					
   265 FF22 68				pla
   266 FF23 40				rti
   267 				.endp
   284 					.endif
