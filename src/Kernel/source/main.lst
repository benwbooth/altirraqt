  1849 				;==========================================================================
  1850 				; log10(x) coefficients
  1851 				;
  1852 				; LOG10 computes:
  1853 				;							-0.30 <= z <= 3.0
  1854 				;	y = (z-1)/(z+1)			-0.54 <= y <= 0.5
  1855 				;	x = y^2					0 <= x <= 0.29
  1856 				;	log10(z) = f(x)*y
  1857 				;
  1858 				; Therefore:
  1859 				;	f(x) = log10((1+y)/(1-y))/y
  1860 				;
  1861 DF72			fpconst_log10coeff:		;Maclaurin series expansion for log10((z-1)/(z+1))
  1862 DF72 3F 20 26 22 71 54		dta		$3F,$20,$26,$22,$71,$54	; 0.2026227154
  1863 DF78 BF 07 32 04 49 21		dta		$BF,$07,$32,$04,$49,$21	;-0.0732044921
  1864 DF7E 3F 10 60 98 35 64		dta		$3F,$10,$60,$98,$35,$64	; 0.1060983564
  1865 DF84 3F 05 60 41 73 29		dta		$3F,$05,$60,$41,$73,$29	; 0.0560417329
  1866 DF8A 3F 08 04 18 84 07		dta		$3F,$08,$04,$18,$84,$07	; 0.0804188407
  1867 DF90 3F 09 63 91 60 15		dta		$3F,$09,$63,$91,$60,$15	; 0.0963916015
  1868 DF96 3F 12 40 89 61 35		dta		$3F,$12,$40,$89,$61,$35	; 0.1240896135
  1869 DF9C 3F 17 37 17 66 46		dta		$3F,$17,$37,$17,$66,$46	; 0.1737176646
  1870 DFA2 3F 28 95 29 65 58		dta		$3F,$28,$95,$29,$65,$58	; 0.2895296558
  1871 DFA8 3F 86 85 88 96 38		dta		$3F,$86,$85,$88,$96,$38	; 0.8685889638
  1872
  1873 				;==========================================================================
  1874 				; Arctangent coefficients
  1875 				;
  1876 				; The 11 coefficients here form a power series approximation
  1877 				; f(x^2) ~= atn(x)/x. This is not an official feature of the math pack but
  1878 				; is relied upon by BASIC.
  1879 				;
  1880 				; We used to use the coefficients from Abramowitz & Stegun 4.4.49 here, but
  1881 				; there seems to be an error there such that the result falls far short
  1882 				; of the specified 2x10^-8 accuracy over 0<=x<=1 at x=1. Instead, we now
  1883 				; use a custom minimax polynomial for f(y)=atn(sqrt(y))/sqrt(y) where y=x^2.
  1884 				;
  1885 DFAE				fixadr	$dfae
