  1527 				;==========================================================================
  1528 				; Hide the screen cursor, if it is present.
  1529 				;
  1530 				; Modified:
  1531 				;	Y
  1532 				;
  1533 				; Preserved:
  1534 				;	A
  1535 				;
  1536 F8F0			.proc ScreenHideCursor	
  1537 					;erase the cursor
  1538 F8F0 48				pha
  1539 F8F1 A0 00			ldy		#0
  1540 F8F3 A5 5D			lda		oldchr
  1541 F8F5 91 5E			sta		(oldadr),y
  1542 F8F7 68				pla
  1543 F8F8			no_cursor:
  1544 F8F8 60				rts
  1545 				.endp
